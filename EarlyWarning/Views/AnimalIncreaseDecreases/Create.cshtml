@model EarlyWarning.Models.AnimalSupply.AnimalIncreaseDecrease

@{
    ViewData["Title"] = "አዲስ የእንስሳት አቅርቦት ለውጥ ምክንያት";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Custom Styles */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 25px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
            transform: rotate(45deg);
        }

        .page-header h1 {
            margin: 0;
            font-size: 1.6rem;
            position: relative;
            z-index: 1;
        }

        .page-header p {
            margin: 8px 0 0;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

    .form-container {
        max-width: 100%;
        margin: 0 auto;
        padding: 0 15px;
    }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .form-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.15);
        }

    .card-header-custom {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 20px;
        font-weight: 600;
    }

        .card-header-custom i {
            margin-right: 8px;
        }

    .card-body-custom {
        padding: 25px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        font-size: 0.9rem;
    }

        .form-label i {
            margin-right: 5px;
            color: #fa709a;
        }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 10px 12px;
        width: 100%;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #fa709a;
            box-shadow: 0 0 0 0.2rem rgba(250, 112, 154, 0.25);
            outline: none;
        }

    .radio-group {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin-top: 5px;
    }

    .radio-option {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 15px;
        background: #f8f9fa;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .radio-option:hover {
            background: #e9ecef;
        }

        .radio-option input {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .radio-option.selected {
            background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
            color: #333;
        }

            .radio-option.selected i {
                color: #333;
            }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 25px;
    }

    .btn-custom {
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-submit {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
    }

    .btn-back {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white;
    }

    .btn-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        color: white;
    }

    .text-danger {
        color: #dc3545;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .info-hint {
        background: #fff3e6;
        border-left: 3px solid #fa709a;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    /* Full Screen Layout */
    .fullscreen-layout {
        min-height: calc(100vh - 100px);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .fullscreen-layout .form-card {
            max-width: 700px;
            margin: 0 auto;
            width: 100%;
        }

    @@media (max-width: 768px) {
        .fullscreen-layout {
            min-height: auto;
            padding: 20px 0;
        }

            .fullscreen-layout .form-card {
                max-width: 100%;
            }

        .card-body-custom {
            padding: 20px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-custom {
            width: 100%;
            text-align: center;
        }

        .radio-group {
            flex-direction: column;
        }

        .page-header h1 {
            font-size: 1.3rem;
        }
    }
</style>

<div class="container-fluid">
    <div class="form-container">
        <!-- Page Header -->
        <div class="page-header">
            <h1>
                <i class="fas fa-plus-circle"></i> @ViewData["Title"]
            </h1>
            <p>እባክዎ አዲስ የእንስሳት አቅርቦት ለውጥ ምክንያት ይሙሉ</p>
        </div>

        <!-- Form Card -->
        <div class="form-card">
            <div class="card-header-custom">
                <i class="fas fa-paw"></i> የምክንያት መረጃ
            </div>
            <div class="card-body-custom">
                <form asp-action="Create" method="post" id="animalReasonForm">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <!-- Reason Name -->
                    <div class="form-group">
                        <label asp-for="ReasonName" class="form-label">
                            <i class="fas fa-tag"></i> @Html.DisplayNameFor(m => m.ReasonName)
                            <span class="text-danger">*</span>
                        </label>
                        <input asp-for="ReasonName" class="form-control" placeholder="ለምሳሌ፦ የመኸር ወቅት በመሆኑ, የእንስሳት በሽታ መከሰት, ወዘተ..." />
                        <span asp-validation-for="ReasonName" class="text-danger"></span>
                        <div class="info-hint">
                            <i class="fas fa-info-circle"></i> የምክንያቱን ግልጽ እና አጭር መግለጫ ያስገቡ (ከ2 እስከ 200 ቁምፊዎች)
                        </div>
                    </div>

                    <!-- Reason Type -->
                    <div class="form-group">
                        <label asp-for="ReasonType" class="form-label">
                            <i class="fas fa-chart-line"></i> @Html.DisplayNameFor(m => m.ReasonType)
                            <span class="text-danger">*</span>
                        </label>
                        <div class="radio-group">
                            <label class="radio-option">
                                <input type="radio" asp-for="ReasonType" value="1" />
                                <i class="fas fa-arrow-up text-success"></i> ጨምሯል
                            </label>
                            <label class="radio-option">
                                <input type="radio" asp-for="ReasonType" value="2" />
                                <i class="fas fa-arrow-down text-danger"></i> ቀንሷል
                            </label>
                        </div>
                        <span asp-validation-for="ReasonType" class="text-danger"></span>
                        <div class="info-hint">
                            <i class="fas fa-info-circle"></i> የእንስሳት አቅርቦት ከባለፈው ሳምንት ጋር ሲነጻጸር ያለውን ለውጥ ይምረጡ
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="action-buttons">
                        <a asp-action="Index" class="btn-custom btn-back">
                            <i class="fas fa-arrow-left"></i> ወደ ዝርዝር ተመለስ
                        </a>
                        <button type="submit" class="btn-custom btn-submit">
                            <i class="fas fa-save"></i> መዝግብ
                        </button>
                    </div>
                </form>
            </div>
        </div>

        
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Radio button styling
            $('.radio-option').on('click', function() {
                $(this).find('input').prop('checked', true);
                $('.radio-option').removeClass('selected');
                $(this).addClass('selected');
            });

            // Check if any radio is preselected
            if ($('input[name="ReasonType"]:checked').length > 0) {
                var checkedValue = $('input[name="ReasonType"]:checked').val();
                $('.radio-option').removeClass('selected');
                $('.radio-option input[value="' + checkedValue + '"]').closest('.radio-option').addClass('selected');
            }

            // Set default selection (optional - uncomment if you want default)
            // if ($('input[name="ReasonType"]:checked').length === 0) {
            //     $('input[name="ReasonType"][value="1"]').prop('checked', true);
            //     $('.radio-option input[value="1"]').closest('.radio-option').addClass('selected');
            // }

            // Auto capitalize first letter of reason name
            $('#ReasonName').on('blur', function() {
                var value = $(this).val();
                if (value) {
                    $(this).val(value.charAt(0).toUpperCase() + value.slice(1).toLowerCase());
                }
            });

            // Character limit for reason name
            $('#ReasonName').on('input', function() {
                var length = $(this).val().length;
                var maxLength = 200;

                if (length > maxLength) {
                    $(this).val($(this).val().substring(0, maxLength));
                    alert('የምክንያት ስም ከ200 ቁምፊዎች መብለጥ አይችልም');
                }
            });

            // Form validation before submit
            $('#animalReasonForm').on('submit', function(e) {
                var reasonName = $('#ReasonName').val().trim();
                var reasonType = $('input[name="ReasonType"]:checked').val();

                if (!reasonName) {
                    e.preventDefault();
                    alert('እባክዎ የምክንያት ስም ያስገቡ');
                    $('#ReasonName').focus();
                    return false;
                }

                if (reasonName.length < 2) {
                    e.preventDefault();
                    alert('የምክንያት ስም ቢያንስ 2 ቁምፊዎች መሆን አለበት');
                    $('#ReasonName').focus();
                    return false;
                }

                if (!reasonType) {
                    e.preventDefault();
                    alert('እባክዎ የምክንያት አይነት ይምረጡ');
                    return false;
                }

                return true;
            });
        });
    </script>
}