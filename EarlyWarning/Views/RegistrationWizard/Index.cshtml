@model List<RegistrationWizardIndexViewModel>
@{
    ViewData["Title"] = "የምዝገባ ውጤቶች";
}
<h2>@ViewData["Title"]</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">ምንም የተመዘገበ ውሂብ የለም።</div>
}
else
{
    foreach (var item in Model)
    {
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h4>@item.WoredaName - ከ @item.StartDate?.ToString("yyyy-MM-dd") እስከ @item.EndDate?.ToString("yyyy-MM-dd")</h4>
            </div>
            <div class="card-body">
                <!-- 1. Rainfall Report -->
                <h5>የዝናብ መጠን ሪፖርት</h5>
                @if (item.RainfallReport != null)
                {
                    <dl class="row">
                        <dt class="col-sm-3">ሙሉ ሽፋን ቀበሌዎች</dt>
                        <dd class="col-sm-3">@item.RainfallReport.FullCoverageKebeles</dd>
                        <dt class="col-sm-3">ከፊል ሽፋን</dt>
                        <dd class="col-sm-3">@item.RainfallReport.PartialCoverageKebeles</dd>
                        <dt class="col-sm-3">ዝናብ ያልነበረ</dt>
                        <dd class="col-sm-3">@item.RainfallReport.NoRainKebeles</dd>
                        <dt class="col-sm-3">ውሂብ የሌለ</dt>
                        <dd class="col-sm-3">@item.RainfallReport.NoDataKebeles</dd>
                    </dl>
                    <dl class="row">
                        <dt class="col-sm-3">ዝቅተኛ ዝናብ</dt>
                        <dd class="col-sm-3">@item.RainfallReport.LowAmountKebeles</dd>
                        <dt class="col-sm-3">ዝቅተኛ-መካከለኛ</dt>
                        <dd class="col-sm-3">@item.RainfallReport.LowMediumAmountKebeles</dd>
                        <dt class="col-sm-3">መካከለኛ</dt>
                        <dd class="col-sm-3">@item.RainfallReport.MediumAmountKebeles</dd>
                        <dt class="col-sm-3">ከፍተኛ</dt>
                        <dd class="col-sm-3">@item.RainfallReport.HighAmountKebeles</dd>
                    </dl>
                    <p><strong>የተመረጡ ቀበሌዎች:</strong> @string.Join(", ", item.KebeleNames)</p>
                }
                else
                {

                    <p>ሪፖርት የለም</p>
                }

                <!-- 2. Farming Activity -->
                <h5>የእርሻ እንቅስቃሴ</h5>
                @if (item.FarmingActivity != null)
                {
                    <dl class="row">
                        <dt class="col-sm-3">የተዘራ ቦታ (ሄክ)</dt>
                        <dd class="col-sm-3">@item.FarmingActivity.MeherFarmPlan</dd>
                        <dt class="col-sm-3">የሰብል አይነት</dt>
                        <dd class="col-sm-3">@item.FarmingActivity.AutumnPloughed</dd>
                        <dt class="col-sm-3">የመከር ሁኔታ</dt>
                        <dd class="col-sm-3">@item.FarmingActivity.AutumnFarmPlan</dd>
                    </dl>
                }
                else
                {

                    <p>ሪፖርት የለም</p>
                }

                <!-- 3. Crop Pest/Disease -->
                <h5>የሰብል ተባይ/በሽታ</h5>
                @if (item.CropPestAndDeseaseReport != null)
                {
                    <p><strong>ተባይ/በሽታ አጋጥሟል?</strong> @(item.CropPestAndDeseaseReport.HasPestAndDeseasOccured ? "አዎ" : "አይ")</p>
                    if (item.CropPestAndDeseaseReport.HasPestAndDeseasOccured)
                    {
                        <p><strong>የተጎዳ መሬት (ሄክ):</strong> @item.CropPestAndDeseaseReport.AffectedLandInHectar</p>
                        <p><strong>የተጎዳ ሰብል:</strong> @item.CropPestAndDeseaseReport.TypeOfCropAffected</p>
                        <p><strong>ተባዮች/በሽታዎች:</strong> @string.Join(", ", item.CropDiseaseNames)</p>
                    }
                }
                else
                {

                    <p>ሪፖርት የለም</p>
                }

                <!-- 4. Pasture Status -->
                <h5>የግጦሽ መሬት ሁኔታ</h5>
                @if (item.PastureStatus != null)
                {
                    <p><strong>በቂ ነው?</strong> @(item.PastureStatus.Enough ? "በቂ" : "በቂ አይደለም")</p>
                    if (!item.PastureStatus.Enough)
                    {
                        <dl class="row">
                            <dt class="col-sm-3">ዝቅተኛ</dt>
                            <dd class="col-sm-3">@item.PastureStatus.TotalAffected</dd>
                            <dt class="col-sm-3">የተጎዱ እንስሳት</dt>
                            <dd class="col-sm-3">@item.PastureStatus.NumberOfAnimalsAffected</dd>
                            <dt class="col-sm-3">ጠቅላላ ተጎጂዎች</dt>
                            <dd class="col-sm-3">@(item.PastureStatus.TotalMale + item.PastureStatus.TotalFemale)</dd>
                        </dl>
                    }
                }
                else
                {

                    <p>ሪፖርት የለም</p>
                }

                <!-- 5. Animal Water Supply -->
                <h5>የእንስሳት ውሃ አቅርቦት</h5>
                @if (item.AnimalWaterSupplyStatus != null)
                {
                    <p><strong>በቂ ነው?</strong> @(item.AnimalWaterSupplyStatus.Enough ? "በቂ" : "በቂ አይደለም")</p>
                    if (!item.AnimalWaterSupplyStatus.Enough)
                    {
                        <dl class="row">
                            <dt class="col-sm-3">የግጦሽ ችግር ቀበሌዎች</dt>
                            <dd class="col-sm-3">@item.AnimalWaterSupplyStatus.NoOfKebeliesWithPastureShortage</dd>
                            <dt class="col-sm-3">የውሃ ችግር ቀበሌዎች</dt>
                            <dd class="col-sm-3">@item.AnimalWaterSupplyStatus.NoOfKebeliesWithWaterSupply</dd>
                        </dl>
                    }
                }
                else
                {

                    <p>ሪፖርት የለም</p>
                }

                <!-- 6. Animal Health -->
                <h5>የእንስሳት ጤና</h5>
                @if (item.AnimalHealthStatus != null)
                {
                    <p><strong>በሽታ አለ?</strong> @(item.AnimalHealthStatus.Enough ? "አለ" : "የለም")</p>
                    if (item.AnimalHealthStatus.Enough)
                    {
                        <p><strong>በሽታዎች:</strong> @string.Join(", ", item.AnimalDiseaseNames)</p>
                        <p><strong>ጠቅላላ ተጎጂዎች:</strong> @(item.AnimalHealthStatus.TotalMale + item.AnimalHealthStatus.TotalFemale)</p>
                    }
                }
                else
                {

                    <p>ሪፖርት የለም</p>
                }

                <hr />
                <small class="text-muted">ሁኔታ: ረቂቅ / ቀርቧል / ጸድቋል (እያንዳንዱ ሪፖርት የራሱ ሁኔታ አለው) </small>
            </div>
        </div>
    }
}