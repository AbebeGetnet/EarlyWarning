@model RegistrationWithardViewModel
@{
    ViewData["Title"] = "የሁሉም ሪፖርቶች ምዝገባ";
}
<h2>@ViewData["Title"]</h2>
<form method="post" id="wizardForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="WoredaId" />

    <!-- Shared Info Card -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5>መሠረታዊ መረጃ</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <label>ወረዳ</label>
                    <input class="form-control" value="@ViewBag.WoredaName" readonly disabled />
                </div>
                <div class="col-md-4">
                    <label asp-for="StartDate"></label>
                    <input asp-for="StartDate" type="date" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label asp-for="EndDate"></label>
                    <input asp-for="EndDate" type="date" class="form-control" required />
                </div>
            </div>
        </div>
    </div>

    <!-- 1. Rainfall Report -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h5>የዝናብ መጠን ሪፖርት</h5>
        </div>
        <div class="card-body">
            <!-- Kebele selection (multi‑select) -->
            <div class="mb-3">
                <label class="fw-bold">የተጎዱ ቀበሌዎች ይምረጡ (ለዝናብ እጥረት / ጎርፍ)</label>
                <div class="row">
                    @foreach (var kebele in Model.Kebelies)
                    {
                        bool isChecked = Model.SelectedKebeliesIds?.Contains(kebele.Id) ?? false;
                        <div class="col-md-3">
                            <div class="form-check">
                                <input type="checkbox" name="SelectedKebeliesIds" value="@kebele.Id" class="form-check-input" id="kebele_@kebele.Id" @(isChecked ? "checked" : "") />
                                <label class="form-check-label" for="kebele_@kebele.Id">@kebele.LocationName</label>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="row">
                <div class="col-md-3"><label asp-for="RainfallReport.FullCoverageKebeles"></label><input asp-for="RainfallReport.FullCoverageKebeles" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="RainfallReport.PartialCoverageKebeles"></label><input asp-for="RainfallReport.PartialCoverageKebeles" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="RainfallReport.NoRainKebeles"></label><input asp-for="RainfallReport.NoRainKebeles" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="RainfallReport.NoDataKebeles"></label><input asp-for="RainfallReport.NoDataKebeles" class="form-control" /></div>
            </div>
            <div class="row mt-2">
                <div class="col-md-3"><label asp-for="RainfallReport.LowAmountKebeles"></label><input asp-for="RainfallReport.LowAmountKebeles" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="RainfallReport.LowMediumAmountKebeles"></label><input asp-for="RainfallReport.LowMediumAmountKebeles" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="RainfallReport.MediumAmountKebeles"></label><input asp-for="RainfallReport.MediumAmountKebeles" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="RainfallReport.MediumHighAmountKebeles"></label><input asp-for="RainfallReport.MediumHighAmountKebeles" class="form-control" /></div>
            </div>
            <div class="row mt-2">
                <div class="col-md-3"><label asp-for="RainfallReport.HighAmountKebeles"></label><input asp-for="RainfallReport.HighAmountKebeles" class="form-control" /></div>
            </div>
        </div>
    </div>

    <!-- 2. Farming Activity -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h5>የእርሻ እንቅስቃሴ</h5>
        </div>
       @*  <div class="card-body">
            <div class="row">
                <div class="col-md-4"><label asp-for="FarmingActivity.AreaPlanted"></label><input asp-for="FarmingActivity.AreaPlanted" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="FarmingActivity.CropType"></label><input asp-for="FarmingActivity.CropType" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="FarmingActivity.HarvestStatus"></label><input asp-for="FarmingActivity.HarvestStatus" class="form-control" /></div>
            </div>
        </div> *@
    </div>

    <!-- 3. Crop Pest / Disease Report -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h5>የሰብል ተባይ/በሽታ ሪፖርት</h5>
        </div>
        <div class="card-body">
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" asp-for="CropPestAndDeseaseReport.HasPestAndDeseasOccured" id="cropHasPest" />
                <label class="form-check-label" asp-for="CropPestAndDeseaseReport.HasPestAndDeseasOccured"></label>
            </div>
            <div id="cropPestDetails" style="display:none;">
                <div class="mb-3">
                    <label class="fw-bold">የሰብል ተባዮች/በሽታዎች ይምረጡ</label>
                    <div class="row">
                        @foreach (var disease in Model.CropPestAndDeseases)
                        {
                            bool isChecked = Model.SelectedCropDiseaseIds?.Contains(disease.Id) ?? false;
                            <div class="col-md-3">
                                <div class="form-check">
                                    <input type="checkbox" name="SelectedCropDiseaseIds" value="@disease.Id" class="form-check-input" id="crop_@disease.Id" @(isChecked ? "checked" : "") />
                                    <label class="form-check-label" for="crop_@disease.Id">@disease.Name</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6"><label asp-for="CropPestAndDeseaseReport.AffectedLandInHectar"></label><input asp-for="CropPestAndDeseaseReport.AffectedLandInHectar" class="form-control" /></div>
                    <div class="col-md-6"><label asp-for="CropPestAndDeseaseReport.TypeOfCropAffected"></label><input asp-for="CropPestAndDeseaseReport.TypeOfCropAffected" class="form-control" /></div>
                </div>
            </div>
        </div>
    </div>

    <!-- 4. Pasture Status -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h5>የግጦሽ መሬት ሁኔታ</h5>
        </div>
        <div class="card-body">
            <div class="d-flex gap-3 mb-3">
                <div class="form-check"><input type="radio" asp-for="PastureStatus.Enough" value="true" id="pastureTrue" class="form-check-input" /><label for="pastureTrue">በቂ ነው</label></div>
                <div class="form-check"><input type="radio" asp-for="PastureStatus.Enough" value="false" id="pastureFalse" class="form-check-input" /><label for="pastureFalse">በቂ አይደለም</label></div>
            </div>
            <div id="pastureDetails" style="display:none;">
                <div class="row">
@*                     <div class="col-md-6"><label asp-for="PastureStatus.Low"></label><input asp-for="PastureStatus.Low" class="form-control" /></div>
 *@                    <div class="col-md-6"><label asp-for="PastureStatus.NumberOfAnimalsAffected"></label><input asp-for="PastureStatus.NumberOfAnimalsAffected" class="form-control" /></div>
                </div>
                <h6 class="mt-3">የቤተሰብ ብዛት</h6>
                <div class="row">
                    <div class="col"><label asp-for="PastureStatus.MaleHouseHold"></label><input asp-for="PastureStatus.MaleHouseHold" class="form-control" /></div>
                    <div class="col"><label asp-for="PastureStatus.FemaleHouseHold"></label><input asp-for="PastureStatus.FemaleHouseHold" class="form-control" /></div>
                    <div class="col"><label asp-for="PastureStatus.MaleFamily"></label><input asp-for="PastureStatus.MaleFamily" class="form-control" /></div>
                    <div class="col"><label asp-for="PastureStatus.FemaleFamily"></label><input asp-for="PastureStatus.FemaleFamily" class="form-control" /></div>
                </div>
                <div class="row">
                    <div class="col"><label asp-for="PastureStatus.ChildhMale"></label><input asp-for="PastureStatus.ChildhMale" class="form-control" /></div>
                    <div class="col"><label asp-for="PastureStatus.ChildFemale"></label><input asp-for="PastureStatus.ChildFemale" class="form-control" /></div>
                    <div class="col"><label asp-for="PastureStatus.YouthMale"></label><input asp-for="PastureStatus.YouthMale" class="form-control" /></div>
                    <div class="col"><label asp-for="PastureStatus.YouthFemale"></label><input asp-for="PastureStatus.YouthFemale" class="form-control" /></div>
                </div>
                <div class="row">
                    <div class="col"><label asp-for="PastureStatus.ElderlyMale"></label><input asp-for="PastureStatus.ElderlyMale" class="form-control" /></div>
                    <div class="col"><label asp-for="PastureStatus.ElderlyFemale"></label><input asp-for="PastureStatus.ElderlyFemale" class="form-control" /></div>
                    <div class="col"><label asp-for="PastureStatus.DisabledMale"></label><input asp-for="PastureStatus.DisabledMale" class="form-control" /></div>
                    <div class="col"><label asp-for="PastureStatus.DisabledFemale"></label><input asp-for="PastureStatus.DisabledFemale" class="form-control" /></div>
                </div>
            </div>
        </div>
    </div>

    <!-- 5. Animal Water Supply Status -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h5>የእንስሳት ውሃ አቅርቦት ሁኔታ</h5>
        </div>
        <div class="card-body">
            <div class="d-flex gap-3 mb-3">
                <div class="form-check"><input type="radio" asp-for="AnimalWaterSupplyStatus.Enough" value="true" id="waterTrue" class="form-check-input" /><label for="waterTrue">በቂ ነው</label></div>
                <div class="form-check"><input type="radio" asp-for="AnimalWaterSupplyStatus.Enough" value="false" id="waterFalse" class="form-check-input" /><label for="waterFalse">በቂ አይደለም</label></div>
            </div>
            <div id="waterDetails" style="display:none;">
                <div class="row">
                    <div class="col-md-6"><label asp-for="AnimalWaterSupplyStatus.NoOfKebeliesWithPastureShortage"></label><input asp-for="AnimalWaterSupplyStatus.NoOfKebeliesWithPastureShortage" class="form-control" /></div>
                    <div class="col-md-6"><label asp-for="AnimalWaterSupplyStatus.NoOfKebeliesWithWaterSupply"></label><input asp-for="AnimalWaterSupplyStatus.NoOfKebeliesWithWaterSupply" class="form-control" /></div>
                </div>
                <h6 class="mt-3">የቤተሰብ ብዛት</h6>
                <div class="row">
                    <div class="col"><label asp-for="AnimalWaterSupplyStatus.MaleHouseHold"></label><input asp-for="AnimalWaterSupplyStatus.MaleHouseHold" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalWaterSupplyStatus.FemaleHouseHold"></label><input asp-for="AnimalWaterSupplyStatus.FemaleHouseHold" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalWaterSupplyStatus.MaleFamily"></label><input asp-for="AnimalWaterSupplyStatus.MaleFamily" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalWaterSupplyStatus.FemaleFamily"></label><input asp-for="AnimalWaterSupplyStatus.FemaleFamily" class="form-control" /></div>
                </div>
                <div class="row">
                    <div class="col"><label asp-for="AnimalWaterSupplyStatus.ChildhMale"></label><input asp-for="AnimalWaterSupplyStatus.ChildhMale" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalWaterSupplyStatus.ChildFemale"></label><input asp-for="AnimalWaterSupplyStatus.ChildFemale" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalWaterSupplyStatus.YouthMale"></label><input asp-for="AnimalWaterSupplyStatus.YouthMale" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalWaterSupplyStatus.YouthFemale"></label><input asp-for="AnimalWaterSupplyStatus.YouthFemale" class="form-control" /></div>
                </div>
                <div class="row">
                    <div class="col"><label asp-for="AnimalWaterSupplyStatus.ElderlyMale"></label><input asp-for="AnimalWaterSupplyStatus.ElderlyMale" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalWaterSupplyStatus.ElderlyFemale"></label><input asp-for="AnimalWaterSupplyStatus.ElderlyFemale" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalWaterSupplyStatus.DisabledMale"></label><input asp-for="AnimalWaterSupplyStatus.DisabledMale" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalWaterSupplyStatus.DisabledFemale"></label><input asp-for="AnimalWaterSupplyStatus.DisabledFemale" class="form-control" /></div>
                </div>
            </div>
        </div>
    </div>

    <!-- 6. Animal Health Status -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h5>የእንስሳት ጤና ሁኔታ</h5>
        </div>
        <div class="card-body">
            <div class="d-flex gap-3 mb-3">
                <div class="form-check"><input type="radio" asp-for="AnimalHealthStatus.Enough" value="true" id="healthTrue" class="form-check-input" /><label for="healthTrue">አለ (በሽታ አለ)</label></div>
                <div class="form-check"><input type="radio" asp-for="AnimalHealthStatus.Enough" value="false" id="healthFalse" class="form-check-input" /><label for="healthFalse">የለም</label></div>
            </div>
            <div id="healthDetails" style="display:none;">
                <div class="mb-3">
                    <label class="fw-bold">የእንስሳት በሽታዎች ይምረጡ</label>
                    <div class="row">
                        @foreach (var disease in Model.AnimalDiseases)
                        {
                            bool isChecked = Model.SelectedAnimalDiseaseIds?.Contains(disease.Id) ?? false;
                            <div class="col-md-3">
                                <div class="form-check">
                                    <input type="checkbox" name="SelectedAnimalDiseaseIds" value="@disease.Id" class="form-check-input" id="animal_@disease.Id" @(isChecked ? "checked" : "") />
                                    <label class="form-check-label" for="animal_@disease.Id">@disease.Name</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <h6 class="mt-3">የቤተሰብ ብዛት</h6>
                <div class="row">
                    <div class="col"><label asp-for="AnimalHealthStatus.MaleHouseHold"></label><input asp-for="AnimalHealthStatus.MaleHouseHold" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalHealthStatus.FemaleHouseHold"></label><input asp-for="AnimalHealthStatus.FemaleHouseHold" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalHealthStatus.MaleFamily"></label><input asp-for="AnimalHealthStatus.MaleFamily" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalHealthStatus.FemaleFamily"></label><input asp-for="AnimalHealthStatus.FemaleFamily" class="form-control" /></div>
                </div>
                <div class="row">
                    <div class="col"><label asp-for="AnimalHealthStatus.ChildhMale"></label><input asp-for="AnimalHealthStatus.ChildhMale" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalHealthStatus.ChildFemale"></label><input asp-for="AnimalHealthStatus.ChildFemale" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalHealthStatus.YouthMale"></label><input asp-for="AnimalHealthStatus.YouthMale" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalHealthStatus.YouthFemale"></label><input asp-for="AnimalHealthStatus.YouthFemale" class="form-control" /></div>
                </div>
                <div class="row">
                    <div class="col"><label asp-for="AnimalHealthStatus.ElderlyMale"></label><input asp-for="AnimalHealthStatus.ElderlyMale" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalHealthStatus.ElderlyFemale"></label><input asp-for="AnimalHealthStatus.ElderlyFemale" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalHealthStatus.DisabledMale"></label><input asp-for="AnimalHealthStatus.DisabledMale" class="form-control" /></div>
                    <div class="col"><label asp-for="AnimalHealthStatus.DisabledFemale"></label><input asp-for="AnimalHealthStatus.DisabledFemale" class="form-control" /></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Global Remarks -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h5>አጠቃላይ ማስታወሻ</h5>
        </div>
        <div class="card-body">
            <textarea asp-for="Remarks" class="form-control" rows="3"></textarea>
        </div>
    </div>

    <div class="d-flex justify-content-between mb-5">
        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">ወደ መነሻ ተመለስ</a>
        <button type="submit" class="btn btn-primary btn-lg">ሁሉንም ሪፖርቶች አስቀምጥ</button>
    </div>
</form>

@section Scripts {
    <script>
        // 1. Crop Pest toggle
        $('#cropHasPest').change(function() {
            $('#cropPestDetails').toggle(this.checked);
            // disable/enable inputs inside
            var inputs = $('#cropPestDetails').find('input, textarea');
            if (this.checked) inputs.prop('disabled', false);
            else inputs.prop('disabled', true);
        }).trigger('change');

        // 2. Pasture Status toggle (show when "በቂ አይደለም" is selected)
        function togglePasture() {
            var show = $('#pastureFalse').is(':checked');
            $('#pastureDetails').toggle(show);
            var inputs = $('#pastureDetails').find('input, textarea');
            if (show) inputs.prop('disabled', false);
            else inputs.prop('disabled', true);
        }
        $('input[name="PastureStatus.Enough"]').change(togglePasture);
        togglePasture();

        // 3. Animal Water Supply toggle
        function toggleWater() {
            var show = $('#waterFalse').is(':checked');
            $('#waterDetails').toggle(show);
            var inputs = $('#waterDetails').find('input, textarea');
            if (show) inputs.prop('disabled', false);
            else inputs.prop('disabled', true);
        }
        $('input[name="AnimalWaterSupplyStatus.Enough"]').change(toggleWater);
        toggleWater();

        // 4. Animal Health Status toggle (show when "አለ" is selected)
        function toggleHealth() {
            var show = $('#healthTrue').is(':checked');
            $('#healthDetails').toggle(show);
            var inputs = $('#healthDetails').find('input, textarea');
            if (show) inputs.prop('disabled', false);
            else inputs.prop('disabled', true);
        }
        $('input[name="AnimalHealthStatus.Enough"]').change(toggleHealth);
        toggleHealth();
    </script>
}