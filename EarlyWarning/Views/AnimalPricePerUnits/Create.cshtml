@using EarlyWarning.Enums
@model EarlyWarning.Models.AnimalPrice.AnimalPricePerUnit

@{
    ViewData["Title"] = "የእንስሳት ዋጋ ሪፖርት";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var animalTypes = ViewBag.AnimalTypes as IEnumerable<EarlyWarning.Models.AnimalPrice.AnimalType> ?? new List<EarlyWarning.Models.AnimalPrice.AnimalType>();
}

<style>
    /* Custom Styles */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 25px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
            transform: rotate(45deg);
        }

        .page-header h1 {
            margin: 0;
            font-size: 1.6rem;
            position: relative;
            z-index: 1;
        }

        .page-header p {
            margin: 8px 0 0;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

    .form-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .form-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.15);
        }

    .card-header-custom {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 20px;
        font-weight: 600;
    }

        .card-header-custom i {
            margin-right: 8px;
        }

    .card-body-custom {
        padding: 25px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        font-size: 0.9rem;
    }

        .form-label i {
            margin-right: 5px;
            color: #fa709a;
        }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 10px 12px;
        width: 100%;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #fa709a;
            box-shadow: 0 0 0 0.2rem rgba(250, 112, 154, 0.25);
            outline: none;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 80px;
    }

    .radio-group {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin-top: 5px;
    }

    .radio-option {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 15px;
        background: #f8f9fa;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .radio-option:hover {
            background: #e9ecef;
        }

        .radio-option input {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .radio-option.selected {
            background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
            color: #333;
        }

            .radio-option.selected i {
                color: #333;
            }

    .price-item-card {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 15px;
        border-left: 4px solid #fa709a;
        position: relative;
    }

    .btn-remove-price {
        position: absolute;
        top: 10px;
        right: 15px;
        background: none;
        border: none;
        color: #dc3545;
        font-size: 1.2rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-remove-price:hover {
            transform: scale(1.1);
        }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 25px;
    }

    .btn-custom {
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-submit {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
    }

    .btn-back {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white;
    }

    .btn-add {
        background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
        color: #333;
    }

    .btn-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        color: white;
    }

    .btn-add:hover {
        color: white;
    }

    .text-danger {
        color: #dc3545;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .info-hint {
        background: #fff3e6;
        border-left: 3px solid #fa709a;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        margin: -10px;
    }

    .col-md-6 {
        flex: 0 0 50%;
        padding: 10px;
    }

    .col-md-12 {
        flex: 0 0 100%;
        padding: 10px;
    }

    .price-summary {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        border-radius: 12px;
        padding: 15px;
        margin-top: 20px;
    }

    .summary-stats {
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        gap: 20px;
    }

    .summary-item {
        text-align: center;
        flex: 1;
        min-width: 100px;
    }

    .summary-number {
        font-size: 1.5rem;
        font-weight: bold;
    }

    .summary-label {
        font-size: 0.8rem;
        opacity: 0.9;
    }

    @@media (max-width: 768px) {
        .form-container {
            max-width: 100%;
        }

        .card-body-custom {
            padding: 20px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-custom {
            width: 100%;
            text-align: center;
        }

        .radio-group {
            flex-direction: column;
        }

        .col-md-6 {
            flex: 0 0 100%;
        }
    }
</style>

<div class="container-fluid">
    <div class="form-container">
        <!-- Page Header -->
        <div class="page-header">
            <h1>
                <i class="fas fa-plus-circle"></i> @ViewData["Title"]
            </h1>
            <p>እባክዎ በሳምንቱ የእንስሳት ዋጋ መረጃ ይሙሉ (አንድ ላይ በርካታ የእንስሳት ዓይነቶችን መመዝገብ ይችላሉ)</p>
        </div>

        <form asp-action="Create" method="post" id="animalPriceForm">
            @Html.AntiForgeryToken()

            <!-- Basic Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-calendar-alt"></i> መሰረታዊ መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="StartDate" class="form-label">
                                    <i class="fas fa-calendar-week"></i> የሪፖርት መነሻ ቀን
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="EndDate" class="form-label">
                                    <i class="fas fa-calendar-check"></i> የሪፖርት መጨረሻ ቀን
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="EndDate" class="form-control" type="date" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    
                </div>
            </div>

            <!-- Multiple Animal Prices Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-paw"></i> የእንስሳት ዋጋ ዝርዝር
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-paw"></i> የእንስሳት ዓይነት
                                </label>
                                <select id="animalTypeSelect" class="form-control">
                                    <option value="">-- ይምረጡ --</option>
                                    @foreach (var animal in animalTypes)
                                    {
                                        <option value="@animal.AnimalTypeId">@animal.AnimalTypeName</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-money-bill-wave"></i> ዋጋ (ብር)
                                </label>
                                <input type="number" id="weeklyPriceInput" class="form-control" step="0.01" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-chart-line"></i> ሁኔታ
                                </label>
                                <select id="statusSelect" class="form-control">
                                    <option value="1">ጨምሯል 📈</option>
                                    <option value="2">ቀንሷል 📉</option>
                                    <option value="3">ተመሳሳይ ➡️</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label class="form-label">&nbsp;</label>
                                <button type="button" class="btn btn-success form-control" id="btnAddPrice">
                                    <i class="fas fa-plus"></i> ጨምር
                                </button>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div id="pricesContainer">
                        <h6 class="text-primary"><i class="fas fa-list"></i> የተመዘገቡ የእንስሳት ዋጋዎች</h6>
                        <div id="pricesList" class="mt-3">
                            <div class="alert alert-info" id="noPricesMsg">ምንም የእንስሳት ዋጋ አልተመዘገበም</div>
                        </div>
                    </div>

                    <div class="info-hint mt-3">
                        <i class="fas fa-info-circle"></i> በርካታ የእንስሳት ዓይነቶችን አንድ ላይ መመዝገብ ይችላሉ
                    </div>
                </div>
            </div>

            <!-- Additional Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-file-alt"></i> ተጨማሪ መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label asp-for="Notes" class="form-label">
                                    <i class="fas fa-sticky-note"></i> ማስታወሻ
                                </label>
                                <textarea asp-for="Notes" class="form-control" rows="3" placeholder="ተጨማሪ ማስታወሻ ካለ ያስገቡ..."></textarea>
                                <span asp-validation-for="Notes" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Report Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-user-edit"></i> የሪፖርት መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ReportDate" class="form-label">
                                    <i class="fas fa-calendar-day"></i> የሪፖርት ቀን
                                </label>
                                <input asp-for="ReportDate" class="form-control" type="datetime-local" />
                                <span asp-validation-for="ReportDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ReportedBy" class="form-label">
                                    <i class="fas fa-user"></i> አዘጋጅ
                                </label>
                                <input asp-for="ReportedBy" class="form-control" placeholder="ሙሉ ስም ያስገቡ" />
                                <span asp-validation-for="ReportedBy" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label asp-for="ApprovalStatus" class="form-label">
                                    <i class="fas fa-check-circle"></i> የሪፖርት ሁኔታ
                                </label>
                                <select asp-for="ApprovalStatus" class="form-control" asp-items="Html.GetEnumSelectList<ApprovalStatus>()">
                                    <option value="">-- ሁኔታ ይምረጡ --</option>
                                </select>
                                <span asp-validation-for="ApprovalStatus" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Summary Card -->
            <div class="price-summary" id="summaryCard" style="display: none;">
                <div class="summary-stats">
                    <div class="summary-item">
                        <div class="summary-number" id="totalAnimals">0</div>
                        <div class="summary-label"><i class="fas fa-paw"></i> ጠቅላላ ዓይነቶች</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-number" id="avgPrice">0</div>
                        <div class="summary-label"><i class="fas fa-coins"></i> አማካይ ዋጋ</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-number" id="minPrice">0</div>
                        <div class="summary-label"><i class="fas fa-arrow-down"></i> ዝቅተኛ ዋጋ</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-number" id="maxPrice">0</div>
                        <div class="summary-label"><i class="fas fa-arrow-up"></i> ከፍተኛ ዋጋ</div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <a asp-action="Index" class="btn-custom btn-back">
                    <i class="fas fa-arrow-left"></i> ወደ ዝርዝር ተመለስ
                </a>
                <button type="submit" class="btn-custom btn-submit" id="submitBtn">
                    <i class="fas fa-save"></i> መዝግብ
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            var animalPrices = [];

            // Set default report date
            if (!$('#ReportDate').val()) {
                var now = new Date();
                var formattedDate = now.getFullYear() + '-' +
                                   String(now.getMonth() + 1).padStart(2, '0') + '-' +
                                   String(now.getDate()).padStart(2, '0') + 'T' +
                                   String(now.getHours()).padStart(2, '0') + ':' +
                                   String(now.getMinutes()).padStart(2, '0');
                $('#ReportDate').val(formattedDate);
            }

            // Update summary statistics
            function updateSummary() {
                if (animalPrices.length === 0) {
                    $('#summaryCard').hide();
                    return;
                }

                $('#summaryCard').show();
                $('#totalAnimals').text(animalPrices.length);

                var prices = animalPrices.map(function(a) { return a.price; });
                var avg = prices.reduce(function(a, b) { return a + b; }, 0) / prices.length;
                var min = Math.min.apply(null, prices);
                var max = Math.max.apply(null, prices);

                $('#avgPrice').text(avg.toFixed(2));
                $('#minPrice').text(min.toFixed(2));
                $('#maxPrice').text(max.toFixed(2));
            }

            // Update displayed list
            function updatePricesDisplay() {
                var container = $('#pricesList');
                container.empty();

                if (animalPrices.length === 0) {
                    container.html('<div class="alert alert-info" id="noPricesMsg">ምንም የእንስሳት ዋጋ አልተመዘገበም</div>');
                    updateSummary();
                    return;
                }

                var html = '<div class="table-responsive"><table class="table table-bordered table-sm"><thead>';
                html += '<tr><th>የእንስሳት ዓይነት</th><th>ዋጋ (ብር)</th><th>ሁኔታ</th><th>ድርጊት</th></tr></thead><tbody>';

                $.each(animalPrices, function(index, item) {
                    var statusText = '';
                    var statusClass = '';
                    if (item.status == '1') {
                        statusText = 'ጨምሯል 📈';
                        statusClass = 'text-success';
                    } else if (item.status == '2') {
                        statusText = 'ቀንሷል 📉';
                        statusClass = 'text-danger';
                    } else {
                        statusText = 'ተመሳሳይ ➡️';
                        statusClass = 'text-secondary';
                    }

                    html += '<tr>';
                    html += '<td><strong>' + item.name + '</strong></td>';
                    html += '<td class="text-end">' + parseFloat(item.price).toFixed(2) + ' ብር</td>';
                    html += '<td class="' + statusClass + '">' + statusText + '</td>';
                    html += '<td class="text-center">';
                    html += '<button type="button" class="btn btn-sm btn-danger remove-price" data-index="' + index + '">';
                    html += '<i class="fas fa-trash"></i> ሰርዝ';
                    html += '</button></td>';
                    html += '</td>';
                });

                html += '</tbody></table></div>';
                container.html(html);

                $('.remove-price').on('click', function() {
                    var index = $(this).data('index');
                    animalPrices.splice(index, 1);
                    updatePricesDisplay();
                    updateSummary();
                });

                updateSummary();
            }

            // Add price to list
            $('#btnAddPrice').on('click', function() {
                var animalTypeId = $('#animalTypeSelect').val();
                var animalTypeName = $('#animalTypeSelect option:selected').text();
                var weeklyPrice = parseFloat($('#weeklyPriceInput').val());
                var status = $('#statusSelect').val();

                if (!animalTypeId) {
                    alert('እባክዎ የእንስሳት ዓይነት ይምረጡ');
                    $('#animalTypeSelect').focus();
                    return;
                }

                if (isNaN(weeklyPrice) || weeklyPrice <= 0) {
                    alert('እባክዎ ትክክለኛ ዋጋ ያስገቡ');
                    $('#weeklyPriceInput').focus();
                    return;
                }

                // Check for duplicate
                if (animalPrices.some(function(a) { return a.id === animalTypeId; })) {
                    alert('ይህ የእንስሳት ዓይነት ቀድሞ ተመዝግቧል');
                    return;
                }

                animalPrices.push({
                    id: animalTypeId,
                    name: animalTypeName,
                    price: weeklyPrice,
                    status: status
                });

                // Reset inputs
                $('#animalTypeSelect').val('');
                $('#weeklyPriceInput').val('');
                $('#statusSelect').val('1');

                updatePricesDisplay();
            });

            // Enter key support
            $('#weeklyPriceInput').on('keypress', function(e) {
                if (e.which === 13) {
                    e.preventDefault();
                    $('#btnAddPrice').click();
                }
            });

            // Form validation before submit
            $('#animalPriceForm').on('submit', function(e) {
                var woredaId = $('#WoredaId').val();
                var startDate = $('#StartDate').val();
                var endDate = $('#EndDate').val();

                

                if (!startDate) {
                    e.preventDefault();
                    alert('እባክዎ የሪፖርት መነሻ ቀን ይምረጡ');
                    $('#StartDate').focus();
                    return false;
                }

                if (!endDate) {
                    e.preventDefault();
                    alert('እባክዎ የሪፖርት መጨረሻ ቀን ይምረጡ');
                    $('#EndDate').focus();
                    return false;
                }

                if (animalPrices.length === 0) {
                    e.preventDefault();
                    alert('እባክዎ ቢያንስ አንድ የእንስሳት ዋጋ ይመዝግቡ');
                    return false;
                }

                // Add hidden fields for each animal price
                animalPrices.forEach(function(item, index) {
                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AnimalPrices[' + index + '].AnimalTypeId',
                        value: item.id
                    }).appendTo('#animalPriceForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AnimalPrices[' + index + '].WeeklyPrice',
                        value: item.price
                    }).appendTo('#animalPriceForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AnimalPrices[' + index + '].WeeklyMarketStatus',
                        value: item.status
                    }).appendTo('#animalPriceForm');
                });

                return true;
            });
        });
    </script>
}