@using EarlyWarning.Enums
@model EarlyWarning.Models.Aid.OtherProblem

@{
    ViewData["Title"] = "ሌላ ችግር ሪፖርት";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Custom Styles */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 25px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
            transform: rotate(45deg);
        }

        .page-header h1 {
            margin: 0;
            font-size: 1.6rem;
            position: relative;
            z-index: 1;
        }

        .page-header p {
            margin: 8px 0 0;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

    .form-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .form-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.15);
        }

    .card-header-custom {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 20px;
        font-weight: 600;
    }

        .card-header-custom i {
            margin-right: 8px;
        }

    .card-header-success {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
    }

    .card-header-danger {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
    }

    .card-body-custom {
        padding: 25px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        font-size: 0.9rem;
    }

        .form-label i {
            margin-right: 5px;
            color: #fa709a;
        }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 10px 12px;
        width: 100%;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #fa709a;
            box-shadow: 0 0 0 0.2rem rgba(250, 112, 154, 0.25);
            outline: none;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 80px;
    }

    .checkbox-group {
        background: #f8f9fa;
        padding: 15px 20px;
        border-radius: 10px;
        border: 1px solid #e0e0e0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
    }

    .checkbox-label {
        font-weight: 600;
        margin: 0;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .checkbox-label input {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }

    .badge-status {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
    }

        .badge-status.inactive {
            background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
            color: #333;
        }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 25px;
    }

    .btn-custom {
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-submit {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
    }

    .btn-back {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white;
    }

    .btn-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        color: white;
    }

    .text-danger {
        color: #dc3545;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .info-hint {
        background: #fff3e6;
        border-left: 3px solid #fa709a;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .summary-card {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        border-radius: 12px;
        padding: 20px;
        margin-top: 20px;
    }

    .summary-stats {
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        gap: 20px;
    }

    .summary-item {
        text-align: center;
        flex: 1;
        min-width: 100px;
    }

    .summary-number {
        font-size: 1.5rem;
        font-weight: bold;
    }

    .summary-label {
        font-size: 0.8rem;
        opacity: 0.9;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        margin: -10px;
    }

    .col-md-6 {
        flex: 0 0 50%;
        padding: 10px;
    }

    .col-md-12 {
        flex: 0 0 100%;
        padding: 10px;
    }

    hr {
        margin: 15px 0;
    }

    @@media (max-width: 768px) {
        .form-container {
            max-width: 100%;
        }

        .card-body-custom {
            padding: 20px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-custom {
            width: 100%;
            text-align: center;
        }

        .checkbox-group {
            flex-direction: column;
            gap: 10px;
            align-items: flex-start;
        }

        .col-md-6 {
            flex: 0 0 100%;
        }

        .summary-number {
            font-size: 1.2rem;
        }
    }
</style>

<div class="container-fluid">
    <div class="form-container">
        <!-- Page Header -->
        <div class="page-header">
            <h1>
                <i class="fas fa-plus-circle"></i> @ViewData["Title"]
            </h1>
            <p>እባክዎ አዲስ ሌላ ያልተገለፀ ችግር ሪፖርት ይሙሉ</p>
        </div>

        <form asp-action="Create" method="post" id="otherProblemForm">
            @Html.AntiForgeryToken()

            <!-- Basic Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-calendar-alt"></i> መሰረታዊ መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="StartDate" class="form-label">
                                    <i class="fas fa-calendar-week"></i> @Html.DisplayNameFor(m => m.StartDate)
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="EndDate" class="form-label">
                                    <i class="fas fa-calendar-check"></i> @Html.DisplayNameFor(m => m.EndDate)
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="EndDate" class="form-control" type="date" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="WoredaId" class="form-label">
                                    <i class="fas fa-map-marker-alt"></i> @Html.DisplayNameFor(m => m.WoredaId)
                                    <span class="text-danger">*</span>
                                </label>
                                <select asp-for="WoredaId" class="form-control" asp-items="ViewBag.WoredaId">
                                    <option value="">-- ወረዳ ይምረጡ --</option>
                                </select>
                                <span asp-validation-for="WoredaId" class="text-danger"></span>
                            </div>
                        </div>
                        
                    </div>

                    <div class="form-group">
                        <div class="checkbox-group">
                            <label class="checkbox-label">
                                <input asp-for="HasOtherProblem" type="checkbox" id="hasProblemCheckbox" />
                                <span>
                                    <i class="fas fa-exclamation-triangle"></i> @Html.DisplayNameFor(m => m.HasOtherProblem)
                                </span>
                            </label>
                            <span id="statusBadge" class="badge-status">
                                <i class="fas fa-check-circle"></i> ችግር አለ
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Affected Population Card (Hidden by default) -->
            <div id="populationSection" class="form-card" style="display: none;">
                <div class="card-header-custom card-header-danger">
                    <i class="fas fa-users"></i> በችግሩ የተጎዳ ማህበረሰብ
                </div>
                <div class="card-body-custom">
                    <div class="form-group">
                        <label asp-for="ProblemName" class="form-label">
                            <i class="fas fa-exclamation-triangle"></i> @Html.DisplayNameFor(m => m.ProblemName)
                        </label>
                        <textarea asp-for="ProblemName" class="form-control" rows="3" placeholder="ለምሳሌ፦ የመሠረተ ልማት ችግር፣ የትራንስፖርት ችግር..."></textarea>
                        @* <input asp-for="ProblemName" class="form-control" placeholder="ለምሳሌ፦ የመሠረተ ልማት ችግር፣ የትራንስፖርት ችግር..." /> *@
                        <span asp-validation-for="ProblemName" class="text-danger"></span>
                    </div>
                    <!-- Household Heads -->
                    <h6 class="text-primary"><i class="fas fa-user-friends"></i> አባወራ / እማወራ</h6>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="MaleHouseholdHeads">ወንድ</label>
                                <input asp-for="MaleHouseholdHeads" class="form-control" type="number" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FemaleHouseholdHeads">ሴት</label>
                                <input asp-for="FemaleHouseholdHeads" class="form-control" type="number" min="0" value="0" />
                            </div>
                        </div>
                    </div>
                    <hr />

                    <!-- Family Members -->
                    <h6 class="text-primary"><i class="fas fa-home"></i> ቤተሰብ</h6>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="MaleFamilyMembers">ወንድ</label>
                                <input asp-for="MaleFamilyMembers" class="form-control" type="number" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FemaleFamilyMembers">ሴት</label>
                                <input asp-for="FemaleFamilyMembers" class="form-control" type="number" min="0" value="0" />
                            </div>
                        </div>
                    </div>
                    <hr />

                    <!-- Children -->
                    <h6 class="text-primary"><i class="fas fa-child"></i> ህጻናት</h6>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="MaleChildren">ወንድ</label>
                                <input asp-for="MaleChildren" class="form-control" type="number" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FemaleChildren">ሴት</label>
                                <input asp-for="FemaleChildren" class="form-control" type="number" min="0" value="0" />
                            </div>
                        </div>
                    </div>
                    <hr />

                    <!-- Youth -->
                    <h6 class="text-primary"><i class="fas fa-user-graduate"></i> ወጣቶች</h6>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="MaleYouth">ወንድ</label>
                                <input asp-for="MaleYouth" class="form-control" type="number" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FemaleYouth">ሴት</label>
                                <input asp-for="FemaleYouth" class="form-control" type="number" min="0" value="0" />
                            </div>
                        </div>
                    </div>
                    <hr />

                    <!-- Elderly -->
                    <h6 class="text-primary"><i class="fas fa-user-astronaut"></i> አረጋውያን</h6>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="MaleElderly">ወንድ</label>
                                <input asp-for="MaleElderly" class="form-control" type="number" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FemaleElderly">ሴት</label>
                                <input asp-for="FemaleElderly" class="form-control" type="number" min="0" value="0" />
                            </div>
                        </div>
                    </div>
                    <hr />

                    <!-- Disabled -->
                    <h6 class="text-primary"><i class="fas fa-wheelchair"></i> አካል ጉዳተኞች</h6>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="MaleDisabled">ወንድ</label>
                                <input asp-for="MaleDisabled" class="form-control" type="number" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FemaleDisabled">ሴት</label>
                                <input asp-for="FemaleDisabled" class="form-control" type="number" min="0" value="0" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- General Information Card -->
            <div id="generalNote" class="form-card" style="display: none;">
                <div class="card-header-custom card-header-success">
                    <i class="fas fa-file-alt"></i> አጠቃላይ መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="form-group">
                        <label asp-for="GeneralNotes" class="form-label">
                            <i class="fas fa-sticky-note"></i> @Html.DisplayNameFor(m => m.GeneralNotes)
                        </label>
                        <textarea asp-for="GeneralNotes" class="form-control" rows="3" placeholder="ተጨማሪ ማስታወሻ ካለ ያስገቡ..."></textarea>
                        <span asp-validation-for="GeneralNotes" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Report Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-user-edit"></i> የሪፖርት መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ReportDate" class="form-label">
                                    <i class="fas fa-calendar-day"></i> @Html.DisplayNameFor(m => m.ReportDate)
                                </label>
                                <input asp-for="ReportDate" class="form-control" type="datetime-local" />
                                <span asp-validation-for="ReportDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ReportedBy" class="form-label">
                                    <i class="fas fa-user"></i> @Html.DisplayNameFor(m => m.ReportedBy)
                                </label>
                                <input asp-for="ReportedBy" class="form-control" placeholder="ሙሉ ስም ያስገቡ" />
                                <span asp-validation-for="ReportedBy" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label asp-for="ApprovalStatus" class="form-label">
                                    <i class="fas fa-check-circle"></i> @Html.DisplayNameFor(m => m.ApprovalStatus)
                                </label>
                                <select asp-for="ApprovalStatus" class="form-control" asp-items="Html.GetEnumSelectList<ApprovalStatus>()">
                                    <option value="">-- ሁኔታ ይምረጡ --</option>
                                </select>
                                <span asp-validation-for="ApprovalStatus" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Summary Card -->
            <div id="summaryCard" class="summary-card" style="display: none;">
                <div class="summary-stats" id="summaryStats">
                    <div class="summary-item">
                        <div class="summary-number" id="totalMales">0</div>
                        <div class="summary-label"><i class="fas fa-male"></i> ጠቅላላ ወንዶች</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-number" id="totalFemales">0</div>
                        <div class="summary-label"><i class="fas fa-female"></i> ጠቅላላ ሴቶች</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-number" id="totalPopulation">0</div>
                        <div class="summary-label"><i class="fas fa-users"></i> ጠቅላላ ተጎጆች</div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <a asp-action="Index" class="btn-custom btn-back">
                    <i class="fas fa-arrow-left"></i> ወደ ዝርዝር ተመለስ
                </a>
                <button type="submit" class="btn-custom btn-submit">
                    <i class="fas fa-save"></i> መዝግብ
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Toggle sections based on HasOtherProblem
            function toggleSections() {
                var hasProblem = $('#hasProblemCheckbox').is(':checked');
                var badge = $('#statusBadge');

                if (hasProblem) {
                    $('#populationSection').slideDown(300);
                    $('#summaryCard').slideDown(300);
                    $('#generalNote').slideDown(300);
                    badge.removeClass('inactive');
                    badge.html('<i class="fas fa-exclamation-triangle"></i> ችግር አለ');
                } else {
                    $('#populationSection').slideUp(300);
                    $('#summaryCard').slideUp(300);
                    $('#generalNote').slideUp(300);
                    badge.addClass('inactive');
                    badge.html('<i class="fas fa-check-circle"></i> ችግር የለም');
                    resetNumbers();
                }
            }

            // Calculate totals
            function calculateTotals() {
                var maleFields = ['MaleHouseholdHeads', 'MaleFamilyMembers', 'MaleChildren', 'MaleYouth', 'MaleElderly', 'MaleDisabled'];
                var femaleFields = ['FemaleHouseholdHeads', 'FemaleFamilyMembers', 'FemaleChildren', 'FemaleYouth', 'FemaleElderly', 'FemaleDisabled'];

                var totalMales = 0;
                var totalFemales = 0;

                maleFields.forEach(function(field) {
                    totalMales += parseInt($('#' + field).val()) || 0;
                });

                femaleFields.forEach(function(field) {
                    totalFemales += parseInt($('#' + field).val()) || 0;
                });

                var totalPopulation = totalMales + totalFemales;

                $('#totalMales').text(totalMales.toLocaleString());
                $('#totalFemales').text(totalFemales.toLocaleString());
                $('#totalPopulation').text(totalPopulation.toLocaleString());
            }

            function resetNumbers() {
                var allFields = ['MaleHouseholdHeads', 'FemaleHouseholdHeads', 'MaleFamilyMembers', 'FemaleFamilyMembers',
                                 'MaleChildren', 'FemaleChildren', 'MaleYouth', 'FemaleYouth', 'MaleElderly', 'FemaleElderly',
                                 'MaleDisabled', 'FemaleDisabled'];

                allFields.forEach(function(field) {
                    $('#' + field).val(0);
                });
                calculateTotals();
            }

            // Event listeners
            $('#hasProblemCheckbox').on('change', function() {
                toggleSections();
                if ($(this).is(':checked')) {
                    calculateTotals();
                }
            });

            // Calculate totals on input change
            $('input[type="number"]').on('input', function() {
                if ($('#hasProblemCheckbox').is(':checked')) {
                    calculateTotals();
                }
            });

            // Set default report date
            if (!$('#ReportDate').val()) {
                var now = new Date();
                var formattedDate = now.getFullYear() + '-' +
                                   String(now.getMonth() + 1).padStart(2, '0') + '-' +
                                   String(now.getDate()).padStart(2, '0') + 'T' +
                                   String(now.getHours()).padStart(2, '0') + ':' +
                                   String(now.getMinutes()).padStart(2, '0');
                $('#ReportDate').val(formattedDate);
            }

            // Initial toggle
            toggleSections();

            // Auto capitalize first letter of problem name
            $('#ProblemName').on('blur', function() {
                var value = $(this).val();
                if (value) {
                    $(this).val(value.charAt(0).toUpperCase() + value.slice(1).toLowerCase());
                }
            });

            // Form validation before submit
            $('#otherProblemForm').on('submit', function(e) {
                if ($('#hasProblemCheckbox').is(':checked')) {
                    var totalPopulation = parseInt($('#totalPopulation').text().replace(/,/g, '')) || 0;
                    if (totalPopulation === 0) {
                        e.preventDefault();
                        alert('እባክዎ ቢያንስ አንድ የተጎዳ ሰው ያስገቡ');
                        return false;
                    }
                }
                return true;
            });
        });
    </script>
}