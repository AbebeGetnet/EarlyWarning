@model CropGrowth
@{
    ViewData["Title"] = "የሰብል እድገት ደረጃ ሪፖርት";
}
<h2>@ViewData["Title"]</h2>
<h5>ወረዳ: @ViewBag.WoredaName</h5>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="card">
        <div class="card-header bg-success text-white">
            <h5>የሰብል እድገት ደረጃዎች በሄክታር</h5>
        </div>
        <div class="card-body">
            <!-- Date range row -->
            <div class="section-card mb-1 p-3 bg-light rounded">
                <h5 class="text-primary-custom"><i class="bi bi-calendar-week"></i> የሪፖርት ጊዜ/ሳምንት</h5>
                <div class="row">
                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label fw-bold"></label>
                        <input asp-for="StartDate" type="date" required class="form-control" />
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label fw-bold"></label>
                        <input asp-for="EndDate" type="date" required class="form-control" />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>
                </div>
                <div id="dateRangeError" class="validation-summary-error" style="display:none;"></div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AtSeedStage" class="form-label">በዘር ደረጃ</label>
                        <input asp-for="AtSeedStage" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="AtSeedStage" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AtGerminationStage" class="form-label">በብቅለት ደረጃ</label>
                        <input asp-for="AtGerminationStage" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="AtGerminationStage" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AtGrowthStage" class="form-label">በእድገት ደረጃ</label>
                        <input asp-for="AtGrowthStage" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="AtGrowthStage" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AtFruitStage" class="form-label">ፍሬ በመሙላት ደረጃ</label>
                        <input asp-for="AtFruitStage" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="AtFruitStage" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AtHarvestingStage" class="form-label">በመሰብሰብ ደረጃ</label>
                        <input asp-for="AtHarvestingStage" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="AtHarvestingStage" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-info text-white">
            <h5>ተጨማሪ ዝርዝር</h5>
        </div>
        <div class="card-body">
            <div class="form-group mb-3">
                <label asp-for="Remarks" class="form-label">ማስታወሻ</label>
                <textarea asp-for="Remarks" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Remarks" class="text-danger"></span>
            </div>
        </div>
    </div>

    <input type="hidden" asp-for="WoredaId" />
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">ፍጠር</button>
        <a asp-action="Index" class="btn btn-secondary">ተመልሰው</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
