@using EarlyWarning.Enums
@model EarlyWarning.Models.Migration.Migration

@{
    ViewData["Title"] = "የስደት ሪፖርት";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    var locations = ViewBag.Locations as IEnumerable<EarlyWarning.Models.Locations> ?? new List<EarlyWarning.Models.Locations>();
}

<style>
    /* Your existing styles plus modal styles */
    .page-header {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 25px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
    }

    .form-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        overflow: hidden;
    }

    .card-header-custom {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 12px 20px;
        font-weight: 600;
    }

        .card-header-custom i {
            margin-right: 8px;
        }

    .card-header-danger {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }

    .card-header-success {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    }

    .card-body-custom {
        padding: 25px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
    }

        .form-label i {
            margin-right: 5px;
            color: #1e3c72;
        }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 10px 12px;
        width: 100%;
    }

        .form-control:focus, .form-select:focus {
            border-color: #1e3c72;
            outline: none;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 80px;
    }

    .checkbox-group {
        background: #e8f4f8;
        padding: 15px 20px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
    }

    .checkbox-label {
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .checkbox-label input {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }

    .badge-status {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
    }

        .badge-status.inactive {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 25px;
    }

    .btn-custom {
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-submit {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
    }

    .btn-back {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white;
    }

    .btn-add {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
    }

    .btn-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        color: white;
    }

    .text-danger {
        color: #dc3545;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .info-hint {
        background: #e8f4f8;
        border-left: 3px solid #1e3c72;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        margin: -10px;
    }

    .col-md-6 {
        flex: 0 0 50%;
        padding: 10px;
    }

    .col-md-12 {
        flex: 0 0 100%;
        padding: 10px;
    }

    /* Modal Styles */
    .modal-custom {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.5);
        overflow-y: auto;
    }

    .modal-content-custom {
        background-color: white;
        margin: 50px auto;
        width: 90%;
        max-width: 800px;
        border-radius: 12px;
        animation: slideDown 0.3s ease;
    }

    .modal-header-custom {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 15px 20px;
        border-radius: 12px 12px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-body-custom {
        padding: 25px;
        max-height: 60vh;
        overflow-y: auto;
    }

    .modal-footer-custom {
        padding: 15px 20px;
        border-top: 1px solid #e0e0e0;
        display: flex;
        gap: 10px;
        justify-content: flex-end;
    }

    .close-modal {
        background: none;
        border: none;
        color: white;
        font-size: 28px;
        cursor: pointer;
    }

    .demographics-section {
        margin-top: 15px;
        padding-top: 15px;
        border-top: 1px solid #e0e0e0;
    }

        .demographics-section:first-child {
            border-top: none;
            margin-top: 0;
            padding-top: 0;
        }

    @@keyframes slideDown {
        from

    {
        transform: translateY(-50px);
        opacity: 0;
    }

    to {
        transform: translateY(0);
        opacity: 1;
    }

    }

    @@media (max-width: 768px) {
        .form-container {
            max-width: 100%;
        }

        .card-body-custom {
            padding: 20px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-custom {
            width: 100%;
            text-align: center;
        }

        .checkbox-group {
            flex-direction: column;
            gap: 10px;
            align-items: flex-start;
        }

        .col-md-6 {
            flex: 0 0 100%;
        }

        .modal-content-custom {
            width: 95%;
            margin: 20px auto;
        }
    }
</style>

<div class="container-fluid">
    <div class="form-container">
        <div class="page-header">
            <h1><i class="fas fa-plus-circle"></i> @ViewData["Title"]</h1>
            <p>እባክዎ በሳምንቱ የተከሰተውን የስደት መረጃ ይሙሉ</p>
        </div>

        <form asp-action="Create" method="post" id="migrationForm">
            @Html.AntiForgeryToken()

            <!-- Basic Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-calendar-alt"></i> መሰረታዊ መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="StartDate" class="form-label">
                                    <i class="fas fa-calendar-week"></i> @Html.DisplayNameFor(m => m.StartDate)
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="EndDate" class="form-label">
                                    <i class="fas fa-calendar-check"></i> @Html.DisplayNameFor(m => m.EndDate)
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="EndDate" class="form-control" type="date" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        
                        <div class="col-md-6">
                            <div class="checkbox-group">
                                <label class="checkbox-label">
                                    <input asp-for="HasMigration" type="checkbox" id="hasMigrationCheckbox" />
                                    <span><i class="fas fa-people-arrows"></i> @Html.DisplayNameFor(m => m.HasMigration)</span>
                                </label>
                                <span id="statusBadge" class="badge-status">
                                    <i class="fas fa-check-circle"></i> ስደት የለም
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Migration Details Card -->
            <div id="migrationSection" class="form-card" style="display: none;">
                <div class="card-header-custom">
                    <i class="fas fa-people-arrows"></i> የስደት ዝርዝሮች
                </div>
                <div class="card-body-custom">
                    <button type="button" class="btn btn-add mb-3" id="btnShowModal">
                        <i class="fas fa-plus"></i> አዲስ የስደት ዝርዝር ይጨምሩ
                    </button>

                    <div id="migrationsList" class="mt-3"></div>

                    <div class="info-hint mt-3">
                        <i class="fas fa-info-circle"></i> በርካታ የስደት ዝርዝሮችን አንድ ላይ መመዝገብ ይችላሉ
                    </div>
                </div>
            </div>

            <!-- General Notes Card -->
            <div class="form-card">
                <div class="card-header-custom card-header-success">
                    <i class="fas fa-file-alt"></i> አጠቃላይ መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="form-group">
                        <label asp-for="GeneralNotes" class="form-label">
                            <i class="fas fa-sticky-note"></i> @Html.DisplayNameFor(m => m.GeneralNotes)
                        </label>
                        <textarea asp-for="GeneralNotes" class="form-control" rows="3" placeholder="ተጨማሪ ማስታወሻ ካለ ያስገቡ..."></textarea>
                        <span asp-validation-for="GeneralNotes" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Report Info Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-user-edit"></i> የሪፖርት መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ReportDate" class="form-label">
                                    <i class="fas fa-calendar-day"></i> @Html.DisplayNameFor(m => m.ReportDate)
                                </label>
                                <input asp-for="ReportDate" class="form-control" type="datetime-local" />
                                <span asp-validation-for="ReportDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ReportedBy" class="form-label">
                                    <i class="fas fa-user"></i> @Html.DisplayNameFor(m => m.ReportedBy)
                                </label>
                                <input asp-for="ReportedBy" class="form-control" placeholder="ሙሉ ስም ያስገቡ" />
                                <span asp-validation-for="ReportedBy" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="ApprovalStatus" class="form-label">
                            <i class="fas fa-check-circle"></i> @Html.DisplayNameFor(m => m.ApprovalStatus)
                        </label>
                        <select asp-for="ApprovalStatus" class="form-control" asp-items="Html.GetEnumSelectList<ApprovalStatus>()">
                            <option value="">-- ሁኔታ ይምረጡ --</option>
                        </select>
                        <span asp-validation-for="ApprovalStatus" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <a asp-action="Index" class="btn-custom btn-back">
                    <i class="fas fa-arrow-left"></i> ወደ ዝርዝር ተመለስ
                </a>
                <button type="submit" class="btn-custom btn-submit">
                    <i class="fas fa-save"></i> መዝግብ
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal for Migration Detail with Demographics -->
<div id="migrationModal" class="modal-custom">
    <div class="modal-content-custom">
        <div class="modal-header-custom">
            <h4><i class="fas fa-people-arrows"></i> የስደት ዝርዝር መረጃ</h4>
            <button type="button" class="close-modal">&times;</button>
        </div>
        <div class="modal-body-custom">
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-map-marker-alt"></i> የተሰደዱበት ቦታ (ከየት)
                            <span class="text-danger">*</span>
                        </label>
                        <select id="modalOriginLocationId" class="form-control">
                            <option value="">-- ይምረጡ --</option>
                            @foreach (var loc in locations)
                            {
                                <option value="@loc.Id">@loc.LocationAmharicName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-question-circle"></i> የስደት ምክንያት
                        </label>
                        <input type="text" id="modalMigrationReason" class="form-control" placeholder="ለምሳሌ፦ የውሃ ችግር፣ የስራ እድል..." />
                    </div>
                </div>
            </div>

            <hr />

            <h5 class="text-primary"><i class="fas fa-users"></i> በስደት የተጎዳ ማህበረሰብ</h5>

            <!-- Household Heads -->
            <div class="demographics-section">
                <h6><i class="fas fa-user-friends"></i> አባወራ / እማወራ</h6>
                <div class="row">
                    <div class="col-md-6">
                        <label>ወንድ</label>
                        <input type="number" id="modalMaleHouseholdHeads" class="form-control" value="0" min="0" />
                    </div>
                    <div class="col-md-6">
                        <label>ሴት</label>
                        <input type="number" id="modalFemaleHouseholdHeads" class="form-control" value="0" min="0" />
                    </div>
                </div>
            </div>

            <!-- Family Members -->
            <div class="demographics-section">
                <h6><i class="fas fa-home"></i> ቤተሰብ</h6>
                <div class="row">
                    <div class="col-md-6">
                        <label>ወንድ</label>
                        <input type="number" id="modalMaleFamilyMembers" class="form-control" value="0" min="0" />
                    </div>
                    <div class="col-md-6">
                        <label>ሴት</label>
                        <input type="number" id="modalFemaleFamilyMembers" class="form-control" value="0" min="0" />
                    </div>
                </div>
            </div>

            <!-- Children -->
            <div class="demographics-section">
                <h6><i class="fas fa-child"></i> ህጻናት</h6>
                <div class="row">
                    <div class="col-md-6">
                        <label>ወንድ</label>
                        <input type="number" id="modalMaleChildren" class="form-control" value="0" min="0" />
                    </div>
                    <div class="col-md-6">
                        <label>ሴት</label>
                        <input type="number" id="modalFemaleChildren" class="form-control" value="0" min="0" />
                    </div>
                </div>
            </div>

            <!-- Youth -->
            <div class="demographics-section">
                <h6><i class="fas fa-user-graduate"></i> ወጣቶች</h6>
                <div class="row">
                    <div class="col-md-6">
                        <label>ወንድ</label>
                        <input type="number" id="modalMaleYouth" class="form-control" value="0" min="0" />
                    </div>
                    <div class="col-md-6">
                        <label>ሴት</label>
                        <input type="number" id="modalFemaleYouth" class="form-control" value="0" min="0" />
                    </div>
                </div>
            </div>

            <!-- Elderly -->
            <div class="demographics-section">
                <h6><i class="fas fa-user-astronaut"></i> አረጋውያን</h6>
                <div class="row">
                    <div class="col-md-6">
                        <label>ወንድ</label>
                        <input type="number" id="modalMaleElderly" class="form-control" value="0" min="0" />
                    </div>
                    <div class="col-md-6">
                        <label>ሴት</label>
                        <input type="number" id="modalFemaleElderly" class="form-control" value="0" min="0" />
                    </div>
                </div>
            </div>

            <!-- Disabled -->
            <div class="demographics-section">
                <h6><i class="fas fa-wheelchair"></i> አካል ጉዳተኞች</h6>
                <div class="row">
                    <div class="col-md-6">
                        <label>ወንድ</label>
                        <input type="number" id="modalMaleDisabled" class="form-control" value="0" min="0" />
                    </div>
                    <div class="col-md-6">
                        <label>ሴት</label>
                        <input type="number" id="modalFemaleDisabled" class="form-control" value="0" min="0" />
                    </div>
                </div>
            </div>

            <!-- Mothers -->
            <div class="demographics-section">
                <h6><i class="fas fa-female"></i> እናቶች</h6>
                <div class="row">
                    <div class="col-md-6">
                        <label>አጥቢ እናቶች</label>
                        <input type="number" id="modalLactatingMothers" class="form-control" value="0" min="0" />
                    </div>
                    <div class="col-md-6">
                        <label>ነፍሰጡር እናቶች</label>
                        <input type="number" id="modalPregnantWomen" class="form-control" value="0" min="0" />
                    </div>
                </div>
            </div>

            <div class="info-hint mt-3">
                <i class="fas fa-info-circle"></i> ሁሉንም የተሰደዱ ሰዎች በምድብ ይለዩ
            </div>
        </div>
        <div class="modal-footer-custom">
            <button type="button" class="btn-custom btn-back" id="modalCancelBtn">ይቅር</button>
            <button type="button" class="btn-custom btn-submit" id="modalSaveBtn">ዝርዝሩን ያስቀምጡ</button>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            var migrationDetails = [];

            // Modal elements
            var modal = $('#migrationModal');

            // Reset modal form
            function resetModal() {
                $('#modalOriginLocationId').val('');
                $('#modalMigrationReason').val('');
                $('#modalMaleHouseholdHeads').val(0);
                $('#modalFemaleHouseholdHeads').val(0);
                $('#modalMaleFamilyMembers').val(0);
                $('#modalFemaleFamilyMembers').val(0);
                $('#modalMaleChildren').val(0);
                $('#modalFemaleChildren').val(0);
                $('#modalMaleYouth').val(0);
                $('#modalFemaleYouth').val(0);
                $('#modalMaleElderly').val(0);
                $('#modalFemaleElderly').val(0);
                $('#modalMaleDisabled').val(0);
                $('#modalFemaleDisabled').val(0);
                $('#modalLactatingMothers').val(0);
                $('#modalPregnantWomen').val(0);
            }

            // Open modal
            $('#btnShowModal').on('click', function() {
                resetModal();
                modal.show();
            });

            // Close modal
            $('.close-modal, #modalCancelBtn').on('click', function() {
                modal.hide();
            });

            // Close modal when clicking outside
            $(window).on('click', function(e) {
                if ($(e.target).is('#migrationModal')) {
                    modal.hide();
                }
            });

            // Calculate totals for display
            function calculateDetailTotals(detail) {
                var totalMales = detail.maleHouseholdHeads + detail.maleFamilyMembers + detail.maleChildren +
                                 detail.maleYouth + detail.maleElderly + detail.maleDisabled;
                var totalFemales = detail.femaleHouseholdHeads + detail.femaleFamilyMembers + detail.femaleChildren +
                                   detail.femaleYouth + detail.femaleElderly + detail.femaleDisabled;
                var total = totalMales + totalFemales;
                return { totalMales, totalFemales, total };
            }

            // Save migration detail from modal
            $('#modalSaveBtn').on('click', function() {
                var originId = $('#modalOriginLocationId').val();
                var originName = $('#modalOriginLocationId option:selected').text();
                var reason = $('#modalMigrationReason').val();

                if (!originId) {
                    alert('እባክዎ የተሰደዱበት ቦታ ይምረጡ');
                    $('#modalOriginLocationId').focus();
                    return;
                }

                var detail = {
                    originLocationId: originId,
                    originLocationName: originName,
                    migrationReason: reason,
                    maleHouseholdHeads: parseInt($('#modalMaleHouseholdHeads').val()) || 0,
                    femaleHouseholdHeads: parseInt($('#modalFemaleHouseholdHeads').val()) || 0,
                    maleFamilyMembers: parseInt($('#modalMaleFamilyMembers').val()) || 0,
                    femaleFamilyMembers: parseInt($('#modalFemaleFamilyMembers').val()) || 0,
                    maleChildren: parseInt($('#modalMaleChildren').val()) || 0,
                    femaleChildren: parseInt($('#modalFemaleChildren').val()) || 0,
                    maleYouth: parseInt($('#modalMaleYouth').val()) || 0,
                    femaleYouth: parseInt($('#modalFemaleYouth').val()) || 0,
                    maleElderly: parseInt($('#modalMaleElderly').val()) || 0,
                    femaleElderly: parseInt($('#modalFemaleElderly').val()) || 0,
                    maleDisabled: parseInt($('#modalMaleDisabled').val()) || 0,
                    femaleDisabled: parseInt($('#modalFemaleDisabled').val()) || 0,
                    lactatingMothers: parseInt($('#modalLactatingMothers').val()) || 0,
                    pregnantWomen: parseInt($('#modalPregnantWomen').val()) || 0
                };

                var totals = calculateDetailTotals(detail);

                if (totals.total === 0) {
                    alert('እባክዎ ቢያንስ አንድ የተሰደደ ሰው ያስገቡ');
                    return;
                }

                detail.totalMigrants = totals.total;
                detail.totalMales = totals.totalMales;
                detail.totalFemales = totals.totalFemales;

                migrationDetails.push(detail);
                updateMigrationsDisplay();
                modal.hide();
            });

            // Update display of migration details
            function updateMigrationsDisplay() {
                var container = $('#migrationsList');
                container.empty();

                if (migrationDetails.length === 0) {
                    container.html('<div class="alert alert-info">ምንም የስደት ዝርዝር አልተመዘገበም</div>');
                    return;
                }

                var html = '<div class="table-responsive"><table class="table table-bordered"><thead>';
                html += '<tr><th>የተሰደዱበት ቦታ</th><th>ምክንያት</th><th>ወንድ</th><th>ሴት</th><th>ጠቅላላ</th><th>ድርጊት</th></tr></thead><tbody>';

                $.each(migrationDetails, function(index, item) {
                    html += '<tr>';
                    html += '<td><strong>' + escapeHtml(item.originLocationName) + '</strong></td>';
                    html += '<td>' + escapeHtml(item.migrationReason || '-') + '</td>';
                    html += '<td class="text-end">' + item.totalMales.toLocaleString() + '</td>';
                    html += '<td class="text-end">' + item.totalFemales.toLocaleString() + '</td>';
                    html += '<td class="text-end"><strong>' + item.totalMigrants.toLocaleString() + '</strong></td>';
                    html += '<td class="text-center">';
                    html += '<button type="button" class="btn btn-sm btn-danger remove-detail" data-index="' + index + '">';
                    html += '<i class="fas fa-trash"></i> ሰርዝ';
                    html += '</button></td>';
                    html += '</tr>';
                });

                html += '</tbody></tr></div>';
                container.html(html);

                $('.remove-detail').on('click', function() {
                    var index = $(this).data('index');
                    migrationDetails.splice(index, 1);
                    updateMigrationsDisplay();
                });
            }

            function escapeHtml(text) {
                if (!text) return '';
                var map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#39;'
                };
                return text.replace(/[&<>"']/g, function(m) { return map[m]; });
            }

            function toggleSections() {
                var hasMigration = $('#hasMigrationCheckbox').is(':checked');
                if (hasMigration) {
                    $('#migrationSection').slideDown(300);
                    $('#statusBadge').removeClass('inactive').html('<i class="fas fa-exclamation-triangle"></i> ስደት አለ');
                } else {
                    $('#migrationSection').slideUp(300);
                    $('#statusBadge').addClass('inactive').html('<i class="fas fa-check-circle"></i> ስደት የለም');
                    migrationDetails = [];
                    updateMigrationsDisplay();
                }
            }

            $('#hasMigrationCheckbox').on('change', toggleSections);

            // Set default report date
            if (!$('#ReportDate').val()) {
                var now = new Date();
                var formattedDate = now.getFullYear() + '-' +
                    String(now.getMonth() + 1).padStart(2, '0') + '-' +
                    String(now.getDate()).padStart(2, '0') + 'T' +
                    String(now.getHours()).padStart(2, '0') + ':' +
                    String(now.getMinutes()).padStart(2, '0');
                $('#ReportDate').val(formattedDate);
            }

            toggleSections();

            // Form submission
            $('#migrationForm').on('submit', function(e) {
                

                if (!$('#StartDate').val()) {
                    e.preventDefault();
                    alert('እባክዎ የሪፖርት መነሻ ቀን ይምረጡ');
                    $('#StartDate').focus();
                    return false;
                }

                if (!$('#EndDate').val()) {
                    e.preventDefault();
                    alert('እባክዎ የሪፖርት መጨረሻ ቀን ይምረጡ');
                    $('#EndDate').focus();
                    return false;
                }

                if ($('#hasMigrationCheckbox').is(':checked')) {
                    if (migrationDetails.length === 0) {
                        e.preventDefault();
                        alert('እባክዎ ቢያንስ አንድ የስደት ዝርዝር ያስገቡ');
                        return false;
                    }

                    // Remove existing hidden fields
                    $('input[name^="MigrationDetails["]').remove();

                    // Add migration details as hidden fields
                    migrationDetails.forEach(function(item, idx) {
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].OriginLocationId', value: item.originLocationId }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].MigrationReason', value: item.migrationReason || '' }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].MaleHouseholdHeads', value: item.maleHouseholdHeads }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].FemaleHouseholdHeads', value: item.femaleHouseholdHeads }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].MaleFamilyMembers', value: item.maleFamilyMembers }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].FemaleFamilyMembers', value: item.femaleFamilyMembers }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].MaleChildren', value: item.maleChildren }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].FemaleChildren', value: item.femaleChildren }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].MaleYouth', value: item.maleYouth }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].FemaleYouth', value: item.femaleYouth }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].MaleElderly', value: item.maleElderly }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].FemaleElderly', value: item.femaleElderly }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].MaleDisabled', value: item.maleDisabled }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].FemaleDisabled', value: item.femaleDisabled }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].LactatingMothers', value: item.lactatingMothers }).appendTo('#migrationForm');
                        $('<input>').attr({ type: 'hidden', name: 'MigrationDetails[' + idx + '].PregnantWomen', value: item.pregnantWomen }).appendTo('#migrationForm');
                    });
                }

                return true;
            });
        });
    </script>
}