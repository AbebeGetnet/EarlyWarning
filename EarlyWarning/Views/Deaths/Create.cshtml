@using EarlyWarning.Enums
@model EarlyWarning.Models.Migration.Death

@{
    ViewData["Title"] = "የሞት ሪፖርት";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Custom Styles */
    .page-header {
        background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%);
        color: white;
        padding: 25px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            transform: rotate(45deg);
        }

        .page-header h1 {
            margin: 0;
            font-size: 1.6rem;
            position: relative;
            z-index: 1;
        }

        .page-header p {
            margin: 8px 0 0;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

    .form-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .form-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.15);
        }

    .card-header-custom {
        background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%);
        color: white;
        padding: 12px 20px;
        font-weight: 600;
    }

        .card-header-custom i {
            margin-right: 8px;
        }

    .card-body-custom {
        padding: 25px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        font-size: 0.9rem;
    }

        .form-label i {
            margin-right: 5px;
            color: #3498db;
        }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 10px 12px;
        width: 100%;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #3498db;
            box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.25);
            outline: none;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 80px;
    }

    .checkbox-group {
        background: #e8f4f8;
        padding: 15px 20px;
        border-radius: 10px;
        border: 1px solid #b8daff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
    }

    .checkbox-label {
        font-weight: 600;
        margin: 0;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .checkbox-label input {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }

    .badge-status {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
    }

        .badge-status.inactive {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        }

    .death-detail-card {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 15px;
        border-left: 4px solid #3498db;
        position: relative;
        transition: all 0.3s ease;
    }

        .death-detail-card:hover {
            background: #e8f4f8;
            transform: translateX(5px);
        }

    .btn-remove-death {
        position: absolute;
        top: 10px;
        right: 15px;
        background: none;
        border: none;
        color: #dc3545;
        font-size: 1.2rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-remove-death:hover {
            transform: scale(1.1);
        }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 25px;
    }

    .btn-custom {
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-submit {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
    }

    .btn-back {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white;
    }

    .btn-add {
        background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%);
        color: white;
    }

    .btn-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        color: white;
    }

    .btn-add:hover {
        color: white;
    }

    .text-danger {
        color: #dc3545;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .info-hint {
        background: #e8f4f8;
        border-left: 3px solid #3498db;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        margin: -10px;
    }

    .col-md-6 {
        flex: 0 0 50%;
        padding: 10px;
    }

    .col-md-12 {
        flex: 0 0 100%;
        padding: 10px;
    }

    .summary-card {
        background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%);
        color: white;
        border-radius: 12px;
        padding: 20px;
        margin-top: 20px;
    }

    .summary-stats {
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        gap: 20px;
    }

    .summary-item {
        text-align: center;
        flex: 1;
        min-width: 100px;
    }

    .summary-number {
        font-size: 1.5rem;
        font-weight: bold;
    }

    .summary-label {
        font-size: 0.8rem;
        opacity: 0.9;
    }

    /* Modal Styles */
    .modal-header-custom {
        background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%);
        color: white;
    }

        .modal-header-custom .btn-close {
            filter: brightness(0) invert(1);
        }

    @@media (max-width: 768px) {
        .form-container {
            max-width: 100%;
        }

        .card-body-custom {
            padding: 20px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-custom {
            width: 100%;
            text-align: center;
        }

        .col-md-6 {
            flex: 0 0 100%;
        }

        .summary-number {
            font-size: 1.2rem;
        }
    }
</style>

<div class="container-fluid">
    <div class="form-container">
        <!-- Page Header -->
        <div class="page-header">
            <h1>
                <i class="fas fa-plus-circle"></i> @ViewData["Title"]
            </h1>
            <p>እባክዎ በሳምንቱ የተከሰቱ ሞቶች መረጃ ይሙሉ</p>
        </div>

        <form asp-action="Create" method="post" id="deathForm">
            @Html.AntiForgeryToken()

            <!-- Basic Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-calendar-alt"></i> መሰረታዊ መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="StartDate" class="form-label">
                                    <i class="fas fa-calendar-week"></i> @Html.DisplayNameFor(m => m.StartDate)
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="EndDate" class="form-label">
                                    <i class="fas fa-calendar-check"></i> @Html.DisplayNameFor(m => m.EndDate)
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="EndDate" class="form-control" type="date" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="WoredaId" class="form-label">
                                    <i class="fas fa-map-marker-alt"></i> @Html.DisplayNameFor(m => m.WoredaId)
                                    <span class="text-danger">*</span>
                                </label>
                                <select asp-for="WoredaId" class="form-control" asp-items="ViewBag.WoredaId">
                                    <option value="">-- ወረዳ ይምረጡ --</option>
                                </select>
                                <span asp-validation-for="WoredaId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <div class="checkbox-group">
                                    <label class="checkbox-label">
                                        <input asp-for="HasDeath" type="checkbox" id="hasDeathCheckbox" />
                                        <span>
                                            <i class="fas fa-skull"></i> @Html.DisplayNameFor(m => m.HasDeath)
                                        </span>
                                    </label>
                                    <span id="statusBadge" class="badge-status">
                                        <i class="fas fa-check-circle"></i> ሞት የለም
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Multiple Death Details Card -->
            <div class="form-card" id="deathDetailsCard" style="display: none;">
                <div class="card-header-custom">
                    <i class="fas fa-skull"></i> የሞት ዝርዝሮች
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-question-circle"></i> የሞት ምክንያት
                                </label>
                                <input type="text" id="deathReasonInput" class="form-control" placeholder="ለምሳሌ፦ በሽታ፣ አደጋ፣ እርጅና፣ ወዘተ..." />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-user-friends"></i> አባወራ (ወንድ)
                                </label>
                                <input type="number" id="maleHouseholdsInput" class="form-control" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-user-friends"></i> እማወራ (ሴት)
                                </label>
                                <input type="number" id="femaleHouseholdsInput" class="form-control" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-home"></i> ቤተሰብ (ወንድ)
                                </label>
                                <input type="number" id="maleFamilyInput" class="form-control" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-home"></i> ቤተሰብ (ሴት)
                                </label>
                                <input type="number" id="femaleFamilyInput" class="form-control" min="0" value="0" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-child"></i> ህጻናት (ወንድ)
                                </label>
                                <input type="number" id="maleChildrenInput" class="form-control" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-child"></i> ህጻናት (ሴት)
                                </label>
                                <input type="number" id="femaleChildrenInput" class="form-control" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-user-graduate"></i> ወጣቶች (ወንድ)
                                </label>
                                <input type="number" id="maleYouthInput" class="form-control" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-user-graduate"></i> ወጣቶች (ሴት)
                                </label>
                                <input type="number" id="femaleYouthInput" class="form-control" min="0" value="0" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-user-astronaut"></i> አረጋውያን (ወንድ)
                                </label>
                                <input type="number" id="maleElderlyInput" class="form-control" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-user-astronaut"></i> አረጋውያን (ሴት)
                                </label>
                                <input type="number" id="femaleElderlyInput" class="form-control" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-wheelchair"></i> አካል ጉዳተኛ (ወንድ)
                                </label>
                                <input type="number" id="maleDisabledInput" class="form-control" min="0" value="0" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-wheelchair"></i> አካል ጉዳተኛ (ሴት)
                                </label>
                                <input type="number" id="femaleDisabledInput" class="form-control" min="0" value="0" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-sticky-note"></i> ተጨማሪ ማስታወሻ
                        </label>
                        <textarea id="deathNotesInput" class="form-control" rows="2"></textarea>
                    </div>

                    <button type="button" class="btn btn-success" id="btnAddDeathDetail">
                        <i class="fas fa-plus"></i> ሞት ጨምር
                    </button>

                    <hr />

                    <div id="deathDetailsContainer">
                        <h6 class="text-primary"><i class="fas fa-list"></i> የተመዘገቡ ሞቶች</h6>
                        <div id="deathDetailsList" class="mt-3">
                            <div class="alert alert-info" id="noDeathDetailsMsg">ምንም ሞት አልተመዘገበም</div>
                        </div>
                    </div>

                    <div class="info-hint mt-3">
                        <i class="fas fa-info-circle"></i> በርካታ ሞቶችን በተለያየ ምክንያት መመዝገብ ይችላሉ
                    </div>
                </div>
            </div>

            <!-- Report Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-user-edit"></i> የሪፖርት መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ReportDate" class="form-label">
                                    <i class="fas fa-calendar-day"></i> @Html.DisplayNameFor(m => m.ReportDate)
                                </label>
                                <input asp-for="ReportDate" class="form-control" type="datetime-local" />
                                <span asp-validation-for="ReportDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ReportedBy" class="form-label">
                                    <i class="fas fa-user"></i> @Html.DisplayNameFor(m => m.ReportedBy)
                                </label>
                                <input asp-for="ReportedBy" class="form-control" placeholder="ሙሉ ስም ያስገቡ" />
                                <span asp-validation-for="ReportedBy" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label asp-for="ApprovalStatus" class="form-label">
                                    <i class="fas fa-check-circle"></i> @Html.DisplayNameFor(m => m.ApprovalStatus)
                                </label>
                                <select asp-for="ApprovalStatus" class="form-control" asp-items="Html.GetEnumSelectList<ApprovalStatus>()">
                                    <option value="">-- ሁኔታ ይምረጡ --</option>
                                </select>
                                <span asp-validation-for="ApprovalStatus" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Summary Card -->
            <div class="summary-card" id="summaryCard" style="display: none;">
                <div class="summary-stats">
                    <div class="summary-item">
                        <div class="summary-number" id="totalDeathRecords">0</div>
                        <div class="summary-label"><i class="fas fa-skull"></i> ጠቅላላ ሞቶች</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-number" id="totalMales">0</div>
                        <div class="summary-label"><i class="fas fa-male"></i> ጠቅላላ ወንዶች</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-number" id="totalFemales">0</div>
                        <div class="summary-label"><i class="fas fa-female"></i> ጠቅላላ ሴቶች</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-number" id="totalDeaths">0</div>
                        <div class="summary-label"><i class="fas fa-users"></i> ጠቅላላ ሞት</div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <a asp-action="Index" class="btn-custom btn-back">
                    <i class="fas fa-arrow-left"></i> ወደ ዝርዝር ተመለስ
                </a>
                <button type="submit" class="btn-custom btn-submit" id="submitBtn">
                    <i class="fas fa-save"></i> መዝግብ
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            var deathDetails = [];

            // Set default report date
            if (!$('#ReportDate').val()) {
                var now = new Date();
                var formattedDate = now.getFullYear() + '-' +
                                   String(now.getMonth() + 1).padStart(2, '0') + '-' +
                                   String(now.getDate()).padStart(2, '0') + 'T' +
                                   String(now.getHours()).padStart(2, '0') + ':' +
                                   String(now.getMinutes()).padStart(2, '0');
                $('#ReportDate').val(formattedDate);
            }

            // Toggle sections based on HasDeath
            $('#hasDeathCheckbox').on('change', function() {
                var hasDeath = $(this).is(':checked');
                var badge = $('#statusBadge');

                if (hasDeath) {
                    $('#deathDetailsCard').slideDown(300);
                    $('#summaryCard').slideDown(300);
                    badge.removeClass('inactive');
                    badge.html('<i class="fas fa-exclamation-triangle"></i> ሞት አለ');
                } else {
                    $('#deathDetailsCard').slideUp(300);
                    $('#summaryCard').slideUp(300);
                    badge.addClass('inactive');
                    badge.html('<i class="fas fa-check-circle"></i> ሞት የለም');
                    deathDetails = [];
                    updateDeathDetailsDisplay();
                }
            });

            // Add death detail
            $('#btnAddDeathDetail').on('click', function() {
                var deathReason = $('#deathReasonInput').val().trim();

                // Get all values
                var maleHouseholds = parseInt($('#maleHouseholdsInput').val()) || 0;
                var femaleHouseholds = parseInt($('#femaleHouseholdsInput').val()) || 0;
                var maleFamily = parseInt($('#maleFamilyInput').val()) || 0;
                var femaleFamily = parseInt($('#femaleFamilyInput').val()) || 0;
                var maleChildren = parseInt($('#maleChildrenInput').val()) || 0;
                var femaleChildren = parseInt($('#femaleChildrenInput').val()) || 0;
                var maleYouth = parseInt($('#maleYouthInput').val()) || 0;
                var femaleYouth = parseInt($('#femaleYouthInput').val()) || 0;
                var maleElderly = parseInt($('#maleElderlyInput').val()) || 0;
                var femaleElderly = parseInt($('#femaleElderlyInput').val()) || 0;
                var maleDisabled = parseInt($('#maleDisabledInput').val()) || 0;
                var femaleDisabled = parseInt($('#femaleDisabledInput').val()) || 0;
                var notes = $('#deathNotesInput').val();

                // Calculate total deaths
                var totalDeaths = maleHouseholds + femaleHouseholds + maleFamily + femaleFamily +
                                 maleChildren + femaleChildren + maleYouth + femaleYouth +
                                 maleElderly + femaleElderly + maleDisabled + femaleDisabled;

                // Validation: At least one death
                if (totalDeaths === 0) {
                    alert('እባክዎ ቢያንስ አንድ ሞት ያስገቡ');
                    return;
                }

                // Validation: Death reason is required if there are deaths
                if (!deathReason && totalDeaths > 0) {
                    alert('እባክዎ የሞት ምክንያት ያስገቡ');
                    $('#deathReasonInput').focus();
                    return;
                }

                deathDetails.push({
                    deathReason: deathReason,
                    maleHouseholds: maleHouseholds,
                    femaleHouseholds: femaleHouseholds,
                    maleFamilyMembers: maleFamily,
                    femaleFamilyMembers: femaleFamily,
                    maleChildren: maleChildren,
                    femaleChildren: femaleChildren,
                    maleYouth: maleYouth,
                    femaleYouth: femaleYouth,
                    maleElderly: maleElderly,
                    femaleElderly: femaleElderly,
                    maleDisabled: maleDisabled,
                    femaleDisabled: femaleDisabled,
                    notes: notes
                });

                // Reset inputs
                $('#deathReasonInput').val('');
                $('#maleHouseholdsInput').val(0);
                $('#femaleHouseholdsInput').val(0);
                $('#maleFamilyInput').val(0);
                $('#femaleFamilyInput').val(0);
                $('#maleChildrenInput').val(0);
                $('#femaleChildrenInput').val(0);
                $('#maleYouthInput').val(0);
                $('#femaleYouthInput').val(0);
                $('#maleElderlyInput').val(0);
                $('#femaleElderlyInput').val(0);
                $('#maleDisabledInput').val(0);
                $('#femaleDisabledInput').val(0);
                $('#deathNotesInput').val('');

                updateDeathDetailsDisplay();
            });

            // Update displayed list
            function updateDeathDetailsDisplay() {
                var container = $('#deathDetailsList');
                container.empty();

                if (deathDetails.length === 0) {
                    container.html('<div class="alert alert-info" id="noDeathDetailsMsg">ምንም ሞት አልተመዘገበም</div>');
                    updateSummary();
                    return;
                }

                var html = '<div class="table-responsive"><table class="table table-bordered table-sm"><thead>';
                html += '<tr><th>የሞት ምክንያት</th><th>ወንዶች</th><th>ሴቶች</th><th>ጠቅላላ</th><th>ማስታወሻ</th><th>ድርጊት</th></tr></thead><tbody>';

                $.each(deathDetails, function(index, item) {
                    var totalMales = (item.maleHouseholds || 0) + (item.maleFamilyMembers || 0) + (item.maleChildren || 0) +
                                    (item.maleYouth || 0) + (item.maleElderly || 0) + (item.maleDisabled || 0);
                    var totalFemales = (item.femaleHouseholds || 0) + (item.femaleFamilyMembers || 0) + (item.femaleChildren || 0) +
                                      (item.femaleYouth || 0) + (item.femaleElderly || 0) + (item.femaleDisabled || 0);
                    var total = totalMales + totalFemales;

                    html += '<tr>';
                    html += '<td><strong>' + (item.deathReason || '-') + '</strong></td>';
                    html += '<td class="text-end">' + totalMales + '</td>';
                    html += '<td class="text-end">' + totalFemales + '</td>';
                    html += '<td class="text-end fw-bold">' + total + '</td>';
                    html += '<td>' + (item.notes || '-') + '</td>';
                    html += '<td class="text-center">';
                    html += '<button type="button" class="btn btn-sm btn-danger remove-death" data-index="' + index + '">';
                    html += '<i class="fas fa-trash"></i> ሰርዝ';
                    html += '</button></td>';
                    html += '</tr>';
                });

                html += '</tbody></table></div>';
                container.html(html);

                $('.remove-death').on('click', function() {
                    var index = $(this).data('index');
                    deathDetails.splice(index, 1);
                    updateDeathDetailsDisplay();
                    updateSummary();
                });

                updateSummary();
            }

            // Update summary statistics
            function updateSummary() {
                if (deathDetails.length === 0) {
                    $('#summaryCard').hide();
                    return;
                }

                $('#summaryCard').show();
                $('#totalDeathRecords').text(deathDetails.length);

                var totalMales = 0, totalFemales = 0, totalDeaths = 0;

                $.each(deathDetails, function(index, item) {
                    var males = (item.maleHouseholds || 0) + (item.maleFamilyMembers || 0) + (item.maleChildren || 0) +
                               (item.maleYouth || 0) + (item.maleElderly || 0) + (item.maleDisabled || 0);
                    var females = (item.femaleHouseholds || 0) + (item.femaleFamilyMembers || 0) + (item.femaleChildren || 0) +
                                 (item.femaleYouth || 0) + (item.femaleElderly || 0) + (item.femaleDisabled || 0);

                    totalMales += males;
                    totalFemales += females;
                    totalDeaths += males + females;
                });

                $('#totalMales').text(totalMales);
                $('#totalFemales').text(totalFemales);
                $('#totalDeaths').text(totalDeaths);
            }

            // Form validation before submit
            $('#deathForm').on('submit', function(e) {
                var hasDeath = $('#hasDeathCheckbox').is(':checked');

                if (hasDeath && deathDetails.length === 0) {
                    e.preventDefault();
                    alert('እባክዎ ቢያንስ አንድ ሞት ይመዝግቡ');
                    return false;
                }

                // Add hidden fields for each death detail
                deathDetails.forEach(function(item, index) {
                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].DeathReason',
                        value: item.deathReason
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].MaleHouseholdHeads',
                        value: item.maleHouseholds
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].FemaleHouseholdHeads',
                        value: item.femaleHouseholds
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].MaleFamilyMembers',
                        value: item.maleFamilyMembers
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].FemaleFamilyMembers',
                        value: item.femaleFamilyMembers
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].MaleChildren',
                        value: item.maleChildren
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].FemaleChildren',
                        value: item.femaleChildren
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].MaleYouth',
                        value: item.maleYouth
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].FemaleYouth',
                        value: item.femaleYouth
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].MaleElderly',
                        value: item.maleElderly
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].FemaleElderly',
                        value: item.femaleElderly
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].MaleDisabled',
                        value: item.maleDisabled
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].FemaleDisabled',
                        value: item.femaleDisabled
                    }).appendTo('#deathForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'DeathDetails[' + index + '].Notes',
                        value: item.notes || ''
                    }).appendTo('#deathForm');
                });

                return true;
            });

            // Initial state
            if ($('#hasDeathCheckbox').is(':checked')) {
                $('#deathDetailsCard').show();
                $('#summaryCard').show();
            }
        });
    </script>
}