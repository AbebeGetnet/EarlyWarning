@model PastureStatus
@{
    ViewData["Title"] = "የእንስሣት የግጦሽ ሁኔታ አርትዕ";
}
<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-warning text-dark">
            <h3>@ViewData["Title"]</h3>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post" id="pastureForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="WoredaId" />
                <div class="row">
                    <div class="col-md-6">
                        <label>ወረዳ</label>
                        <input class="form-control" value="@ViewBag.WoredaName" readonly disabled />
                    </div>
                </div>
                <hr />
                <!-- Date range row -->
                <div class="section-card mb-1 p-3 bg-light rounded">
                    <h5 class="text-primary-custom"><i class="bi bi-calendar-week"></i> የሪፖርት ጊዜ/ሳምንት</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label fw-bold"></label>
                            <input asp-for="StartDate" type="date" required class="form-control" />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-bold"></label>
                            <input asp-for="EndDate" type="date" required class="form-control" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div id="dateRangeError" class="validation-summary-error" style="display:none;"></div>
                </div>
                <!-- Radio buttons for Enough / Not Enough -->
                <div class="row">
                    <div class="col">
                        <label>የግጦሽ መሬት ሁኔታ</label>
                        <div class="d-flex gap-3 mt-2">
                            <div class="form-check">
                                <input type="radio" asp-for="Enough" value="true" class="form-check-input" id="enoughTrue" />
                                <label class="form-check-label" for="enoughTrue">በቂ ነው</label>
                            </div>&nbsp;&nbsp;&nbsp;
                            <div class="form-check">
                                <input type="radio" asp-for="Enough" value="false" class="form-check-input" id="enoughFalse" />
                                <label class="form-check-label" for="enoughFalse">በቂ አይደለም</label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Detailed fields – hidden when Enough is true -->
                <div id="detailsSection" style="display: none;">
                    <div class="row mt-3">
                        <div class="col">
                            <label asp-for="NumberOfAnimalsAffected"></label>
                            <input asp-for="NumberOfAnimalsAffected" class="form-control" />
                        </div>
                    </div>

                    <h4 class="mt-3">በችግሩ የተጎዳ ማህበረሰብ</h4>
                    <h5 class="mt-3">የቤተሰብ ብዛት</h5>
                    <div class="row">
                        <div class="col"><label asp-for="MaleHouseHold"></label><input asp-for="MaleHouseHold" class="form-control" /></div>
                        <div class="col"><label asp-for="FemaleHouseHold"></label><input asp-for="FemaleHouseHold" class="form-control" /></div>
                        <div class="col"><label asp-for="MaleFamily"></label><input asp-for="MaleFamily" class="form-control" /></div>
                        <div class="col"><label asp-for="FemaleFamily"></label><input asp-for="FemaleFamily" class="form-control" /></div>
                    </div>
                    <div class="row">
                        <div class="col"><label asp-for="ChildhMale"></label><input asp-for="ChildhMale" class="form-control" /></div>
                        <div class="col"><label asp-for="ChildFemale"></label><input asp-for="ChildFemale" class="form-control" /></div>
                        <div class="col"><label asp-for="YouthMale"></label><input asp-for="YouthMale" class="form-control" /></div>
                        <div class="col"><label asp-for="YouthFemale"></label><input asp-for="YouthFemale" class="form-control" /></div>
                    </div>
                    <div class="row">
                        <div class="col"><label asp-for="ElderlyMale"></label><input asp-for="ElderlyMale" class="form-control" /></div>
                        <div class="col"><label asp-for="ElderlyFemale"></label><input asp-for="ElderlyFemale" class="form-control" /></div>
                        <div class="col"><label asp-for="DisabledMale"></label><input asp-for="DisabledMale" class="form-control" /></div>
                        <div class="col"><label asp-for="DisabledFemale"></label><input asp-for="DisabledFemale" class="form-control" /></div>
                    </div>

                    <div class="mt-3">
                        <label asp-for="Remarks"></label>
                        <textarea asp-for="Remarks" class="form-control"></textarea>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary mt-3">አስቀምጥ</button>
                <a asp-action="Index" class="btn btn-secondary mt-3">ወደ ዝርዝር</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleDetails() {
            var enoughRadio = document.getElementById('enoughTrue');
            var details = document.getElementById('detailsSection');
            if (enoughRadio.checked) {
                details.style.display = 'none';
                var inputs = details.querySelectorAll('input, textarea');
                inputs.forEach(function(input) {
                    input.disabled = true;
                });
            } else {
                details.style.display = 'block';
                var inputs = details.querySelectorAll('input, textarea');
                inputs.forEach(function(input) {
                    input.disabled = false;
                });
            }
        }

        var enoughTrue = document.getElementById('enoughTrue');
        var enoughFalse = document.getElementById('enoughFalse');
        enoughTrue.addEventListener('change', toggleDetails);
        enoughFalse.addEventListener('change', toggleDetails);
        toggleDetails(); // initial state based on model value
    </script>
}