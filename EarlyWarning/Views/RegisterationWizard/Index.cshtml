@section Scripts {
    <script>
        let currentStep = 0;
        const steps = document.getElementsByClassName("wizard-step");
        const totalSteps = steps.length;
        let currentWoredaMaxKebeles = 0;

        function updateMaxKebeleLimit() {
            const totalKebelesInput = document.getElementById("totalWoredaKebeles");
            if (totalKebelesInput) {
                currentWoredaMaxKebeles = parseInt(totalKebelesInput.value) || 0;
            }
            
            const badge = document.getElementById("woredaKebeleCountBadge");
            if (badge) {
                badge.innerText = currentWoredaMaxKebeles;
            }
        }

        function showStep(n) {
            steps[n].classList.remove("d-none");
            document.getElementById("prevBtn").classList.toggle("d-none", n === 0);

            if (n === (totalSteps - 1)) {
                buildDataPreviewEngine();
                document.getElementById("nextBtn").className = "btn btn-success px-5 ms-auto";
                document.getElementById("nextBtn").innerHTML = 'መረጃውን በአንድነት መዝግብ <i class="fas fa-cloud-upload-alt ms-2"></i>';
            } else {
                document.getElementById("nextBtn").className = "btn btn-primary px-5 ms-auto";
                document.getElementById("nextBtn").innerHTML = 'ቀጣይ ገጽ <i class="fas fa-arrow-right ms-2"></i>';
            }

            document.getElementById("stepIndicator").innerText = `ደረጃ ${n + 1} ከ ${totalSteps}`;
            document.getElementById("wizardProgress").style.width = ((n + 1) / totalSteps) * 100 + "%";
        }

        async function nextPrev(n) {
            if (n === 1) {
                let isStepValid = await validateCurrentStep();
                if (!isStepValid) return false;
            }

            steps[currentStep].classList.add("d-none");
            currentStep += n;

            if (currentStep >= totalSteps) {
                document.getElementById("earlyWarningForm").submit();
                return false;
            }
            showStep(currentStep);
        }

        // =======================================================
        // CLIENT-SIDE REALTIME INTEGER TYPE CONSTRAINT EVALUATION
        // =======================================================
        document.querySelectorAll(".form-for-int, input[type='number']:not([step='any'])").forEach(input => {
            input.addEventListener("keydown", function(e) {
                if (e.key === '.' || e.key === ',') {
                    e.preventDefault();
                }
            });

            input.addEventListener("input", function() {
                let val = this.value;
                if (parseFloat(val) < 0) {
                    this.value = 0;
                    return;
                }
                if (val.includes(".")) {
                    this.value = Math.floor(parseFloat(val)) || 0;
                }
            });

            input.addEventListener("blur", function() {
                if (this.value.trim() === "") {
                    this.value = 0;
                }
            });
        });

        // =======================================================
        // OVERRIDE TOGGLE HANDLERS TO WORK WITH RADIO ACTIONS
        // =======================================================
        function toggleCropPestFields() {
            const value = document.querySelector('input[name="hasPestRadio"]:checked').value === "true";
            document.getElementById("hasPestSwitch").value = value;
            document.getElementById("cropPestFields").classList.toggle("d-none", !value);
        }

        function togglePastureFields() {
            const value = document.querySelector('input[name="pastureEnoughRadio"]:checked').value === "true";
            document.getElementById("pastureEnoughSwitch").value = value;
            document.getElementById("pastureFields").classList.toggle("d-none", value);
        }

        function toggleWaterFields() {
            const value = document.querySelector('input[name="waterEnoughRadio"]:checked').value === "true";
            document.getElementById("waterEnoughSwitch").value = value;
            document.getElementById("waterFields").classList.toggle("d-none", value);
        }

        function toggleAnimalHealthFields() {
            const value = document.querySelector('input[name="healthEnoughRadio"]:checked').value === "true";
            document.getElementById("animalHealthEnoughSwitch").value = value;
            document.getElementById("animalHealthFields").classList.toggle("d-none", value);
        }

        // =======================================================
        // ASYNC STEP STEP-TRANSITION VALIDATOR WITH BOUNDARY CHECKS
        // =======================================================
        async function validateCurrentStep() {
            let valid = true;
            updateMaxKebeleLimit();
            
            // STEP 1 CONTEXT CHECK
            if (currentStep === 0) {
                const woredaSelect = document.getElementById("WoredaId");
                const startDateInput = document.getElementById("StartDate");
                const dateWarningAlert = document.getElementById("dateValidationWarning");

                if (!woredaSelect.value) { woredaSelect.classList.add("is-invalid"); valid = false; } 
                else { woredaSelect.classList.remove("is-invalid"); }

                if (startDateInput.value) {
                    const selectedDate = new Date(startDateInput.value);
                    selectedDate.setHours(0,0,0,0);
                    const today = new Date();
                    today.setHours(0,0,0,0);
                    const oldestAllowedDate = new Date(today);
                    oldestAllowedDate.setDate(today.getDate() - 8);

                    if (selectedDate < oldestAllowedDate || selectedDate > today) {
                        startDateInput.classList.add("is-invalid");
                        dateWarningAlert.classList.remove("d-none");
                        valid = false;
                    } else {
                        startDateInput.classList.remove("is-invalid");
                        dateWarningAlert.classList.add("d-none");
                    }
                } else { startDateInput.classList.add("is-invalid"); valid = false; }

                if (!valid) {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                    return false;
                }

                // API QUERY INTEGRATION
                try {
                    let response = await fetch(`/EarlyWarning/GetExistingWizardData?woredaId=${woredaSelect.value}&startDate=${startDateInput.value}&endDate=${document.getElementById("EndDate").value}`);
                    if (response.ok) {
                        let data = await response.json();
                        if (data.exists) {
                            document.getElementById("RecordId").value = "1";
                            document.getElementById("wizardModeBanner").classList.remove("d-none", "alert-info");
                            document.getElementById("wizardModeBanner").classList.add("alert-warning");
                            document.getElementById("wizardModeText").innerText = `‼️ ማሳሰቢያ፡ ለተመረጠው ወረዳ እና ሳምንት ቀድሞ የተመዘገበ ሪፖርት ተገኝቷል። አሁን የሚሞላው መረጃ የድሮውን ይተካዋል (Edit Mode Active)።`;
                            hydrateWizardForm(data);
                        } else {
                            document.getElementById("RecordId").value = "0";
                            document.getElementById("wizardModeBanner").classList.remove("d-none", "alert-warning");
                            document.getElementById("wizardModeBanner").classList.add("alert-info");
                            document.getElementById("wizardModeText").innerText = "✨ አዲስ ሳምንታዊ መረጃ ምዝገባ (Create Mode Active)...";
                            resetWizardForm();
                        }
                    }
                } catch (err) { console.error("Database graph API error:", err); }
            }
            
            // STEP 2 METADATA GEOMETRIC SUM LIMIT EVALUATION (Rainfall Report)
            if (currentStep === 1) {
                let rFull = parseInt(document.getElementById("rainFull").value) || 0;
                let rPartial = parseInt(document.getElementById("rainPartial").value) || 0;
                let rNone = parseInt(document.getElementById("rainNone").value) || 0;
                let rHigh = parseInt(document.getElementById("rainHigh").value) || 0;

                let totalReportedKebeles = rFull + rPartial + rNone;
                const rainFields = ["rainFull", "rainPartial", "rainNone", "rainHigh"];
                
                rainFields.forEach(id => {
                    let el = document.getElementById(id);
                    if (parseInt(el.value) > currentWoredaMaxKebeles) { el.classList.add("is-invalid"); valid = false; } 
                    else { el.classList.remove("is-invalid"); }
                });

                if (totalReportedKebeles > currentWoredaMaxKebeles || rHigh > currentWoredaMaxKebeles) {
                    valid = false;
                    alert(`⚠️ የተመዘገበው የቀበሌዎች ቁጥር ድምር ከወረዳው ጠቅላላ ቀበሌዎች ብዛት (${currentWoredaMaxKebeles}) መብለጥ አይችልም! እባክዎ ያርሙ።`);
                }
                if (!valid) window.scrollTo({ top: 0, behavior: 'smooth' });
            }

            // STEP 3 LAND ALLOCATION HIERARCHY EVALUATIONS
            if (currentStep === 2) {
                const errorAlert = document.getElementById("farmPlanValidationError");
                errorAlert.classList.add("d-none");
                document.querySelectorAll(".farm-val-meher, .farm-val-autumn, #meherPlan, #autumnPlan").forEach(el => el.classList.remove("is-invalid"));

                let meherPlanVal = parseFloat(document.getElementById("meherPlan").value) || 0;
                document.querySelectorAll(".farm-val-meher").forEach(input => {
                    if ((parseFloat(input.value) || 0) > meherPlanVal) { input.classList.add("is-invalid"); document.getElementById("meherPlan").classList.add("is-invalid"); valid = false; }
                });

                let autumnPlanVal = parseFloat(document.getElementById("autumnPlan").value) || 0;
                document.querySelectorAll(".farm-val-autumn").forEach(input => {
                    if ((parseFloat(input.value) || 0) > autumnPlanVal) { input.classList.add("is-invalid"); document.getElementById("autumnPlan").classList.add("is-invalid"); valid = false; }
                });
                if (!valid) { errorAlert.classList.remove("d-none"); window.scrollTo({ top: 0, behavior: 'smooth' }); }
            }

            // STEP 6 VALIDATION: ANIMAL WATER SUPPLY FIELD BOUNDARY CHECK
            if (currentStep === 5) {
                const waterKebelesInput = document.getElementById("waterKebelesCount");
                const waterFieldsActive = document.querySelector('input[name="waterEnoughRadio"]:checked').value === "false";
                
                if (waterFieldsActive) {
                    let waterKebelesCount = parseInt(waterKebelesInput.value) || 0;
                    
                    if (waterKebelesCount > currentWoredaMaxKebeles) {
                        waterKebelesInput.classList.add("is-invalid");
                        alert(`⚠️ የውሃ እጥረት የታየባቸው ቀበሌዎች ብዛት (${waterKebelesCount}) ከወረዳው ጠቅላላ ቀበሌዎች ብዛት (${currentWoredaMaxKebeles}) ሊበልጥ አይችልም!`);
                        valid = false;
                        window.scrollTo({ top: waterKebelesInput.offsetTop - 100, behavior: 'smooth' });
                    } else {
                        waterKebelesInput.classList.remove("is-invalid");
                    }
                }
            }

            return valid;
        }

        // =======================================================
        // HYDRATION AND DATA FLOW SCHEDULER
        // =======================================================
        function hydrateWizardForm(data) {
            document.getElementById("remarksInput").value = data.remarks || "";

            if (data.totalKebelesCount) {
                document.getElementById("totalWoredaKebeles").value = data.totalKebelesCount;
            }
            updateMaxKebeleLimit();

            if (data.rainfall) {
                document.getElementById("rainFull").value = data.rainfall.full;
                document.getElementById("rainPartial").value = data.rainfall.partial;
                document.getElementById("rainNone").value = data.rainfall.none;
                document.getElementById("rainHigh").value = data.rainfall.high;
                document.querySelectorAll(".kebele-checkbox").forEach(cb => cb.checked = data.rainfall.kebeleIds.includes(parseInt(cb.value)));
            }

            if (data.farming) {
                document.getElementById("meherPlan").value = data.farming.meherPlan;
                document.getElementById("meherPloughed").value = data.farming.meherPloughed;
                document.getElementById("meherSown").value = data.farming.meherSown;
                document.getElementById("meherHarvesting").value = data.farming.meherHarvesting;
                document.getElementById("meherResidual").value = data.farming.meherResidual;
                document.getElementById("autumnPlan").value = data.farming.autumnPlan;
                document.getElementById("autumnPloughed").value = data.farming.autumnPloughed;
                document.getElementById("autumnSown").value = data.farming.autumnSown;
                document.getElementById("autumnHarvesting").value = data.farming.autumnHarvesting;
                document.getElementById("autumnResidual").value = data.farming.autumnResidual;
            }

            if (data.pest) {
                document.getElementById(`hasPest${data.pest.hasOccured ? 'Yes' : 'No'}`).checked = true;
                document.getElementById("pestHectars").value = data.pest.hectars;
                document.getElementById("pestCropType").value = data.pest.cropType || "";
                document.querySelectorAll(".pest-checkbox").forEach(cb => cb.checked = data.pest.pestIds.includes(parseInt(cb.value)));
                const rows = document.getElementById("pestTable").querySelectorAll("tbody tr");
                mapDemographicInputs(rows[0], data.pest.mHH, data.pest.fHH);
                mapDemographicInputs(rows[1], data.pest.mFam, data.pest.fFam);
                mapDemographicInputs(rows[2], data.pest.mChild, data.pest.fChild);
                mapDemographicInputs(rows[3], data.pest.mYouth, data.pest.fYouth);
                mapDemographicInputs(rows[4], data.pest.mEld, data.pest.fEld);
                mapDemographicInputs(rows[5], data.pest.mDis, data.pest.fDis);
                toggleCropPestFields();
            }

            if (data.pasture) {
                document.getElementById(`pastureEnough${data.pasture.enough ? 'Yes' : 'No'}`).checked = true;
                document.getElementById("pastureAnimalsAffected").value = data.pasture.animalsAffected;
                const rows = document.getElementById("pastureTable").querySelectorAll("tbody tr");
                mapDemographicInputs(rows[0], data.pasture.mHH, data.pasture.fHH);
                mapDemographicInputs(rows[1], data.pasture.mFam, data.pasture.fFam);
                mapDemographicInputs(rows[2], data.pasture.mChild, data.pasture.fChild);
                mapDemographicInputs(rows[3], data.pasture.mYouth, data.pasture.fYouth);
                mapDemographicInputs(rows[4], data.pasture.mEld, data.pasture.fEld);
                mapDemographicInputs(rows[5], data.pasture.mDis, data.pasture.fDis);
                togglePastureFields();
            }

            if (data.water) {
                document.getElementById(`waterEnough${data.water.enough ? 'Yes' : 'No'}`).checked = true;
                document.getElementById("waterKebelesCount").value = data.water.kebelesCount;
                const rows = document.getElementById("waterTable").querySelectorAll("tbody tr");
                mapDemographicInputs(rows[0], data.water.mHH, data.water.fHH);
                mapDemographicInputs(rows[1], data.water.mFam, data.water.fFam);
                mapDemographicInputs(rows[2], data.water.mChild, data.water.fChild);
                mapDemographicInputs(rows[3], data.water.mYouth, data.water.fYouth);
                mapDemographicInputs(rows[4], data.water.mEld, data.water.fEld);
                mapDemographicInputs(rows[5], data.water.mDis, data.water.fDis);
                toggleWaterFields();
            }

            if (data.health) {
                document.getElementById(`healthEnough${data.health.enough ? 'Yes' : 'No'}`).checked = true;
                document.getElementById("healthAnimalsMale").value = data.health.infectedMale;
                document.getElementById("healthAnimalsFemale").value = data.health.infectedFemale;
                document.querySelectorAll(".health-checkbox").forEach(cb => cb.checked = data.health.diseaseIds.includes(parseInt(cb.value)));
                const rows = document.getElementById("healthTable").querySelectorAll("tbody tr");
                mapDemographicInputs(rows[0], data.health.mHH, data.health.fHH);
                mapDemographicInputs(rows[1], data.health.mFam, data.health.fFam);
                mapDemographicInputs(rows[2], data.health.mChild, data.health.fChild);
                mapDemographicInputs(rows[3], data.health.mYouth, data.health.fYouth);
                mapDemographicInputs(rows[4], data.health.mEld, data.health.fEld);
                mapDemographicInputs(rows[5], data.health.mDis, data.health.fDis);
                toggleAnimalHealthFields();
            }

            document.querySelectorAll('.calc-table').forEach(t => calculateGridTotals(t));
        }

        function mapDemographicInputs(rowDOM, maleVal, femaleVal) {
            if(!rowDOM) return;
            rowDOM.querySelector(".val-male").value = maleVal;
            rowDOM.querySelector(".val-female").value = femaleVal;
            rowDOM.querySelector(".row-total").innerText = (maleVal + femaleVal).toLocaleString();
        }

        function resetWizardForm() {
            document.getElementById("remarksInput").value = "";
            document.querySelectorAll("input[type='number']").forEach(el => el.value = "0");
            document.querySelectorAll("input[type='text']").forEach(el => el.value = "");
            document.querySelectorAll("input[type='checkbox']").forEach(el => el.checked = false);
            
            document.getElementById("hasPestNo").checked = true;
            document.getElementById("pastureEnoughYes").checked = true;
            document.getElementById("waterEnoughYes").checked = true;
            document.getElementById("healthEnoughYes").checked = true;
            
            toggleCropPestFields();
            togglePastureFields();
            toggleWaterFields();
            toggleAnimalHealthFields();
            document.querySelectorAll('.calc-table').forEach(t => calculateGridTotals(t));
        }

        // =======================================================
        // REAL-TIME MATHEMATICAL MATRIX GRID CALCULATION ENGINE
        // =======================================================
        function initMatrixCalculations() {
            document.querySelectorAll('.calc-table').forEach(table => {
                table.querySelectorAll('tbody tr').forEach(row => {
                    const maleInput = row.querySelector('.val-male');
                    const femaleInput = row.querySelector('.val-female');

                    if(maleInput && femaleInput) {
                        const calculateRow = () => {
                            let mValue = parseInt(maleInput.value) || 0;
                            let fValue = parseInt(femaleInput.value) || 0;
                            row.querySelector('.row-total').innerText = (mValue + fValue).toLocaleString();
                            calculateGridTotals(table);
                        };
                        maleInput.addEventListener('input', calculateRow);
                        femaleInput.addEventListener('input', calculateRow);
                    }
                });
            });
        }

        function calculateGridTotals(table) {
            let totalMaleSum = 0, totalFemaleSum = 0;
            table.querySelectorAll('tbody tr').forEach(row => {
                totalMaleSum += parseInt(row.querySelector('.val-male').value) || 0;
                totalFemaleSum += parseInt(row.querySelector('.val-female').value) || 0;
            });
            table.querySelector('.total-male').innerText = totalMaleSum.toLocaleString();
            table.querySelector('.total-female').innerText = totalFemaleSum.toLocaleString();
            table.querySelector('.grand-total').innerText = (totalMaleSum + totalFemaleSum).toLocaleString();
        }

