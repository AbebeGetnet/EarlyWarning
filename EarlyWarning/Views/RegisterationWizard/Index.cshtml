@model EarlyWarning.ViewModels.RegistrationWithardViewModel
@using EarlyWarning.Enums

<div class="container-fluid mt-4">
    <div class="card shadow border-0 rounded-lg">
        <div class="card-header bg-dark text-white p-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="fas fa-magic me-2"></i>የተቀናጀ የሳምንታዊ መረጃ መሰብሰቢያ ዊዛርድ (Early Warning Data Wizard)</h4>
            <span class="badge bg-info p-2" id="stepIndicator">ደረጃ 1 ከ 8</span>
        </div>
        
        <div class="progress rounded-0" style="height: 6px;">
            <div id="wizardProgress" class="progress-bar bg-success" role="progressbar" style="width: 12.5%;"></div>
        </div>

        <div class="card-body bg-light">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div id="wizardModeBanner" class="alert alert-info py-2 d-none shadow-sm animate-fade-in">
                <i class="fas fa-info-circle me-2"></i><span id="wizardModeText">አዲስ መረጃ በመፍጠር ላይ...</span>
            </div>

            <form asp-action="SubmitWizard" method="post" id="earlyWarningForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-danger mb-3 card p-2 bg-white d-none" id="errorSummaryBox"></div>

                <input type="hidden" asp-for="UserId" />
                <input type="hidden" id="RecordId" name="RecordId" value="0" />

                <div class="wizard-step" id="step1">
                    <div class="p-4 bg-white rounded shadow-sm border-top border-primary border-4">
                        <h4 class="text-primary mb-3"><i class="fas fa-map-marker-alt me-2"></i>ደረጃ 1፡ አጠቃላይ የአካባቢ እና የጊዜ መረጃ</h4>
                        <div class="alert alert-danger p-2 d-none" id="dateValidationWarning">
                            <i class="fas fa-exclamation-triangle me-2"></i><strong>የቀን ስህተት፡</strong> እባክዎ ካለፉት 8 ቀናት እስከ ዛሬ ያለውን ቀን ብቻ ያስገቡ (የወደፊት ቀን ወይም ከ8 ቀን የበለሰ መረጃ ማስገባት አይቻልም)።
                        </div>
                        <hr />
                        <div class="row">                            
                            <div class="col-md-4">
                                <label class="fw-bold">በወረዳ ያሉ ቀበሌዎች ብዛት</label>
                                <input id="totalWoredaKebeles" class="form-control text-center bg-light fw-bold text-primary" value="@ViewBag.TotalKebeles" readonly disabled />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="StartDate" class="form-label fw-bold">የመነሻ ቀን (ከ)</label>
                                <input asp-for="StartDate" id="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="EndDate" class="form-label fw-bold">የማጠናቀቂያ ቀን (እስከ)</label>
                                <input asp-for="EndDate" id="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="wizard-step d-none" id="step2">
                    <div class="p-4 bg-white rounded shadow-sm border-top border-info border-4">
                        <h4 class="text-info mb-3"><i class="fas fa-cloud-showers-heavy me-2"></i>ደረጃ 2፡ የዝናብ ስርጭት ሁኔታ</h4>
                        <div class="alert alert-info py-1 mb-3 bg-opacity-10 text-dark border-info">
                            <i class="fas fa-info-circle me-2 text-info"></i>የወረዳው ጠቅላላ የቀበሌዎች ብዛት ገደብ፦ <span id="woredaKebeleCountBadge" class="fw-bold text-primary">0</span>
                        </div>
                        <hr />
                        <div class="row g-3 mb-3">
                            <div class="col-md-3">
                                <label asp-for="RainfallReport.FullCoverageKebeles" class="form-label"></label>
                                <input asp-for="RainfallReport.FullCoverageKebeles" id="rainFull" class="form-control text-center" type="number" min="0" value="0" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="RainfallReport.PartialCoverageKebeles" class="form-label"></label>
                                <input asp-for="RainfallReport.PartialCoverageKebeles" id="rainPartial" class="form-control text-center" type="number" min="0" value="0" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="RainfallReport.NoRainKebeles" class="form-label"></label>
                                <input asp-for="RainfallReport.NoRainKebeles" id="rainNone" class="form-control text-center" type="number" min="0" value="0" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="RainfallReport.HighAmountKebeles" class="form-label"></label>
                                <input asp-for="RainfallReport.HighAmountKebeles" id="rainHigh" class="form-control text-center" type="number" min="0" value="0" />
                            </div>
                        </div>
                        <div class="p-3 bg-light rounded shadow-sm border">
                            <label class="form-label fw-bold text-dark"><i class="fas fa-map-signs me-1"></i>በከፍተኛ ዝናብ የተጎዱ ቀበሌዎችን ይምረጡ</label>
                            <div class="row pt-2 ms-1">
                                @if (Model.Kebelies != null)
                                {
                                    foreach (var kebele in Model.Kebelies)
                                    {
                                        <div class="col-md-3 form-check mb-2">
                                            <input class="form-check-input kebele-checkbox" type="checkbox" name="SelectedKebeliesIds" value="@kebele.Id" data-name="@kebele.LocationAmharicName" id="keb_@kebele.Id" />
                                            <label class="form-check-label" for="keb_@kebele.Id">@kebele.LocationAmharicName</label>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="wizard-step d-none" id="step3">
                    <div class="p-4 bg-white rounded shadow-sm border-top border-success border-4">
                        <h4 class="text-success mb-3"><i class="fas fa-seedling me-2"></i>ደረጃ 3፡ የግብርና ስራዎች ክንውን (ሄክታር)</h4>
                        <div class="alert alert-warning p-2 d-none" id="farmPlanValidationError">
                            <i class="fas fa-exclamation-triangle me-2"></i><strong>ስህተት፡</strong> የእቅድ መጠን ከተከናወኑት ማናቸውም መስኮች ማነስ አይችልም።
                        </div>
                        <hr />
                        <div class="row g-3">
                            <div class="col-md-6 border-end">
                                <h5 class="text-muted border-bottom pb-2">የመኸር ወቅት (Meher Season)</h5>
                                <div class="mb-2"><label class="fw-bold">የታቀደ (Plan)</label><input asp-for="FarmingActivity.MeherFarmPlan" id="meherPlan" type="number" step="any" min="0" class="form-control" value="0" /></div>
                                <div class="mb-2"><label>የታረሰ (Ploughed)</label><input asp-for="FarmingActivity.MeherPloughed" id="meherPloughed" type="number" step="any" min="0" class="form-control farm-val-meher" value="0" /></div>
                                <div class="mb-2"><label>የተዘራ (Sown)</label><input asp-for="FarmingActivity.MeherSown" id="meherSown" type="number" step="any" min="0" class="form-control farm-val-meher" value="0" /></div>
                                <div class="mb-2"><label>የተሰበሰበ (Harvesting)</label><input asp-for="FarmingActivity.MeherHarvestingHHarvesting" id="meherHarvesting" type="number" step="any" min="0" class="form-control farm-val-meher" value="0" /></div>
                                <div class="mb-2"><label>በቀሪ እርጥበት የተዘራ</label><input asp-for="FarmingActivity.MeherSownWithResidualMoisture" id="meherResidual" type="number" step="any" min="0" class="form-control farm-val-meher" value="0" /></div>
                            </div>
                            <div class="col-md-6">
                                <h5 class="text-muted border-bottom pb-2">የበልግ ወቅት (Autumn/Belg Season)</h5>
                                <div class="mb-2"><label class="fw-bold">የታቀደ (Plan)</label><input asp-for="FarmingActivity.AutumnFarmPlan" id="autumnPlan" type="number" step="any" min="0" class="form-control" value="0" /></div>
                                <div class="mb-2"><label>የታረሰ (Ploughed)</label><input asp-for="FarmingActivity.AutumnPloughed" id="autumnPloughed" type="number" step="any" min="0" class="form-control farm-val-autumn" value="0" /></div>
                                <div class="mb-2"><label>የተዘራ (Sown)</label><input asp-for="FarmingActivity.AutumnSown" id="autumnSown" type="number" step="any" min="0" class="form-control farm-val-autumn" value="0" /></div>
                                <div class="mb-2"><label>የተሰበሰበ (Harvesting)</label><input asp-for="FarmingActivity.AutumnHarvestingHHarvesting" id="autumnHarvesting" type="number" step="any" min="0" class="form-control farm-val-autumn" value="0" /></div>
                                <div class="mb-2"><label>በቀሪ እርጥበት የተዘራ</label><input asp-for="FarmingActivity.AutumnSownWithResidualMoisture" id="autumnResidual" type="number" step="any" min="0" class="form-control farm-val-autumn" value="0" /></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="wizard-step d-none" id="step4">
                    <div class="p-4 bg-white rounded shadow-sm border-top border-warning border-4">
                        <h4 class="text-warning mb-3"><i class="fas fa-bug me-2"></i>ደረጃ 4፡ የሰብል ተባይ እና በሽታ ሁኔታ</h4>
                        <hr />
                        
                        <div class="card p-3 bg-light mb-3">
                            <label class="form-label fw-bold mb-2">የሰብል ተባይ እና በሽታ ተከስቷል?</label>
                            <div class="d-flex gap-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="hasPestRadio" id="hasPestYes" value="true" onchange="toggleCropPestFields()">
                                    <label class="form-check-label fw-bold text-danger" for="hasPestYes">አዎ ተከስቷል</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="hasPestRadio" id="hasPestNo" value="false" onchange="toggleCropPestFields()" checked>
                                    <label class="form-check-label fw-bold text-success" for="hasPestNo">አልተከሰተም</label>
                                </div>
                            </div>
                            <input type="hidden" asp-for="CropPestAndDeseaseReport.HasPestAndDeseasOccured" id="hasPestSwitch" value="false" />
                        </div>

                        <div id="cropPestFields" class="d-none">
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label asp-for="CropPestAndDeseaseReport.AffectedLandInHectar" class="form-label"></label>
                                    <input asp-for="CropPestAndDeseaseReport.AffectedLandInHectar" id="pestHectars" class="form-control" value="0" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CropPestAndDeseaseReport.TypeOfCropAffected" class="form-label"></label>
                                    <input asp-for="CropPestAndDeseaseReport.TypeOfCropAffected" id="pestCropType" class="form-control" />
                                </div>
                            </div>

                            <div class="p-3 bg-light rounded mb-3 shadow-sm border">
                                <label class="form-label fw-bold text-danger"><i class="fas fa-virus me-1"></i>የተከሰቱ የበሽታ/ተባይ አይነቶች</label>
                                <div class="row pt-2 ms-1">
                                    @if (Model.CropPestAndDeseases != null)
                                    {
                                        foreach (var pest in Model.CropPestAndDeseases)
                                        {
                                            <div class="col-md-4 form-check mb-2">
                                                <input class="form-check-input pest-checkbox" type="checkbox" name="SelectedCropDiseaseIds" value="@pest.Id" data-name="@pest.Name" id="pest_@pest.Id" />
                                                <label class="form-check-label" for="pest_@pest.Id">@pest.Name</label>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>

                            <h5 class="text-muted mt-4 mb-2"><i class="fas fa-users me-2"></i>በተባይ/በሽታ ምክንያት የተጎዱ አርሶ አደሮች ስብጥር</h5>
                            <div class="table-responsive bg-white rounded shadow-sm">
                                <table class="table table-bordered text-center align-middle m-0 calc-table" id="pestTable">
                                    <thead class="table-warning text-dark">
                                        <tr>
                                            <th>የተጎጂዎች ምድብ</th>
                                            <th style="width: 25%;">ወንድ</th>
                                            <th style="width: 25%;">ሴት</th>
                                            <th style="width: 20%;" class="bg-warning bg-opacity-25 fw-bold">ድምር</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr><td class="bg-light fw-bold" data-label="አባወራ / እማወራ">አባወራ / እማወራ</td><td><input asp-for="CropPestAndDeseaseReport.MaleHouseHold" class="form-for-int form-control text-center val-male" type="number" min="0" value="0" /></td><td><input asp-for="CropPestAndDeseaseReport.FemaleHouseHold" class="form-for-int form-control text-center val-female" type="number" min="0" value="0" /></td><td class="fw-bold bg-light row-total">0</td></tr>
                                        <tr><td class="bg-light fw-bold" data-label="የቤተሰብ አባላት">የቤተሰብ አባላት</td><td><input asp-for="CropPestAndDeseaseReport.MaleFamily" class="form-for-int form-control text-center val-male" type="number" min="0" value="0" /></td><td><input asp-for="CropPestAndDeseaseReport.FemaleFamily" class="form-for-int form-control text-center val-female" type="number" min="0" value="0" /></td><td class="fw-bold bg-light row-total">0</td></tr>
                                        <tr><td class="bg-light fw-bold" data-label="ህጻናት">ህጻናት</td><td><input asp-for="CropPestAndDeseaseReport.ChildhMale" class="form-for-int form-control text-center val-male" type="number" min="0" value="0" /></td><td><input asp-for="CropPestAndDeseaseReport.ChildFemale" class="form-for-int form-control text-center val-female" type="number" min="0" value="0" /></td><td class="fw-bold bg-light row-total">0</td></tr>
                                        <tr><td class="bg-light fw-bold" data-label="ወጣቶች">ወጣቶች</td><td><input asp-for="CropPestAndDeseaseReport.YouthMale" class="form-for-int form-control text-center val-male" type="number" min="0" value="0" /></td><td><input asp-for="CropPestAndDeseaseReport.YouthFemale" class="form-for-int form-control text-center val-female" type="number" min="0" value="0" /></td><td class="fw-bold bg-light row-total">0</td></tr>
                                        <tr><td class="bg-light fw-bold" data-label="አረጋውያን">አረጋውያን</td><td><input asp-for="CropPestAndDeseaseReport.ElderlyMale" class="form-for-int form-control text-center val-male" type="number" min="0" value="0" /></td><td><input asp-for="CropPestAndDeseaseReport.ElderlyFemale" class="form-for-int form-control text-center val-female" type="number" min="0" value="0" /></td><td class="fw-bold bg-light row-total">0</td></tr>
                                        <tr><td class="bg-light fw-bold" data-label="አካል ጉዳተኞች">አካል ጉዳተኞች</td><td><input asp-for="CropPestAndDeseaseReport.DisabledMale" class="form-for-int form-control text-center val-male" type="number" min="0" value="0" /></td><td><input asp-for="CropPestAndDeseaseReport.DisabledFemale" class="form-for-int form-control text-center val-female" type="number" min="0" value="0" /></td><td class="fw-bold bg-light row-total">0</td></tr>
                                    </tbody>
                                    <tfoot class="table-light fw-bold border-top border-2">
                                        <tr class="text-primary">
                                            <td>ጠቅላላ ድምር (Grand Total)</td>
                                            <td class="total-male">0</td>
                                            <td class="total-female">0</td>
                                            <td class="bg-primary text-white grand-total">0</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="wizard-step d-none" id="step5">
                    <div class="p-4 bg-white rounded shadow-sm border-top border-success border-4">
                        <h4 class="text-success mb-3"><i class="fas fa-leaf me-2"></i>ደረጃ 5፡ 
                            መኖ ሁኔታ (Pasture Status)</h4>
                        <hr />
                        
                        <div class="card p-3 bg-light mb-3">
                            <label class="form-label fw-bold mb-2">የእንስሳት መኖ አቅርቦት ሁኔታ ምንድነው?</label>
                            <div class="d-flex gap-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="pastureEnoughRadio" id="pastureEnoughYes" value="true" onchange="togglePastureFields()" checked>
                                    <label class="form-check-label fw-bold text-success" for="pastureEnoughYes">በቂ ነው</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="pastureEnoughRadio" id="pastureEnoughNo" value="false" onchange="togglePastureFields()">
                                    <label class="form-check-label fw-bold text-danger" for="pastureEnoughNo">እጥረት አለ</label>
                                </div>
                            </div>
                            <input type="hidden" asp-for="PastureStatus.Enough" id="pastureEnoughSwitch" value="true" />
                        </div>

                        <div id="pastureFields" class="d-none">
                            <div class="mb-3 col-md-4">
                                <label asp-for="PastureStatus.NumberOfAnimalsAffected" class="form-label fw-bold text-danger"></label>
                                <input asp-for="PastureStatus.NumberOfAnimalsAffected" id="pastureAnimalsAffected" class="form-for-int form-control border-danger" type="number" min="0" value="0" />
                            </div>

                            <h5 class="text-muted mt-4 mb-2"><i class="fas fa-users me-2"></i>በመኖ እጥረት ምክንያት የተጎዱ አርብቶ አደሮች ስብጥር</h5>
                            <div class="table-responsive bg-white rounded shadow-sm">
                                <table class="table table-bordered text-center align-middle m-0 calc-table" id="pastureTable">
                                    <thead class="table-success text-dark">
                                        <tr>
                                            <th>የተጎጂዎች ምድብ</th>
                                            <th style="width: 40%;">ወንድ</th>
                                            <th style="width: 40%;">ሴት</th>
                                            <th style="width: 20%;" class="bg-success bg-opacity-25 fw-bold">ድምር</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr><td class="bg-light fw-bold" data-label="አባወራ / እማወራ">አባወራ / እማወራ</td><td><input asp-for="PastureStatus.MaleHouseHold" class="form-for-int form-control text-center val-male" type="number" min="0" value="0" /></td><td><input asp-for="PastureStatus.FemaleHouseHold" class="form-for-int form-control text-center val-female" type="number" min="0" value="0" /></td><td class="fw-bold bg-light row-total">0</td></tr>
                                        <tr><td class="bg-light fw-bold" data-label="የቤተሰብ አባላት">የቤተሰብ አባላት</td><td><input asp-for="PastureStatus.MaleFamily" class="form-for-int form-control text-center val-male" type="number" min="0" value="0" /></td><td><input asp-for="PastureStatus.FemaleFamily" class="form-for-int form-control text-center val-female" type="number" min="0" value="0" /></td><td class="fw-bold bg-light row-total">0</td></tr>
