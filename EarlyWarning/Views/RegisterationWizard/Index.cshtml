                </div>

                <div class="card mb-3 border-primary shadow-sm">
                    <div class="card-header bg-primary bg-opacity-10 text-primary fw-bold"><i class="fas fa-tint me-2"></i>ደረጃ 6፡ የእንስሳት ውሃ አቅርቦት ሁኔታ</div>
                    <div class="card-body bg-white">
                        <p><strong>የውሃ አቅርቦት በቂ ነው?</strong> ${!isWaterShort ? '<span class="badge bg-success">በቂ ነው</span>' : '<span class="badge bg-danger">እጥረት አለ</span>'}</p>
                        ${hasWaterShortage ? `
                            <p><strong>የውሃ እጥረት የታየባቸው ቀበሌዎች ብዛት፡</strong> <span class="fw-bold text-danger">${document.getElementById("waterKebelesCount").value}</span></p>
                            ${compileReviewGridHtml('waterTable', 'primary')}
                        ` : ''}
                    </div>
                </div>

                <div class="card mb-3 border-danger shadow-sm">
                    <div class="card-header bg-danger bg-opacity-10 text-danger fw-bold"><i class="fas fa-ambulance me-2"></i>ደረጃ 7፡ የእንስሳት ጤና እና በሽታዎች ሁኔታ ማጠቃለያ</div>
                    <div class="card-body bg-white">
                        <p><strong>የእንስሳት ጤና ሁኔታ አጥጋቢ ነው?</strong> ${!isHealthIssues ? '<span class="badge bg-success">አዎ አጥጋቢ ነው</span>' : '<span class="badge bg-danger">አጥጋቢ አይደለም (ችግር አለ)</span>'}</p>
                        ${hasHealthIssues ? `
                            <p><strong>የሞቱ/የታመሙ እንስሳት፡</strong> ወንድ፦ <span class="fw-bold text-danger">${document.getElementById("healthAnimalsMale").value}</span> | ሴት፦ <span class="fw-bold text-danger">${document.getElementById("healthAnimalsFemale").value}</span></p>
                            <p><strong>የተከሰቱ በሽታዎች፡</strong> <span class="text-danger fw-bold">${selectedDiseases}</span></p>
                            ${compileReviewGridHtml('healthTable', 'danger')}
                        ` : ''}
                        <div class="p-2 border rounded bg-light mt-3">
                            <strong>ተጨማሪ ማስታወሻ (Remarks)፦</strong> 
                            <p class="mb-0 text-muted italic small pt-1">${document.getElementById("remarksInput").value || "ምንም አስተያየት አልተሰጠም"}</p>
                        </div>
                    </div>
                </div>
            `;
            document.getElementById("previewContainer").innerHTML = html;
        }

        function compileReviewGridHtml(tableId, theme) {
            const table = document.getElementById(tableId);
            if (!table) return '';
            let rowsHtml = '';
            table.querySelectorAll('tbody tr').forEach(row => {
                let cell = row.querySelector('td[data-label]');
                let category = cell ? cell.getAttribute('data-label') : 'ምድብ';
                let male = row.querySelector('.val-male').value || 0;
                let female = row.querySelector('.val-female').value || 0;
                let total = row.querySelector('.row-total').innerText || 0;
                rowsHtml += `<tr><td class="bg-light fw-bold text-start ps-3">${category}</td><td>${male}</td><td>${female}</td><td class="fw-bold bg-light">${total}</td></tr>`;
            });

            return `
                <div class="table-responsive mt-2">
                    <table class="table table-sm table-bordered text-center m-0" style="font-size:0.85rem;">
                        <thead class="table-${theme} text-dark">
                            <tr><th>የተጎጂዎች ምድብ</th><th style="width:25%;">ወንድ</th><th style="width:25%;">ሴት</th><th style="width:20%;">ድምር</th></tr>
                        </thead>
                        <tbody>${rowsHtml}</tbody>
                        <tfoot class="table-light fw-bold text-${theme}">
                            <tr>
                                <td class="text-start ps-3">ጠቅላላ ድምር</td>
                                <td>${table.querySelector('.total-male').innerText}</td>
                                <td>${table.querySelector('.total-female').innerText}</td>
                                <td class="bg-${theme} text-white">${table.querySelector('.grand-total').innerText}</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>`;
        }

        document.addEventListener("DOMContentLoaded", function() {
            showStep(currentStep);
            updateMaxKebeleLimit();
            toggleCropPestFields();
            togglePastureFields();
            toggleWaterFields();
            toggleAnimalHealthFields();
            initMatrixCalculations();
        });
    </script>
}