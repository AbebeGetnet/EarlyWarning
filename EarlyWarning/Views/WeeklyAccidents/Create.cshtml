@using EarlyWarning.Enums
@model EarlyWarning.Models.WeeklyAccidents.WeeklyAccidents

@{
    ViewData["Title"] = "ሳምንታዊ አደጋ ሪፖርት";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var accidentTypes = ViewBag.AccidentTypes as IEnumerable<EarlyWarning.Models.WeeklyAccidents.AccidentType> ?? new List<EarlyWarning.Models.WeeklyAccidents.AccidentType>();
}

<style>
    /* Custom Styles */
    .page-header {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 25px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            transform: rotate(45deg);
        }

        .page-header h1 {
            margin: 0;
            font-size: 1.6rem;
            position: relative;
            z-index: 1;
        }

        .page-header p {
            margin: 8px 0 0;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

    .form-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .form-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.15);
        }

    .card-header-custom {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        padding: 12px 20px;
        font-weight: 600;
    }

        .card-header-custom i {
            margin-right: 8px;
        }

    .card-body-custom {
        padding: 25px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        font-size: 0.9rem;
    }

        .form-label i {
            margin-right: 5px;
            color: #f5576c;
        }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 10px 12px;
        width: 100%;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #f5576c;
            box-shadow: 0 0 0 0.2rem rgba(245, 87, 108, 0.25);
            outline: none;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 80px;
    }

    .checkbox-group {
        background: #fef3f2;
        padding: 15px 20px;
        border-radius: 10px;
        border: 1px solid #f5c6cb;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
    }

    .checkbox-label {
        font-weight: 600;
        margin: 0;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .checkbox-label input {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }

    .badge-status {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
    }

        .badge-status.inactive {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        }

    .accident-item-card {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 15px;
        border-left: 4px solid #f5576c;
        position: relative;
    }

    .btn-remove-accident {
        position: absolute;
        top: 10px;
        right: 15px;
        background: none;
        border: none;
        color: #dc3545;
        font-size: 1.2rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-remove-accident:hover {
            transform: scale(1.1);
        }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 25px;
    }

    .btn-custom {
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-submit {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
    }

    .btn-back {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white;
    }

    .btn-add {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
    }

    .btn-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        color: white;
    }

    .btn-add:hover {
        color: white;
    }

    .text-danger {
        color: #dc3545;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .info-hint {
        background: #fef3f2;
        border-left: 3px solid #f5576c;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        margin: -10px;
    }

    .col-md-6 {
        flex: 0 0 50%;
        padding: 10px;
    }

    .col-md-12 {
        flex: 0 0 100%;
        padding: 10px;
    }

    .summary-card {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        border-radius: 12px;
        padding: 20px;
        margin-top: 20px;
    }

    .summary-stats {
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        gap: 20px;
    }

    .summary-item {
        text-align: center;
        flex: 1;
        min-width: 100px;
    }

    .summary-number {
        font-size: 1.5rem;
        font-weight: bold;
    }

    .summary-label {
        font-size: 0.8rem;
        opacity: 0.9;
    }

    /* Modal Styles */
    .modal-header-custom {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
    }

        .modal-header-custom .btn-close {
            filter: brightness(0) invert(1);
        }

    @@media (max-width: 768px) {
        .form-container {
            max-width: 100%;
        }

        .card-body-custom {
            padding: 20px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-custom {
            width: 100%;
            text-align: center;
        }

        .col-md-6 {
            flex: 0 0 100%;
        }
    }
</style>

<div class="container-fluid">
    <div class="form-container">
        <!-- Page Header -->
        <div class="page-header">
            <h1>
                <i class="fas fa-plus-circle"></i> @ViewData["Title"]
            </h1>
            <p>እባክዎ በሳምንቱ የተከሰቱ አደጋዎች መረጃ ይሙሉ</p>
        </div>

        <!-- Debug Alert - Remove after fixing -->
        @if (!accidentTypes.Any())
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <strong>ማስታወሻ!</strong> ምንም የአደጋ ዓይነቶች አልተገኙም።
                እባክዎ በመጀመሪያ የአደጋ ዓይነቶችን ይመዝግቡ።
                <a asp-controller="AccidentType" asp-action="Create" class="btn btn-sm btn-primary ms-2">አዲስ የአደጋ ዓይነት ጨምር</a>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form asp-action="Create" method="post" id="weeklyAccidentForm">
            @Html.AntiForgeryToken()

            <!-- Basic Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-calendar-alt"></i> መሰረታዊ መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="StartDate" class="form-label">
                                    <i class="fas fa-calendar-week"></i> @Html.DisplayNameFor(m => m.StartDate)
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="EndDate" class="form-label">
                                    <i class="fas fa-calendar-check"></i> @Html.DisplayNameFor(m => m.EndDate)
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="EndDate" class="form-control" type="date" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        
                        <div class="col-md-6">
                            <div class="form-group">
                                <div class="checkbox-group">
                                    <label class="checkbox-label">
                                        <input asp-for="HasAccident" type="checkbox" id="hasAccidentCheckbox" />
                                        <span>
                                            <i class="fas fa-car-crash"></i> @Html.DisplayNameFor(m => m.HasAccident)
                                        </span>
                                    </label>
                                    <span id="statusBadge" class="badge-status">
                                        <i class="fas fa-check-circle"></i> አደጋ የለም
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Multiple Accidents Card -->
            <div class="form-card" id="accidentsCard" style="display: none;">
                <div class="card-header-custom">
                    <i class="fas fa-car-crash"></i> የአደጋ ዝርዝር
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-car-crash"></i> የአደጋ አይነት
                                </label>
                                <select id="accidentTypeSelect" class="form-control">
                                    <option value="">-- ይምረጡ --</option>
                                    @foreach (var accident in accidentTypes)
                                    {
                                        <option value="@accident.AccidentTypeId">@accident.AccidentName</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-tree"></i> የተጎዳ መሬት (ሄክታር)
                                </label>
                                <input type="number" id="damagedLandInput" class="form-control" step="0.01" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-percent"></i> የጉዳት መጠን (%)
                                </label>
                                <input type="number" id="damageRateInput" class="form-control" step="0.01" placeholder="0" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label class="form-label">&nbsp;</label>
                                <button type="button" class="btn btn-success form-control" id="btnAddAccident">
                                    <i class="fas fa-plus"></i> ጨምር
                                </button>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div id="accidentsContainer">
                        <h6 class="text-primary"><i class="fas fa-list"></i> የተመዘገቡ አደጋዎች</h6>
                        <div id="accidentsList" class="mt-3">
                            <div class="alert alert-info" id="noAccidentsMsg">ምንም አደጋ አልተመዘገበም</div>
                        </div>
                    </div>

                    <div class="info-hint mt-3">
                        <i class="fas fa-info-circle"></i> በርካታ አደጋዎችን አንድ ላይ መመዝገብ ይችላሉ
                    </div>
                </div>
            </div>

            <!-- Additional Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-file-alt"></i> ተጨማሪ መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label asp-for="Notes" class="form-label">
                                    <i class="fas fa-sticky-note"></i> @Html.DisplayNameFor(m => m.Notes)
                                </label>
                                <textarea asp-for="Notes" class="form-control" rows="3" placeholder="ተጨማሪ ማስታወሻ ካለ ያስገቡ..."></textarea>
                                <span asp-validation-for="Notes" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Report Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-user-edit"></i> የሪፖርት መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ReportDate" class="form-label">
                                    <i class="fas fa-calendar-day"></i> @Html.DisplayNameFor(m => m.ReportDate)
                                </label>
                                <input asp-for="ReportDate" class="form-control" type="datetime-local" />
                                <span asp-validation-for="ReportDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ReportedBy" class="form-label">
                                    <i class="fas fa-user"></i> @Html.DisplayNameFor(m => m.ReportedBy)
                                </label>
                                <input asp-for="ReportedBy" class="form-control" placeholder="ሙሉ ስም ያስገቡ" />
                                <span asp-validation-for="ReportedBy" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label asp-for="ApprovalStatus" class="form-label">
                                    <i class="fas fa-check-circle"></i> @Html.DisplayNameFor(m => m.ApprovalStatus)
                                </label>
                                <select asp-for="ApprovalStatus" class="form-control" asp-items="Html.GetEnumSelectList<ApprovalStatus>()">
                                    <option value="">-- ሁኔታ ይምረጡ --</option>
                                </select>
                                <span asp-validation-for="ApprovalStatus" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Summary Card -->
            <div class="summary-card" id="summaryCard" style="display: none;">
                <div class="summary-stats">
                    <div class="summary-item">
                        <div class="summary-number" id="totalAccidents">0</div>
                        <div class="summary-label"><i class="fas fa-car-crash"></i> ጠቅላላ አደጋዎች</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-number" id="totalAffected">0</div>
                        <div class="summary-label"><i class="fas fa-users"></i> ጠቅላላ ተጎጆች</div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <a asp-action="Index" class="btn-custom btn-back">
                    <i class="fas fa-arrow-left"></i> ወደ ዝርዝር ተመለስ
                </a>
                <button type="submit" class="btn-custom btn-submit" id="submitBtn">
                    <i class="fas fa-save"></i> መዝግብ
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Add Accident Details Modal -->
<div class="modal fade" id="accidentDetailModal" tabindex="-1" aria-labelledby="accidentDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title" id="accidentDetailModalLabel">
                    <i class="fas fa-car-crash"></i> የአደጋ ዝርዝር መረጃ
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="modalAccidentTypeId" />
                <input type="hidden" id="modalAccidentTypeName" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">የተጎዳ መሬት (ሄክታር)</label>
                            <input type="number" id="modalDamagedLand" class="form-control" step="0.01" value="0" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">የጉዳት መጠን (%)</label>
                            <input type="number" id="modalDamageRate" class="form-control" step="0.01" value="0" />
                        </div>
                    </div>
                </div>

                <hr />
                <h6 class="text-primary"><i class="fas fa-users"></i> በምድብ የተጎዱ ሰዎች</h6>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">የተጎዱ ቤተሰቦች (ወንድ)</label>
                            <input type="number" id="modalHouseholdsMale" class="form-control" min="0" value="0" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">የተጎዱ ቤተሰቦች (ሴት)</label>
                            <input type="number" id="modalHouseholdsFemale" class="form-control" min="0" value="0" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">የተጎዱ ህጻናት (ወንድ)</label>
                            <input type="number" id="modalChildrenMale" class="form-control" min="0" value="0" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">የተጎዱ ህጻናት (ሴት)</label>
                            <input type="number" id="modalChildrenFemale" class="form-control" min="0" value="0" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">የተጎዱ ወጣቶች (ወንድ)</label>
                            <input type="number" id="modalYouthMale" class="form-control" min="0" value="0" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">የተጎዱ ወጣቶች (ሴት)</label>
                            <input type="number" id="modalYouthFemale" class="form-control" min="0" value="0" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">የተጎዱ አረጋውያን (ወንድ)</label>
                            <input type="number" id="modalElderlyMale" class="form-control" min="0" value="0" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">የተጎዱ አረጋውያን (ሴት)</label>
                            <input type="number" id="modalElderlyFemale" class="form-control" min="0" value="0" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">የተጎዱ አካል ጉዳተኞች (ወንድ)</label>
                            <input type="number" id="modalDisabledMale" class="form-control" min="0" value="0" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">የተጎዱ አካል ጉዳተኞች (ሴት)</label>
                            <input type="number" id="modalDisabledFemale" class="form-control" min="0" value="0" />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">ማስታወሻ</label>
                    <textarea id="modalNotes" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ይዝጉ</button>
                <button type="button" class="btn btn-primary" id="saveAccidentDetailBtn">አስቀምጥ</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            var accidents = [];
            var pendingAccident = null;

            // Set default report date
            if (!$('#ReportDate').val()) {
                var now = new Date();
                var formattedDate = now.getFullYear() + '-' +
                                   String(now.getMonth() + 1).padStart(2, '0') + '-' +
                                   String(now.getDate()).padStart(2, '0') + 'T' +
                                   String(now.getHours()).padStart(2, '0') + ':' +
                                   String(now.getMinutes()).padStart(2, '0');
                $('#ReportDate').val(formattedDate);
            }

            // Toggle sections based on HasAccident
            $('#hasAccidentCheckbox').on('change', function() {
                var hasAccident = $(this).is(':checked');
                var badge = $('#statusBadge');

                if (hasAccident) {
                    $('#accidentsCard').slideDown(300);
                    $('#summaryCard').slideDown(300);
                    badge.removeClass('inactive');
                    badge.html('<i class="fas fa-exclamation-triangle"></i> አደጋ አለ');
                } else {
                    $('#accidentsCard').slideUp(300);
                    $('#summaryCard').slideUp(300);
                    badge.addClass('inactive');
                    badge.html('<i class="fas fa-check-circle"></i> አደጋ የለም');
                    accidents = [];
                    updateAccidentsDisplay();
                }
            });

            // Open modal to add accident
            $('#btnAddAccident').on('click', function() {
                var accidentTypeId = $('#accidentTypeSelect').val();
                var accidentTypeName = $('#accidentTypeSelect option:selected').text();

                if (!accidentTypeId) {
                    alert('እባክዎ የአደጋ አይነት ይምረጡ');
                    $('#accidentTypeSelect').focus();
                    return;
                }

                // Check for duplicate
                if (accidents.some(function(a) { return a.id === accidentTypeId; })) {
                    alert('ይህ የአደጋ አይነት ቀድሞ ተመዝግቧል');
                    return;
                }

                pendingAccident = {
                    id: accidentTypeId,
                    name: accidentTypeName,
                    damagedLand: 0,
                    damageRate: 0,
                    maleHouseholds: 0,
                    femaleHouseholds: 0,
                    maleChildren: 0,
                    femaleChildren: 0,
                    maleYouth: 0,
                    femaleYouth: 0,
                    maleElderly: 0,
                    femaleElderly: 0,
                    maleDisabled: 0,
                    femaleDisabled: 0,
                    notes: ''
                };

                $('#modalAccidentTypeId').val(accidentTypeId);
                $('#modalAccidentTypeName').val(accidentTypeName);
                $('#modalDamagedLand').val(0);
                $('#modalDamageRate').val(0);
                $('#modalHouseholdsMale').val(0);
                $('#modalHouseholdsFemale').val(0);
                $('#modalChildrenMale').val(0);
                $('#modalChildrenFemale').val(0);
                $('#modalYouthMale').val(0);
                $('#modalYouthFemale').val(0);
                $('#modalElderlyMale').val(0);
                $('#modalElderlyFemale').val(0);
                $('#modalDisabledMale').val(0);
                $('#modalDisabledFemale').val(0);
                $('#modalNotes').val('');

                $('#accidentDetailModal').modal('show');
            });

            // Save accident detail from modal
            $('#saveAccidentDetailBtn').on('click', function() {
                if (pendingAccident) {
                    pendingAccident.damagedLand = parseFloat($('#modalDamagedLand').val()) || 0;
                    pendingAccident.damageRate = parseFloat($('#modalDamageRate').val()) || 0;
                    pendingAccident.maleHouseholds = parseInt($('#modalHouseholdsMale').val()) || 0;
                    pendingAccident.femaleHouseholds = parseInt($('#modalHouseholdsFemale').val()) || 0;
                    pendingAccident.maleChildren = parseInt($('#modalChildrenMale').val()) || 0;
                    pendingAccident.femaleChildren = parseInt($('#modalChildrenFemale').val()) || 0;
                    pendingAccident.maleYouth = parseInt($('#modalYouthMale').val()) || 0;
                    pendingAccident.femaleYouth = parseInt($('#modalYouthFemale').val()) || 0;
                    pendingAccident.maleElderly = parseInt($('#modalElderlyMale').val()) || 0;
                    pendingAccident.femaleElderly = parseInt($('#modalElderlyFemale').val()) || 0;
                    pendingAccident.maleDisabled = parseInt($('#modalDisabledMale').val()) || 0;
                    pendingAccident.femaleDisabled = parseInt($('#modalDisabledFemale').val()) || 0;
                    pendingAccident.notes = $('#modalNotes').val();

                    accidents.push(pendingAccident);
                    pendingAccident = null;

                    // Reset inputs
                    $('#accidentTypeSelect').val('');
                    $('#damagedLandInput').val('');
                    $('#damageRateInput').val('');

                    updateAccidentsDisplay();
                }
                $('#accidentDetailModal').modal('hide');
            });

            // Update displayed list
            function updateAccidentsDisplay() {
                var container = $('#accidentsList');
                container.empty();

                if (accidents.length === 0) {
                    container.html('<div class="alert alert-info" id="noAccidentsMsg">ምንም አደጋ አልተመዘገበም</div>');
                    updateSummary();
                    return;
                }

                var html = '<div class="table-responsive"><table class="table table-bordered table-sm"><thead>';
                html += '<tr><th>የአደጋ አይነት</th><th>የተጎዳ መሬት (ሄክ)</th><th>የጉዳት መጠን (%)</th><th>ቤተሰብ</th><th>ህጻናት</th><th>ወጣቶች</th><th>አረጋውያን</th><th>አካል ጉዳተኛ</th><th>ድርጊት</th></tr></thead><tbody>';

                $.each(accidents, function(index, item) {
                    var totalHouseholds = (item.maleHouseholds || 0) + (item.femaleHouseholds || 0);
                    var totalChildren = (item.maleChildren || 0) + (item.femaleChildren || 0);
                    var totalYouth = (item.maleYouth || 0) + (item.femaleYouth || 0);
                    var totalElderly = (item.maleElderly || 0) + (item.femaleElderly || 0);
                    var totalDisabled = (item.maleDisabled || 0) + (item.femaleDisabled || 0);

                    html += '<tr>';
                    html += '<td><strong>' + item.name + '</strong></td>';
                    html += '<td class="text-end">' + (item.damagedLand || 0).toFixed(2) + ' ሄክ' + '</td>';
                    html += '<td class="text-end">' + (item.damageRate || 0).toFixed(2) + '%' + '</td>';
                    html += '<td>' + totalHouseholds + '</td>';
                    html += '<td>' + totalChildren + '</td>';
                    html += '<td>' + totalYouth + '</td>';
                    html += '<td>' + totalElderly + '</td>';
                    html += '<td>' + totalDisabled + '</td>';
                    html += '<td class="text-center">';
                    html += '<button type="button" class="btn btn-sm btn-danger remove-accident" data-index="' + index + '">';
                    html += '<i class="fas fa-trash"></i> ሰርዝ';
                    html += '</button></td>';
                    html += '</tr>';
                });

                html += '</tbody></table></div>';
                container.html(html);

                $('.remove-accident').on('click', function() {
                    var index = $(this).data('index');
                    accidents.splice(index, 1);
                    updateAccidentsDisplay();
                    updateSummary();
                });

                updateSummary();
            }

            // Update summary statistics
            function updateSummary() {
                if (accidents.length === 0) {
                    $('#summaryCard').hide();
                    return;
                }

                $('#summaryCard').show();
                $('#totalAccidents').text(accidents.length);

                var totalAffected = 0;
                $.each(accidents, function(index, item) {
                    totalAffected += (item.maleHouseholds || 0) + (item.femaleHouseholds || 0);
                    totalAffected += (item.maleChildren || 0) + (item.femaleChildren || 0);
                    totalAffected += (item.maleYouth || 0) + (item.femaleYouth || 0);
                    totalAffected += (item.maleElderly || 0) + (item.femaleElderly || 0);
                    totalAffected += (item.maleDisabled || 0) + (item.femaleDisabled || 0);
                });
                $('#totalAffected').text(totalAffected);
            }

            // Form validation before submit
            $('#weeklyAccidentForm').on('submit', function(e) {
                var hasAccident = $('#hasAccidentCheckbox').is(':checked');

                if (hasAccident && accidents.length === 0) {
                    e.preventDefault();
                    alert('እባክዎ ቢያንስ አንድ አደጋ ይመዝግቡ');
                    return false;
                }

                // Add hidden fields for each accident
                accidents.forEach(function(item, index) {
                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].AccidentTypeId',
                        value: item.id
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].DamagedLandInHectares',
                        value: item.damagedLand
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].DamageRateInPercent',
                        value: item.damageRate
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].AffectedHouseholdsMale',
                        value: item.maleHouseholds
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].AffectedHouseholdsFemale',
                        value: item.femaleHouseholds
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].AffectedChildrenMale',
                        value: item.maleChildren
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].AffectedChildrenFemale',
                        value: item.femaleChildren
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].AffectedYouthMale',
                        value: item.maleYouth
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].AffectedYouthFemale',
                        value: item.femaleYouth
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].AffectedElderlyMale',
                        value: item.maleElderly
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].AffectedElderlyFemale',
                        value: item.femaleElderly
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].AffectedDisabledMale',
                        value: item.maleDisabled
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].AffectedDisabledFemale',
                        value: item.femaleDisabled
                    }).appendTo('#weeklyAccidentForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'AccidentDetails[' + index + '].Notes',
                        value: item.notes || ''
                    }).appendTo('#weeklyAccidentForm');
                });

                return true;
            });

            // Initial state
            if ($('#hasAccidentCheckbox').is(':checked')) {
                $('#accidentsCard').show();
                $('#summaryCard').show();
            }
        });
    </script>
}