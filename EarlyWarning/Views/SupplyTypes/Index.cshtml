@model IEnumerable<EarlyWarning.Models.Aid.SupplyType>

@{
    ViewData["Title"] = "የአቅርቦት አይነቶች";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        padding: 25px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
    }

    .btn-create {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

        .btn-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            color: white;
        }

    .stat-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        overflow: hidden;
        transition: transform 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.15);
        }

    .stat-header {
        padding: 12px 15px;
        text-align: center;
        color: white;
    }

        .stat-header.total {
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        }

        .stat-header.active {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        }

        .stat-header.inactive {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        }

    .stat-body {
        padding: 15px;
        text-align: center;
    }

    .stat-number {
        font-size: 1.8rem;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .stat-label {
        color: #6c757d;
        font-size: 0.85rem;
    }

    .table-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .table {
        margin-bottom: 0;
    }

        .table thead th {
            background: #f8f9fa;
            color: #495057;
            border-bottom: 2px solid #dee2e6;
            padding: 12px;
            font-weight: 600;
            text-align: center;
        }

        .table tbody tr {
            transition: background-color 0.3s ease;
            cursor: pointer;
        }

            .table tbody tr:hover {
                background-color: #f8f9fa;
            }

        .table tbody td {
            padding: 10px;
            text-align: center;
            vertical-align: middle;
        }

    .badge-active {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        padding: 5px 12px;
        border-radius: 20px;
        color: white;
        font-size: 0.75rem;
        display: inline-block;
    }

    .badge-inactive {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        padding: 5px 12px;
        border-radius: 20px;
        color: white;
        font-size: 0.75rem;
        display: inline-block;
    }

    .action-buttons {
        display: flex;
        gap: 5px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.7rem;
        transition: all 0.3s ease;
    }

        .btn-action:hover {
            transform: translateY(-2px);
        }

    .search-box {
        margin-bottom: 20px;
    }

        .search-box input {
            border-radius: 25px;
            padding: 8px 15px;
            border: 1px solid #ddd;
            width: 250px;
            transition: all 0.3s ease;
        }

            .search-box input:focus {
                border-color: #11998e;
                outline: none;
            }

    .table-footer {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        padding: 12px 20px;
        border-radius: 0 0 12px 12px;
    }

    .footer-stats {
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        gap: 15px;
    }

    .footer-stat-item {
        text-align: center;
        flex: 1;
        min-width: 80px;
    }

    .footer-stat-number {
        font-size: 1.3rem;
        font-weight: bold;
    }

    .footer-stat-label {
        font-size: 0.7rem;
        opacity: 0.9;
    }

    @@media (max-width: 768px) {
        .stat-number {
            font-size: 1.3rem;
        }

        .action-buttons {
            flex-direction: column;
            align-items: center;
        }

        .search-box input {
            width: 100%;
        }

        .footer-stat-number {
            font-size: 1rem;
        }
    }
</style>

<div class="container-fluid">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center flex-wrap">
            <div>
                <h1><i class="fas fa-boxes"></i> @ViewData["Title"]</h1>
                <p>የአቅርቦት አይነቶችን ይመልከቱ፣ ያስተዳድሩ እና አዲስ አይነት ይጨምሩ</p>
            </div>
            <div>
                <a asp-action="Create" class="btn-create">
                    <i class="fas fa-plus-circle"></i> አዲስ አይነት
                </a>
            </div>
        </div>
    </div>

    @{
        var totalTypes = Model.Count();
        var activeTypes = Model.Count(x => x.IsActive);
        var inactiveTypes = totalTypes - activeTypes;
    }

    <div class="row">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-header total">
                    <i class="fas fa-list fa-2x"></i>
                </div>
                <div class="stat-body">
                    <div class="stat-number">@totalTypes</div>
                    <div class="stat-label">ጠቅላላ አይነቶች</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-header active">
                    <i class="fas fa-check-circle fa-2x"></i>
                </div>
                <div class="stat-body">
                    <div class="stat-number">@activeTypes</div>
                    <div class="stat-label">ንቁ አይነቶች</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-header inactive">
                    <i class="fas fa-ban fa-2x"></i>
                </div>
                <div class="stat-body">
                    <div class="stat-number">@inactiveTypes</div>
                    <div class="stat-label">እንቅስቃሴ ላይ ያልሆኑ</div>
                </div>
            </div>
        </div>
    </div>

    <div class="search-box">
        <div class="input-group">
            <input type="text" id="searchInput" class="form-control" placeholder="🔍 የአቅርቦት አይነት ፈልግ..." />
            <span class="input-group-text"><i class="fas fa-search"></i></span>
        </div>
    </div>

    <div class="table-container">
        <div class="table-responsive">
            <table class="table table-hover" id="supplyTypeTable">
                <thead>
                    <tr>
                        <th>የአቅርቦት አይነት</th>
                        <th>ሁኔታ</th>
                        <th>ድርጊቶች</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong><i class="fas fa-boxes text-success"></i> @item.SupplyTypeName</strong></td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge-active"><i class="fas fa-check-circle"></i> ንቁ ነው</span>
                                }
                                else
                                {
                                    <span class="badge-inactive"><i class="fas fa-times-circle"></i> እንቅስቃሴ ላይ አይደለም</span>
                                }
                            </td>
                            <td class="action-buttons">
                                <a asp-action="Edit" asp-route-id="@item.SupplyTypeId" class="btn btn-sm btn-warning btn-action">አርትዕ</a>
                                <a asp-action="Details" asp-route-id="@item.SupplyTypeId" class="btn btn-sm btn-info btn-action">ዝርዝር</a>
                                <a asp-action="Delete" asp-route-id="@item.SupplyTypeId" class="btn btn-sm btn-danger btn-action" onclick="return confirm('እርግጠኛ ነዎት?')">ሰርዝ</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-boxes fa-4x text-muted mb-3"></i>
                <h4 class="text-muted">ምንም የአቅርቦት አይነት አልተገኘም</h4>
                <p>እባክዎ አዲስ አይነት ለመጨመር ከላይ ያለውን ቁልፍ ይጫኑ</p>
            </div>
        }

        @if (Model.Any())
        {
            <div class="table-footer">
                <div class="footer-stats">
                    <div class="footer-stat-item">
                        <div class="footer-stat-number">@totalTypes</div>
                        <div class="footer-stat-label">ጠቅላላ አይነቶች</div>
                    </div>
                    <div class="footer-stat-item">
                        <div class="footer-stat-number">@activeTypes</div>
                        <div class="footer-stat-label"><i class="fas fa-check-circle"></i> ንቁ</div>
                    </div>
                    <div class="footer-stat-item">
                        <div class="footer-stat-number">@inactiveTypes</div>
                        <div class="footer-stat-label"><i class="fas fa-ban"></i> እንቅስቃሴ ላይ ያልሆኑ</div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $("#searchInput").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#supplyTypeTable tbody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });

            $('.table tbody tr').click(function(e) {
                if ($(e.target).closest('.action-buttons').length) return;
                var detailsUrl = $(this).find('.btn-info').attr('href');
                if (detailsUrl) window.location.href = detailsUrl;
            });
        });
    </script>
}