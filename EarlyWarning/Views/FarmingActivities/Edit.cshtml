@model FarmingActivity
@{
    ViewData["Title"] = "የእርሻ እንቅስቃሴ ሪፖርት";
}
<h2>@ViewData["Title"]</h2>
<h5>ወረዳ: @ViewBag.WoredaName</h5>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="WoredaId" />
    <!-- Date range row -->
    <div class="section-card mb-1 p-3 bg-light rounded">
        <h5 class="text-primary-custom"><i class="bi bi-calendar-week"></i> የሪፖርት ጊዜ/ሳምንት</h5>
        <div class="row">
            <div class="col-md-6">
                <label asp-for="StartDate" class="form-label fw-bold"></label>
                <input asp-for="StartDate" type="date" required class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="EndDate" class="form-label fw-bold"></label>
                <input asp-for="EndDate" type="date" required class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>
        </div>
        <div id="dateRangeError" class="validation-summary-error" style="display:none;"></div>
    </div>
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5>መህር (Meher) ተግባር</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="MeherFarmPlan" class="form-label">የግብርና ዕቅድ</label>
                        <input asp-for="MeherFarmPlan" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="MeherFarmPlan" class="text-danger"></span>
                        <div id="meher-validation-error" class="text-danger" style="display: none;">
                            የግብርና ዕቅድ ከተሰነዘረ + የዘነበ + ምርት + በእርጥበት የዘነበ ጋር መያዣ አልሆነም።
                        </div>
                        <small class="form-text text-muted">ተሰነዘረ + የዘነበ + ምርት + በእርጥበት = ዕቅድ</small>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="MeherPloughed" class="form-label">ተሰነዘረ</label>
                        <input asp-for="MeherPloughed" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="MeherPloughed" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="MeherSown" class="form-label">የዘነበ</label>
                        <input asp-for="MeherSown" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="MeherSown" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="MeherHarvestingHHarvesting" class="form-label">ምርት</label>
                        <input asp-for="MeherHarvestingHHarvesting" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="MeherHarvestingHHarvesting" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="MeherSownWithResidualMoisture" class="form-label">በእርጥበት የዘነበ</label>
                        <input asp-for="MeherSownWithResidualMoisture" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="MeherSownWithResidualMoisture" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-success text-white">
            <h5>ንዋይ (Autumn) ተግባር</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AutumnFarmPlan" class="form-label">የግብርና ዕቅድ</label>
                        <input asp-for="AutumnFarmPlan" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="AutumnFarmPlan" class="text-danger"></span>
                        <div id="autumn-validation-error" class="text-danger" style="display: none;">
                            የግብርና ዕቅድ ከተሰነዘረ + የዘነበ + ምርት + በእርጥበት የዘነበ ጋር መያዣ አልሆነም።
                        </div>
                        <small class="form-text text-muted">ተሰነዘረ + የዘነበ + ምርት + በእርጥበት = ዕቅድ</small>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AutumnPloughed" class="form-label">ተሰነዘረ</label>
                        <input asp-for="AutumnPloughed" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="AutumnPloughed" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AutumnSown" class="form-label">የዘነበ</label>
                        <input asp-for="AutumnSown" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="AutumnSown" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AutumnHarvestingHHarvesting" class="form-label">ምርት</label>
                        <input asp-for="AutumnHarvestingHHarvesting" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="AutumnHarvestingHHarvesting" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AutumnSownWithResidualMoisture" class="form-label">በእርጥበት የዘነበ</label>
                        <input asp-for="AutumnSownWithResidualMoisture" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="AutumnSownWithResidualMoisture" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-info text-white">
            <h5>ተጨማሪ ዝርዝር</h5>
        </div>
        <div class="card-body">
            <div class="form-group mb-3">
                <label asp-for="Remarks" class="form-label">ማስታወሻ</label>
                <textarea asp-for="Remarks" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Remarks" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">ያስቀምጡ</button>
        <a asp-action="Index" class="btn btn-secondary">ተመልሰው</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function() {
            // Function to validate Meher farm plan
            function validateMeherFarmPlan() {
                var farmPlan = parseFloat($('#MeherFarmPlan').val()) || 0;
                var ploughed = parseFloat($('#MeherPloughed').val()) || 0;
                var sown = parseFloat($('#MeherSown').val()) || 0;
                var harvesting = parseFloat($('#MeherHarvestingHHarvesting').val()) || 0;
                var residual = parseFloat($('#MeherSownWithResidualMoisture').val()) || 0;

                var total = ploughed + sown + harvesting + residual;

                if (Math.abs(farmPlan - total) > 0.01) { // Allow for small floating point differences
                    $('#MeherFarmPlan').addClass('is-invalid');
                    $('#meher-validation-error').show();
                    return false;
                } else {
                    $('#MeherFarmPlan').removeClass('is-invalid');
                    $('#meher-validation-error').hide();
                    return true;
                }
            }

            // Function to validate Autumn farm plan
            function validateAutumnFarmPlan() {
                var farmPlan = parseFloat($('#AutumnFarmPlan').val()) || 0;
                var ploughed = parseFloat($('#AutumnPloughed').val()) || 0;
                var sown = parseFloat($('#AutumnSown').val()) || 0;
                var harvesting = parseFloat($('#AutumnHarvestingHHarvesting').val()) || 0;
                var residual = parseFloat($('#AutumnSownWithResidualMoisture').val()) || 0;

                var total = ploughed + sown + harvesting + residual;

                if (Math.abs(farmPlan - total) > 0.01) { // Allow for small floating point differences
                    $('#AutumnFarmPlan').addClass('is-invalid');
                    $('#autumn-validation-error').show();
                    return false;
                } else {
                    $('#AutumnFarmPlan').removeClass('is-invalid');
                    $('#autumn-validation-error').hide();
                    return true;
                }
            }

            // Add event listeners to Meher fields
            $('#MeherFarmPlan, #MeherPloughed, #MeherSown, #MeherHarvestingHHarvesting, #MeherSownWithResidualMoisture').on('input', validateMeherFarmPlan);

            // Add event listeners to Autumn fields
            $('#AutumnFarmPlan, #AutumnPloughed, #AutumnSown, #AutumnHarvestingHHarvesting, #AutumnSownWithResidualMoisture').on('input', validateAutumnFarmPlan);

            // Validate on form submit
            $('form').on('submit', function(e) {
                var meherValid = validateMeherFarmPlan();
                var autumnValid = validateAutumnFarmPlan();

                if (!meherValid || !autumnValid) {
                    e.preventDefault();
                    alert('የግብርና ዕቅድ ከሌሎች አምዶች ጋር መያዣ አልሆነም። እባክዎ ያረጋግጡ።');
                    return false;
                }
            });
        });
    </script>
}
