@using EarlyWarning.Enums
@model RegistrationWithardViewModel
@{
    ViewData["Title"] = "የእርሻ እንቅስቃሴ ሪፖርት";
}
<h2>@ViewData["Title"]</h2>
<h5>ወረዳ: @ViewBag.WoredaName</h5>

<form asp-action="CreatePost" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5>መህር (Meher) ተግባር</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FarmingActivity.MeherFarmPlan" class="form-label">የግብርና ዕቅድ</label>
                        <input asp-for="FarmingActivity.MeherFarmPlan" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="FarmingActivity.MeherFarmPlan" class="text-danger"></span>
                        <div id="meher-validation-error" class="text-danger" style="display: none;">
                            የእርሻ እንቅስቃሴ ዕቅድ ከታረሰው + ከተዘራው + በአጨዳና ስብሰባ + በበቀሪ እርጥበት ከተዘራው ጋር እኩል አልሆነም።
                        </div>
                        <small class="form-text text-muted">የታረሰ + የተዘራ + በአጨዳና መሰብሰብላይ + በቀሪ እርጥበት የተዘራ = ዕቅድ</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FarmingActivity.MeherPloughed" class="form-label">የታረሰ</label>
                        <input asp-for="FarmingActivity.MeherPloughed" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="FarmingActivity.MeherPloughed" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FarmingActivity.MeherSown" class="form-label">የተዘራ</label>
                        <input asp-for="FarmingActivity.MeherSown" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="FarmingActivity.MeherSown" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FarmingActivity.MeherHarvestingHHarvesting" class="form-label">በአጨዳና ስብሰባ</label>
                        <input asp-for="FarmingActivity.MeherHarvestingHHarvesting" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="FarmingActivity.MeherHarvestingHHarvesting" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FarmingActivity.MeherSownWithResidualMoisture" class="form-label">በእርጥበት የዘነበ</label>
                        <input asp-for="FarmingActivity.MeherSownWithResidualMoisture" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="FarmingActivity.MeherSownWithResidualMoisture" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-success text-white">
            <h5>በልግ (Autumn) ተግባር</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FarmingActivity.AutumnFarmPlan" class="form-label">ዕቅድ</label>
                        <input asp-for="FarmingActivity.AutumnFarmPlan" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="FarmingActivity.AutumnFarmPlan" class="text-danger"></span>

                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FarmingActivity.AutumnPloughed" class="form-label">የታረሰ</label>
                        <input asp-for="FarmingActivity.AutumnPloughed" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="FarmingActivity.AutumnPloughed" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FarmingActivity.AutumnSown" class="form-label">የተዘራ</label>
                        <input asp-for="FarmingActivity.AutumnSown" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="FarmingActivity.AutumnSown" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FarmingActivity.AutumnHarvestingHHarvesting" class="form-label">አጨዳና ስብሰባ</label>
                        <input asp-for="FarmingActivity.AutumnHarvestingHHarvesting" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="FarmingActivity.AutumnHarvestingHHarvesting" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FarmingActivity.AutumnSownWithResidualMoisture" class="form-label">በቀሪ እርጥበት የተዘራ የዘነበ</label>
                        <input asp-for="FarmingActivity.AutumnSownWithResidualMoisture" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="FarmingActivity.AutumnSownWithResidualMoisture" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FarmingActivity.Remarks" class="form-label">ማስታወሻ</label>
                        <textarea asp-for="FarmingActivity.Remarks" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="FarmingActivity.Remarks" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FarmingActivity.CropGrowth" class="form-label">ማስታወሻ</label>
                        <select asp-for="FarmingActivity.CropGrowth" class="form-control" rows="3" asp-items="Html.GetEnumSelectList<CropGrowthType>()"></select>
                        <span asp-validation-for="FarmingActivity.CropGrowth" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <br />
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">ፍጠር</button>
                        <a asp-controller="RainfallReports" asp-action="Create" class="btn btn-secondary px-4">ተመልሰው</a>
                    </div>
                </div>
            </div>
        </div>
    </div>    
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function() {
            // Function to validate Meher farm plan
            function validateMeherFarmPlan() {
                var farmPlan = parseFloat($('#MeherFarmPlan').val()) || 0;
                var ploughed = parseFloat($('#MeherPloughed').val()) || 0;
                var sown = parseFloat($('#MeherSown').val()) || 0;
                var harvesting = parseFloat($('#MeherHarvestingHHarvesting').val()) || 0;
                var residual = parseFloat($('#MeherSownWithResidualMoisture').val()) || 0;

                var total = ploughed + sown + harvesting + residual;

                if (Math.abs(farmPlan - total) > 0.01) { // Allow for small floating point differences
                    $('#MeherFarmPlan').addClass('is-invalid');
                    $('#meher-validation-error').show();
                    return false;
                } else {
                    $('#MeherFarmPlan').removeClass('is-invalid');
                    $('#meher-validation-error').hide();
                    return true;
                }
            }

            // Function to validate Autumn farm plan
            function validateAutumnFarmPlan() {
                var farmPlan = parseFloat($('#AutumnFarmPlan').val()) || 0;
                var ploughed = parseFloat($('#AutumnPloughed').val()) || 0;
                var sown = parseFloat($('#AutumnSown').val()) || 0;
                var harvesting = parseFloat($('#AutumnHarvestingHHarvesting').val()) || 0;
                var residual = parseFloat($('#AutumnSownWithResidualMoisture').val()) || 0;

                var total = ploughed + sown + harvesting + residual;

                if (Math.abs(farmPlan - total) > 0.01) { // Allow for small floating point differences
                    $('#AutumnFarmPlan').addClass('is-invalid');
                    $('#autumn-validation-error').show();
                    return false;
                } else {
                    $('#AutumnFarmPlan').removeClass('is-invalid');
                    $('#autumn-validation-error').hide();
                    return true;
                }
            }

            // Add event listeners to Meher fields
            $('#MeherFarmPlan, #MeherPloughed, #MeherSown, #MeherHarvestingHHarvesting, #MeherSownWithResidualMoisture').on('input', validateMeherFarmPlan);

            // Add event listeners to Autumn fields
            $('#AutumnFarmPlan, #AutumnPloughed, #AutumnSown, #AutumnHarvestingHHarvesting, #AutumnSownWithResidualMoisture').on('input', validateAutumnFarmPlan);

            // Validate on form submit
            $('form').on('submit', function(e) {
                var meherValid = validateMeherFarmPlan();
                var autumnValid = validateAutumnFarmPlan();

                if (!meherValid || !autumnValid) {
                    e.preventDefault();
                    alert('የግብርና ዕቅድ ከሌሎች አምዶች ጋር መያዣ አልሆነም። እባክዎ ያረጋግጡ።');
                    return false;
                }
            });
        });
    </script>
}
