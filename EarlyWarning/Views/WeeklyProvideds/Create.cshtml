@using EarlyWarning.Enums
@using EarlyWarning.Extensions
@model EarlyWarning.Models.Aid.WeeklyProvided

@{
    ViewData["Title"] = "የሳምንታዊ እርዳታ አቅርቦት ሪፖርት";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var supplyTypes = ViewBag.SupplyTypes as IEnumerable<EarlyWarning.Models.Aid.SupplyType> ?? new List<EarlyWarning.Models.Aid.SupplyType>();
}

<style>
    /* Custom Styles */
    .page-header {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        padding: 25px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            transform: rotate(45deg);
        }

        .page-header h1 {
            margin: 0;
            font-size: 1.6rem;
            position: relative;
            z-index: 1;
        }

        .page-header p {
            margin: 8px 0 0;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

    .form-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .form-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.15);
        }

    .card-header-custom {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        padding: 12px 20px;
        font-weight: 600;
    }

        .card-header-custom i {
            margin-right: 8px;
        }

    .card-header-warning {
        background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
        color: #333;
    }

    .card-body-custom {
        padding: 25px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        font-size: 0.9rem;
    }

        .form-label i {
            margin-right: 5px;
            color: #11998e;
        }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 10px 12px;
        width: 100%;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #11998e;
            box-shadow: 0 0 0 0.2rem rgba(17, 153, 142, 0.25);
            outline: none;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 80px;
    }

    .detail-item-card {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 20px;
        border-left: 4px solid #11998e;
        position: relative;
        transition: all 0.3s ease;
    }

        .detail-item-card:hover {
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

    .btn-remove-detail {
        position: absolute;
        top: 15px;
        right: 15px;
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        border: none;
        color: white;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-remove-detail:hover {
            transform: scale(1.1);
        }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 25px;
    }

    .btn-custom {
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-submit {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
    }

    .btn-back {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white;
    }

    .btn-add {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
    }

    .btn-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        color: white;
    }

    .text-danger {
        color: #dc3545;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .info-hint {
        background: #e8f4f8;
        border-left: 3px solid #11998e;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        margin: -10px;
    }

    .col-md-6 {
        flex: 0 0 50%;
        padding: 10px;
    }

    .col-md-12 {
        flex: 0 0 100%;
        padding: 10px;
    }

    .col-md-3 {
        flex: 0 0 25%;
        padding: 10px;
    }

    .summary-card {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        border-radius: 12px;
        padding: 20px;
        margin-top: 20px;
    }

    .summary-stats {
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        gap: 20px;
    }

    .summary-item {
        text-align: center;
        flex: 1;
        min-width: 100px;
    }

    .summary-number {
        font-size: 1.5rem;
        font-weight: bold;
    }

    .summary-label {
        font-size: 0.8rem;
        opacity: 0.9;
    }


    @@media (max-width: 768px) {
        .form-container {
            max-width: 100%;
        }

        .card-body-custom {
            padding: 20px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-custom {
            width: 100%;
            text-align: center;
        }

        .col-md-6, .col-md-3 {
            flex: 0 0 100%;
        }

        .summary-number {
            font-size: 1.2rem;
        }

        .radio-group {
            flex-direction: column;
        }
    }
</style>

<div class="container-fluid">
    <div class="form-container">
        <!-- Page Header -->
        <div class="page-header">
            <h1>
                <i class="fas fa-plus-circle"></i> @ViewData["Title"]
            </h1>
            <p>እባክዎ በሳምንቱ የተቀረበውን እና የተሰራጨውን የእርዳታ መረጃ ይሙሉ</p>
        </div>

        <form asp-action="Create" method="post" id="weeklyProvidedForm">
            @Html.AntiForgeryToken()

            <!-- Basic Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-calendar-alt"></i> መሰረታዊ መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="StartDate" class="form-label">
                                    <i class="fas fa-calendar-week"></i> @Html.DisplayNameFor(m => m.StartDate)
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="EndDate" class="form-label">
                                    <i class="fas fa-calendar-check"></i> @Html.DisplayNameFor(m => m.EndDate)
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="EndDate" class="form-control" type="date" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="WoredaId" class="form-label">
                                    <i class="fas fa-map-marker-alt"></i> @Html.DisplayNameFor(m => m.WoredaId)
                                    <span class="text-danger">*</span>
                                </label>
                                <select asp-for="WoredaId" class="form-control" asp-items="ViewBag.WoredaId">
                                    <option value="">-- ወረዳ ይምረጡ --</option>
                                </select>
                                <span asp-validation-for="WoredaId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="IfProblem" class="form-label">
                                    <i class="fas fa-exclamation-triangle"></i> @Html.DisplayNameFor(m => m.IfProblem)
                                </label>
                                <select asp-for="IfProblem" class="form-control">
                                    <option value="">-- እባክዎ ይምረጡ --</option>
                                    @foreach (Problem problem in Enum.GetValues(typeof(Problem)))
                                    {
                                        <option value="@((int)problem)">@problem.GetDisplayName()</option>
                                    }
                                </select>
                                <span asp-validation-for="IfProblem" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Multiple Details Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-list-alt"></i> የእርዳታ ዝርዝሮች
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-boxes"></i> የእርዳታ አይነት
                                </label>
                                <select id="supplyTypeSelect" class="form-control">
                                    <option value="">-- ይምረጡ --</option>
                                    @foreach (var type in supplyTypes)
                                    {
                                        <option value="@type.SupplyTypeId">@type.SupplyTypeName</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-ruler"></i> መለኪያ አሃድ
                                </label>
                                <select id="measurementSelect" class="form-control">
                                    <option value="">-- ይምረጡ --</option>
                                    @foreach (Measurement m in Enum.GetValues(typeof(Measurement)))
                                    {
                                        <option value="@((int)m)">@m.GetDisplayName()</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-truck"></i> የቀረበ መጠን
                                </label>
                                <input type="number" id="providedQuantityInput" class="form-control" step="0.01" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-hand-holding-heart"></i> የተሰራጨ መጠን
                                </label>
                                <input type="number" id="distributedQuantityInput" class="form-control" step="0.01" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-user-friends"></i> ለጋሽ
                                </label>
                                <input type="text" id="donorInput" class="form-control" placeholder="ለጋሽ ስም" />
                            </div>
                        </div>
                        <div class="col-md-1">
                            <div class="form-group">
                                <label class="form-label">&nbsp;</label>
                                <button type="button" class="btn btn-success form-control" id="btnAddDetail">
                                    <i class="fas fa-plus"></i> ጨምር
                                </button>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div id="detailsContainer">
                        <h6 class="text-primary"><i class="fas fa-list"></i> የተመዘገቡ ዝርዝሮች</h6>
                        <div id="detailsList" class="mt-3">
                            <div class="alert alert-info" id="noDetailsMsg">ምንም ዝርዝር አልተመዘገበም</div>
                        </div>
                    </div>

                    <div class="info-hint mt-3">
                        <i class="fas fa-info-circle"></i> በርካታ የእርዳታ ዝርዝሮችን አንድ ላይ መመዝገብ ይችላሉ
                    </div>
                </div>
            </div>

            <!-- Notes Card -->
            <div class="form-card">
                <div class="card-header-custom card-header-warning">
                    <i class="fas fa-file-alt"></i> ተጨማሪ ማስታወሻ
                </div>
                <div class="card-body-custom">
                    <div class="form-group">
                        <label asp-for="Notes" class="form-label">
                            <i class="fas fa-sticky-note"></i> @Html.DisplayNameFor(m => m.Notes)
                        </label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="ተጨማሪ ማስታወሻ ካለ ያስገቡ..."></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Report Information Card -->
            <div class="form-card">
                <div class="card-header-custom">
                    <i class="fas fa-user-edit"></i> የሪፖርት መረጃ
                </div>
                <div class="card-body-custom">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ReportDate" class="form-label">
                                    <i class="fas fa-calendar-day"></i> @Html.DisplayNameFor(m => m.ReportDate)
                                </label>
                                <input asp-for="ReportDate" class="form-control" type="datetime-local" />
                                <span asp-validation-for="ReportDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ReportedBy" class="form-label">
                                    <i class="fas fa-user"></i> @Html.DisplayNameFor(m => m.ReportedBy)
                                </label>
                                <input asp-for="ReportedBy" class="form-control" placeholder="ሙሉ ስም ያስገቡ" />
                                <span asp-validation-for="ReportedBy" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="ReportStatus" class="form-label">
                            <i class="fas fa-check-circle"></i> @Html.DisplayNameFor(m => m.ReportStatus)
                        </label>
                        <select asp-for="ReportStatus" class="form-control" asp-items="Html.GetEnumSelectList<ApprovalStatus>()">
                            <option value="">-- ሁኔታ ይምረጡ --</option>
                        </select>
                        <span asp-validation-for="ReportStatus" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Summary Card -->
            <div id="summaryCard" class="summary-card" style="display: none;">
                <div class="summary-stats">
                    <div class="summary-item">
                        <div class="summary-number" id="totalItems">0</div>
                        <div class="summary-label"><i class="fas fa-list"></i> ጠቅላላ ዝርዝሮች</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-number" id="totalProvided">0</div>
                        <div class="summary-label"><i class="fas fa-truck"></i> ጠቅላላ የቀረበ</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-number" id="totalDistributed">0</div>
                        <div class="summary-label"><i class="fas fa-hand-holding-heart"></i> ጠቅላላ የተሰራጨ</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-number" id="overallPercentage">0%</div>
                        <div class="summary-label"><i class="fas fa-percent"></i> አጠቃላይ ስርጭት</div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <a asp-action="Index" class="btn-custom btn-back">
                    <i class="fas fa-arrow-left"></i> ወደ ዝርዝር ተመለስ
                </a>
                <button type="submit" class="btn-custom btn-submit">
                    <i class="fas fa-save"></i> መዝግብ
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            var details = [];

            // Set default report date
            if (!$('#ReportDate').val()) {
                var now = new Date();
                var formattedDate = now.getFullYear() + '-' +
                    String(now.getMonth() + 1).padStart(2, '0') + '-' +
                    String(now.getDate()).padStart(2, '0') + 'T' +
                    String(now.getHours()).padStart(2, '0') + ':' +
                    String(now.getMinutes()).padStart(2, '0');
                $('#ReportDate').val(formattedDate);
            }

            

            // Update summary
            function updateSummary() {
                if (details.length === 0) {
                    $('#summaryCard').hide();
                    return;
                }

                $('#summaryCard').show();
                $('#totalItems').text(details.length);

                var totalProvided = 0;
                var totalDistributed = 0;

                details.forEach(function(item) {
                    totalProvided += item.providedQuantity;
                    totalDistributed += item.distributedQuantity;
                });

                var percentage = totalProvided > 0 ? (totalDistributed / totalProvided) * 100 : 0;

                $('#totalProvided').text(totalProvided.toFixed(2));
                $('#totalDistributed').text(totalDistributed.toFixed(2));
                $('#overallPercentage').text(percentage.toFixed(1) + '%');
            }

            // Update details display
            function updateDetailsDisplay() {
                var container = $('#detailsList');
                container.empty();

                if (details.length === 0) {
                    container.html('<div class="alert alert-info" id="noDetailsMsg">ምንም ዝርዝር አልተመዘገበም</div>');
                    updateSummary();
                    return;
                }

                var html = '<div class="table-responsive"><table class="table table-bordered"><thead>';
                html += '<tr><th>የእርዳታ አይነት</th><th>መለኪያ</th><th>የቀረበ</th><th>የተሰራጨ</th><th>መቶኛ</th><th>ለጋሽ</th><th>ድርጊት</th></tr></thead><tbody>';

                $.each(details, function(index, item) {
                    var percentage = item.providedQuantity > 0 ? (item.distributedQuantity / item.providedQuantity) * 100 : 0;
                    html += '<tr>';
                    html += '<td><strong>' + escapeHtml(item.supplyTypeName) + '</strong></td>';
                    html += '<td>' + escapeHtml(item.measurementName) + '</td>';
                    html += '<td class="text-end">' + item.providedQuantity.toFixed(2) + '</td>';
                    html += '<td class="text-end">' + item.distributedQuantity.toFixed(2) + '</td>';
                    // FIXED: Added missing closing td tag
                    html += '<td class="text-center"><span class="badge bg-info">' + percentage.toFixed(1) + '%</span></td>';
                    html += '<td>' + escapeHtml(item.donor || '-') + '</td>';
                    html += '<td class="text-center">';
                    html += '<button type="button" class="btn btn-sm btn-danger remove-detail" data-index="' + index + '">';
                    html += '<i class="fas fa-trash"></i> ሰርዝ';
                    html += '</button></td>';
                    html += '</tr>';
                });

                html += '</tbody></table></div>';
                container.html(html);

                $('.remove-detail').on('click', function() {
                    var index = $(this).data('index');
                    details.splice(index, 1);
                    updateDetailsDisplay();
                    updateSummary();
                });

                updateSummary();
            }

            // Helper function to escape HTML
            function escapeHtml(text) {
                if (!text) return '';
                var map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#39;'
                };
                return text.replace(/[&<>"']/g, function(m) { return map[m]; });
            }

            // Add detail
            $('#btnAddDetail').on('click', function() {
                var supplyTypeId = $('#supplyTypeSelect').val();
                var supplyTypeName = $('#supplyTypeSelect option:selected').text();
                var measurement = $('#measurementSelect').val();
                var measurementName = $('#measurementSelect option:selected').text();
                var providedQuantity = parseFloat($('#providedQuantityInput').val());
                var distributedQuantity = parseFloat($('#distributedQuantityInput').val());
                var donor = $('#donorInput').val();

                if (!supplyTypeId) {
                    alert('እባክዎ የእርዳታ አይነት ይምረጡ');
                    $('#supplyTypeSelect').focus();
                    return;
                }

                if (!measurement) {
                    alert('እባክዎ የመለኪያ አሃድ ይምረጡ');
                    $('#measurementSelect').focus();
                    return;
                }

                if (isNaN(providedQuantity) || providedQuantity < 0) {
                    alert('እባክዎ ትክክለኛ የቀረበ መጠን ያስገቡ');
                    $('#providedQuantityInput').focus();
                    return;
                }

                if (isNaN(distributedQuantity) || distributedQuantity < 0) {
                    alert('እባክዎ ትክክለኛ የተሰራጨ መጠን ያስገቡ');
                    $('#distributedQuantityInput').focus();
                    return;
                }

                if (distributedQuantity > providedQuantity) {
                    alert('የተሰራጨ መጠን ከቀረበ መጠን መብለጥ አይችልም');
                    return;
                }

                details.push({
                    supplyTypeId: supplyTypeId,
                    supplyTypeName: supplyTypeName,
                    measurement: parseInt(measurement),
                    measurementName: measurementName,
                    providedQuantity: providedQuantity,
                    distributedQuantity: distributedQuantity,
                    donor: donor
                });

                // Reset inputs
                $('#supplyTypeSelect').val('');
                $('#measurementSelect').val('');
                $('#providedQuantityInput').val('');
                $('#distributedQuantityInput').val('');
                $('#donorInput').val('');

                updateDetailsDisplay();
            });

            // Enter key support
            $('#providedQuantityInput, #distributedQuantityInput').on('keypress', function(e) {
                if (e.which === 13) {
                    e.preventDefault();
                    $('#btnAddDetail').click();
                }
            });

            // Form validation before submit
            $('#weeklyProvidedForm').on('submit', function(e) {
                var woredaId = $('#WoredaId').val();
                var startDate = $('#StartDate').val();
                var endDate = $('#EndDate').val();

                if (!woredaId) {
                    e.preventDefault();
                    alert('እባክዎ ወረዳ ይምረጡ');
                    $('#WoredaId').focus();
                    return false;
                }

                if (!startDate) {
                    e.preventDefault();
                    alert('እባክዎ የሪፖርት መነሻ ቀን ይምረጡ');
                    $('#StartDate').focus();
                    return false;
                }

                if (!endDate) {
                    e.preventDefault();
                    alert('እባክዎ የሪፖርት መጨረሻ ቀን ይምረጡ');
                    $('#EndDate').focus();
                    return false;
                }

                if (details.length === 0) {
                    e.preventDefault();
                    alert('እባክዎ ቢያንስ አንድ የእርዳታ ዝርዝር ያስገቡ');
                    return false;
                }

                // Remove any existing detail hidden fields first
                $('input[name^="Details["]').remove();

                // Add hidden fields for details
                details.forEach(function(item, index) {
                    $('<input>').attr({
                        type: 'hidden',
                        name: 'Details[' + index + '].SupplyTypeId',
                        value: item.supplyTypeId
                    }).appendTo('#weeklyProvidedForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'Details[' + index + '].Measurement',
                        value: item.measurement
                    }).appendTo('#weeklyProvidedForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'Details[' + index + '].ProvidedQuantity',
                        value: item.providedQuantity
                    }).appendTo('#weeklyProvidedForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'Details[' + index + '].DistributedQuantity',
                        value: item.distributedQuantity
                    }).appendTo('#weeklyProvidedForm');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'Details[' + index + '].Donor',
                        value: item.donor || ''
                    }).appendTo('#weeklyProvidedForm');
                });

                return true;
            });
        });
    </script>
}