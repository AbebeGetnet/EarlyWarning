@model RegistrationWithardViewModel
@{
    ViewData["Title"] = "የሰብል ተባይና በሽታ ክስተት";
}

<style>
    h5 {
        text-align: left;
    }
</style>

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h3>@ViewData["Title"]</h3>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" id="cropReportForm">
                @Html.AntiForgeryToken()

                <hr />
                <div class="row">
                    <div class="col-md-4">
                        <label>ወረዳ</label>
                        <input class="form-control" value="@ViewBag.WoredaName" readonly disabled />
                    </div>
                </div>
                <!-- Main checkbox -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="HasPestCheck" asp-for="CropPestAndDeseaseReport.HasPestAndDeseasOccured" />
                                <label class="form-check-label" asp-for="CropPestAndDeseaseReport.HasPestAndDeseasOccured"></label>
                            </div>
                        </div>
                    </div>
                    <br />
                    <!-- Detailed section (shown only when HasPestCheck is checked) -->
                    <div id="pestDetails" style="display:none;">
                        <div id="existingDiseasesList" class="mb-3">
                            <label class="form-label fw-bold">ተባዮች/በሽታዎች ይምረጡ</label>
                            <div class="disease-checkbox-list">
                                @if (ViewBag.CropPestAndDeseases != null && ((IEnumerable<CropPestAndDesease>)ViewBag.CropPestAndDeseases).Any())
                                {
                                    foreach (var disease in ViewBag.CropPestAndDeseases)
                                    {
                                        <div class="form-check form-check-inline">
                                            <input type="checkbox" name="SelectedDiseaseIds" value="@disease.Id" class="form-check-input" id="disease_@disease.Id" />
                                            <label class="form-check-label" for="disease_@disease.Id">
                                                @disease.Name (@disease.Name)
                                            </label>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <p class="text-muted">ምንም የተመዘገቡ ተባይ/በሽታዎች የሉም።</p>
                                }
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-mb-6">
                                <label asp-for="CropPestAndDeseaseReport.AffectedLandInHectar"></label>
                                <input asp-for="CropPestAndDeseaseReport.AffectedLandInHectar" class="form-control" />
                            </div>
                            <div class="col-mb-6">
                                <label asp-for="CropPestAndDeseaseReport.TypeOfCropAffected"></label>
                                <input asp-for="CropPestAndDeseaseReport.TypeOfCropAffected" class="form-control" />
                            </div>
                        </div>
                        <br />
                        <!-- Household demographics -->
                        <div class="row">
                            <div class="col-md-3"><br /><h5>የተጎዳ አባወራና እማወራ</h5></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.MaleHouseHold"></label><input asp-for="CropPestAndDeseaseReport.MaleHouseHold" class="form-control demographic-input" /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.FemaleHouseHold"></label><input asp-for="CropPestAndDeseaseReport.FemaleHouseHold" class="form-control demographic-input" /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.TotalHouseHold"></label><input asp-for="CropPestAndDeseaseReport.TotalHouseHold" class="form-control" disabled /></div>
                        </div>
                        <div class="row">
                            <div class="col-md-3"><br /><h5>ቤተሰብ </h5></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.MaleFamily"></label><input asp-for="CropPestAndDeseaseReport.MaleFamily" class="form-control demographic-input" /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.FemaleFamily"></label><input asp-for="CropPestAndDeseaseReport.FemaleFamily" class="form-control demographic-input" /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.TotalFamily"></label><input asp-for="CropPestAndDeseaseReport.TotalFamily" class="form-control" disabled /></div>
                        </div>
                        <div class="row">
                        <div class="col-md-3"><br /><h5>ህጻናት ከ5 ዓመት በታች </h5></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.ChildhMale"></label><input asp-for="CropPestAndDeseaseReport.ChildhMale" class="form-control demographic-input" /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.ChildFemale"></label><input asp-for="CropPestAndDeseaseReport.ChildFemale" class="form-control demographic-input" /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.TotalChild"></label><input asp-for="CropPestAndDeseaseReport.TotalChild" class="form-control" disabled /></div>
                        </div>
                        <br />
                        <div class="row">
                            <div class="col-md-3"><h5>ወጣት</h5></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.YouthMale"></label><input asp-for="CropPestAndDeseaseReport.YouthMale" class="form-control demographic-input" /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.YouthFemale"></label><input asp-for="CropPestAndDeseaseReport.YouthFemale" class="form-control demographic-input" /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.TotalYouth"></label><input asp-for="CropPestAndDeseaseReport.TotalYouth" class="form-control" disabled /></div>
                        </div>
                        <br />
                        <div class="row">
                            <div class="col-md-3"><h5>አረጋዊያን</h5></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.ElderlyMale"></label><input asp-for="CropPestAndDeseaseReport.ElderlyMale" class="form-control demographic-input" /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.ElderlyFemale"></label><input asp-for="CropPestAndDeseaseReport.ElderlyFemale" class="form-control demographic-input" /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.TotalElderly"></label><input asp-for="CropPestAndDeseaseReport.TotalElderly" class="form-control" disabled /></div>
                        </div>
                        <br />
                        <div class="row">
                            <div class="col-md-3"><h5>አካል ጉዳተኛ</h5></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.DisabledMale"></label><input asp-for="CropPestAndDeseaseReport.DisabledMale" class="form-control demographic-input" /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.DisabledFemale"></label><input asp-for="CropPestAndDeseaseReport.DisabledFemale" class="form-control demographic-input" /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.TotalDisabled"></label><input asp-for="CropPestAndDeseaseReport.TotalDisabled" class="form-control" disabled /></div>
                        </div>
                        <br />
                        <div class="row">
                            <div class="col-md-3"> <br /><h5>በሰብል ተባይ የተጎዳ ጠቅላል ማህበረሰብ </h5></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.TotalMale"></label><input asp-for="CropPestAndDeseaseReport.TotalMale" class="form-control" disabled /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.TotalFemale"></label><input asp-for="CropPestAndDeseaseReport.TotalFemale" class="form-control" disabled /></div>
                            <div class="col-md-3"><label asp-for="CropPestAndDeseaseReport.TotalAffected"></label><input asp-for="CropPestAndDeseaseReport.TotalAffected" class="form-control" disabled /></div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="mt-3">
                        <label asp-for="CropPestAndDeseaseReport.Remarks"></label>
                        <textarea asp-for="CropPestAndDeseaseReport.Remarks" class="form-control"></textarea>
                    </div>
                </div>
                <div class="card-body">
                    <button type="submit" class="btn btn-primary mt-3">አስቀምጥ</button>
                    <a asp-controller="FarmingActivities" asp-action="Create" class="btn btn-secondary mt-3">ተመልሰው</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Toggle disease details
        $('#HasPestCheck').change(function() {
            if ($(this).is(':checked')) {
                $('#pestDetails').slideDown();
            } else {
                $('#pestDetails').slideUp();
                // Uncheck all disease checkboxes when hiding
                $('input[name="SelectedDiseaseIds"]').not('[type="hidden"]').prop('checked', false);
            }
        });

        // Initial state
        if ($('#HasPestCheck').is(':checked')) {
            $('#pestDetails').show();
        } else {
            $('#pestDetails').hide();
        }

        // Ensure that if the main checkbox is not checked, we remove any disease IDs from the submission.
        $('form').on('submit', function(e) {
            if (!$('#HasPestCheck').is(':checked')) {
                $('input[name="SelectedDiseaseIds"]').not('[type="hidden"]').remove();
            }
        });

        // ------------------------------------------------------------------
        // LIVE CALCULATIONS: Update totals while typing on demographic fields
        // ------------------------------------------------------------------
        function updateAllTotals() {
            // Helper to get integer value from input safely
            function getIntValue(selector) {
                var val = $(selector).val();
                if (!val || isNaN(val)) return 0;
                return parseInt(val, 10) || 0;
            }

            // ---- Gather all demographic values ----
            var maleHouseHold   = getIntValue('#CropPestAndDeseaseReport_MaleHouseHold');
            var femaleHouseHold = getIntValue('#CropPestAndDeseaseReport_FemaleHouseHold');
            var maleFamily      = getIntValue('#CropPestAndDeseaseReport_MaleFamily');
            var femaleFamily    = getIntValue('#CropPestAndDeseaseReport_FemaleFamily');
            var childMale       = getIntValue('#CropPestAndDeseaseReport_ChildhMale');
            var childFemale     = getIntValue('#CropPestAndDeseaseReport_ChildFemale');
            var youthMale       = getIntValue('#CropPestAndDeseaseReport_YouthMale');
            var youthFemale     = getIntValue('#CropPestAndDeseaseReport_YouthFemale');
            var elderlyMale     = getIntValue('#CropPestAndDeseaseReport_ElderlyMale');
            var elderlyFemale   = getIntValue('#CropPestAndDeseaseReport_ElderlyFemale');
            var disabledMale    = getIntValue('#CropPestAndDeseaseReport_DisabledMale');
            var disabledFemale  = getIntValue('#CropPestAndDeseaseReport_DisabledFemale');

            // ---- Compute subgroup totals ----
            var totalHouseHold = maleHouseHold + femaleHouseHold;
            var totalFamily    = maleFamily + femaleFamily;
            var totalChild     = childMale + childFemale;
            var totalYouth     = youthMale + youthFemale;
            var totalElderly   = elderlyMale + elderlyFemale;
            var totalDisabled  = disabledMale + disabledFemale;

            // ---- Compute overall gender totals ----
            var totalMale   = maleHouseHold + maleFamily + childMale + youthMale + elderlyMale + disabledMale;
            var totalFemale = femaleHouseHold + femaleFamily + childFemale + youthFemale + elderlyFemale + disabledFemale;
            var totalAffected = totalMale + totalFemale;

            // ---- Update the disabled total fields ----
            $('#CropPestAndDeseaseReport_TotalHouseHold').val(totalHouseHold);
            $('#CropPestAndDeseaseReport_TotalFamily').val(totalFamily);
            $('#CropPestAndDeseaseReport_TotalChild').val(totalChild);
            $('#CropPestAndDeseaseReport_TotalYouth').val(totalYouth);
            $('#CropPestAndDeseaseReport_TotalElderly').val(totalElderly);
            $('#CropPestAndDeseaseReport_TotalDisabled').val(totalDisabled);
            $('#CropPestAndDeseaseReport_TotalMale').val(totalMale);
            $('#CropPestAndDeseaseReport_TotalFemale').val(totalFemale);
            $('#CropPestAndDeseaseReport_TotalAffected').val(totalAffected);
        }

        // Attach event listeners to all demographic input fields (they have class 'demographic-input')
        $(document).ready(function() {
            // Listen to input events on all demographic fields
            $('.demographic-input').on('input', function() {
                updateAllTotals();
            });

            // Initial calculation in case server pre-populates any values
            updateAllTotals();
        });
    </script>
}