@model IEnumerable<PasswordResetKey>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="card card-outline">
    <div style="background:#4775d1;">
        <h4 style="color: white;padding-left:10px;"> Students Slip </h4>
    </div>
    <div class="card-body">
        <table class="table table-striped table-sm table-bordered" id="example1">
            <thead>
                <tr>
                    <th>Password Reset Key</th>
                    <th>
                        <a asp-action="AddPasswordResetKey" class="btn btn-success">Add new user</a>
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.PasswordResetValue</td>
                        <td></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>