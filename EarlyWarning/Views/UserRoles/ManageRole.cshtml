@using EarlyWarning.ViewModels.UserManagementViewModel
@model List<ManageUserRolesViewModel>
@{
    ViewData["Title"] = "Manage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="card ">
    <div style="background:#4775d1;">
        <h4 style="color: white;padding-left:10px;"> Manage roles </h4>
    </div>
    <div class="card-body">
        <form method="post">
            <div class="card">
                <div class="card-header">
                    <h4>Manage User Roles</h4>
                    Add/Remove Roles for User / @ViewBag.UserName.
                </div>
                <div class="card-body">
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <div class="form-check m-1">
                            <input type="hidden" asp-for="@Model[i].RoleId" />
                            <input type="hidden" asp-for="@Model[i].RoleName" />
                            <input asp-for="@Model[i].Selected" class="form-check-input" />
                            <label class="form-check-label" asp-for="@Model[i].Selected">
                                @Model[i].RoleName
                            </label>
                        </div>
                    }
                    <div asp-validation-summary="All" class="text-danger"></div>
                </div>
                <div class="card-footer">
                    <input type="submit" value="Update" class="btn btn-primary"
                           style="width:auto" />
                    <a asp-action="UserRoleIndex" asp-route-id="@ViewBag.userId"
                       class="btn btn-primary" style="width:auto">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>