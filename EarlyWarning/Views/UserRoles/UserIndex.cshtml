@using EarlyWarning.Models
@model List<EarlyWarning.Models.UserRolesViewModel>
@*@model IEnumerable< ApplicationUser *@>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="card card-primary card-outline">
    <div style="background:#4775d1;">
        <h4 style="color: white;padding-left:10px;"> User roles </h4>
    </div>
    <div class="card-body">
        <table class="table table-striped table-sm table-bordered" id="dataTable">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Roles</th>
            <th align="center">Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FirstName</td>
                <td>@user.LastName</td>
                <td>@user.Email</td>
                <td>@string.Join(" , ", user.Roles.ToList())</td>
                <td>
                    <div class="text-center">
                        <form asp-action="Delete" asp-route-userId="@user.UserId">
                            <a asp-action="Edit" asp-route-userid="@user.UserId" class="btn btn-info text-white" style="cursor:pointer">Edit</a>
                            @if(user.LockoutEnd == null || user.LockoutEnd < DateTime.Now)
                            {
                                <button asp-action="LockUnlock" asp-route-userId="@user.UserId" class="btn btn-success text-white"
                                    style="cursor:pointer"><span>&nbsp; Lock &nbsp;</span>
                                </button>
                            }
                            else
                            {
                                <button asp-action="LockUnlock" asp-route-userId="@user.UserId" class="btn btn-warning text-white"
                                        style="cursor:pointer">
                                    <span>&nbsp; Unlock &nbsp;</span>
                                </button>
                            }
                            <button type="submit" onclick="return confirm('Are you sure you want autofocus delete?')" class="btn btn-danger">
                                Delete
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table> 
    </div>
</div>