@model ApplicationUser
<h3 class="text-info">Edit user</h3>

@{
    ViewData["Title"] = "Delete User";
}

<div class="card card-success card-outline">
    <div style="background:#4775d1;">
        <h4 style="color: white;padding-left:10px;"> Delete </h4>
    </div>
    <div class="card-body">
        <p class="text-danger">Are you sure you want to delete this user? This action cannot be undone.</p>

        <form method="post" asp-action="ConfirmDelete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}