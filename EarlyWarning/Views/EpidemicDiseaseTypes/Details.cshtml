@model EarlyWarning.Models.EpidemicDisease.EpidemicDiseaseType

@{
    ViewData["Title"] = "ዝርዝር መረጃ";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body bg-primary text-white rounded">
            <h3 class="mb-0">
                <i class="fas fa-virus"></i> የበሽታ ዝርዝር መረጃ
            </h3>
        </div>
    </div>

    <!-- Details Card -->
    <div class="card shadow-sm border-0">
        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-4 fw-bold text-muted">ስም</div>
                <div class="col-md-8">
                    <span class="fw-semibold">@Model.Name</span>
                </div>
            </div>

            <hr />

            <div class="row mb-3">
                <div class="col-md-4 fw-bold text-muted">መግለጫ</div>
                <div class="col-md-8">
                    @Model.Description
                </div>
            </div>

            <hr />

            <div class="row mb-3">
                <div class="col-md-4 fw-bold text-muted">ሁኔታ</div>
                <div class="col-md-8">
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success fs-6">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary fs-6">Inactive</span>
                    }
                </div>
            </div>

        </div>
    </div>

    <!-- Action Buttons -->
    <div class="d-flex justify-content-between mt-4">

        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> ተመለስ
        </a>

        <div>
            <a asp-action="Edit"
               asp-route-id="@Model.EpidemicDiseaseTypeId"
               class="btn btn-warning">
                <i class="fas fa-edit"></i> አስተካክል
            </a>

            <a asp-action="Delete"
               asp-route-id="@Model.EpidemicDiseaseTypeId"
               class="btn btn-danger">
                <i class="fas fa-trash"></i> ሰርዝ
            </a>
        </div>

    </div>

</div>