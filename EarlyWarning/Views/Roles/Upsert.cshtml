@model Microsoft.AspNetCore.Identity.IdentityRole

@{
    var title = "Create role";
}
<div class="card card-success card-outline">
    <div style="background:green;">
        <h4 style="color: white;padding-left:10px;"> Add new role </h4>
    </div>
    <div class="card-body">

        <form method="post">
            @if(Model!=null && !string.IsNullOrEmpty(Model.Id))
            {
                <input asp-for="@Model.Id" hidden />
            }
            <div class="border p-3 bg-white">
                <div class="form-group row">
                    <h3 class="text-info pl-3">@title</h3>
                </div>
                <div class="row">        
                    <div class="col-8">
                        <div class="form-group row py-2">
                            <div class="col-4">
                                <label asp-for="Id"></label>
                            </div>
                            <div class="col-8">
                                <input asp-for="Id" readonly class="form-control" />
                            </div>
                        </div>
                        <div class="form-group row py-2">
                            <div class="col-4">
                                <label asp-for="Name"></label>
                            </div>
                            <div class="col-8">
                                <input asp-for="Name" class="form-control" autocomplete="off"/>
                                <span asp-validation-for="Name" class=""></span>
                            </div>
                        </div>
                        <div class="form-group row py-2">
                            <div class="col-8 offset-4 row">
                                <div class="col">
                                    @if(Model!=null && !string.IsNullOrEmpty(Model.Id))
                                    {
                                        //update
                                        <input type="submit" class="btn btn-info wi-100" value="Update"/>
                                    }
                                    else
                                    {
                                        //create
                                        <input type="submit" class="btn btn-primary w-100" value="Create" />
                                    }
                                </div>
                                <div class="col">
                                    <a asp-action="index" class="btn btn-success w-100">Back</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

