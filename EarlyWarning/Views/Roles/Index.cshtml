@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>
<div class="card">
    <div style="background:#4775d1;">
        <h4 style="color: white;padding-left:10px;"> Roles</h4>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-6">
                <h3 class="text-primary">Role list</h3>
            </div>
            <div class="col-6 text-right">
                <a asp-action="Upsert" asp-controller="Roles" class="btn btn-primary">
                    <i class="fa fa-plus" aria-hidden="true"></i>
                    &nbsp; Add new role
                </a>
            </div>
        </div>
        <div class="p-4 border round">
    @if (Model.Any())
    {
        <table class="table table-striped table-sm table-bordered" id="example1">
            <tr>                
                <th>
                    Id
                </th>
                <th>
                    Name
                </th>
                <th>

                </th>
            </tr>
            @foreach(var item in Model)
            {
             <tr>
                 <td>
                     @item.Id
                 </td>

                    <td>
                        @item.Name
                    </td>
                    <td>
                       <div class="text-center">
                            <form asp-action="Delete" asp-route-Id="@item.Id">
                                <a asp-action="Upsert" asp-route-id="@item.Id" class="btn btn-info text-white" style="cursor:pointer">Edit</a>
                                <button type="submit" onclick="return confirm('Are you sure you want autofocus delete?')" class="btn btn-danger">Delete
                                </button>
                            </form>
                    </div>
                    </td>
                </tr>
            }
        </table>
    }

</div>
    </div>
</div>