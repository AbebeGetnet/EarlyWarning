@using EarlyWarning.Models.SupplyofGrain
@model IEnumerable<EarlyWarning.Models.SupplyofGrain.GrainIncreaseDecrease>

@{
    ViewData["Title"] = "የእህል አቅርቦት ለውጥ ምክንያቶች";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Custom Styles */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 25px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        position: relative;
        overflow: hidden;
    }

    .page-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        transform: rotate(45deg);
    }

    .page-header h1 {
        margin: 0;
        font-size: 1.6rem;
        position: relative;
        z-index: 1;
    }

    .page-header p {
        margin: 8px 0 0;
        opacity: 0.9;
        position: relative;
        z-index: 1;
    }

    .btn-create {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        color: white;
    }

    .stat-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        overflow: hidden;
        transition: transform 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 16px rgba(0,0,0,0.15);
    }

    .stat-header {
        padding: 12px 15px;
        text-align: center;
        color: white;
    }

    .stat-header.increase {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }

    .stat-header.decrease {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }

    .stat-header.total {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .stat-body {
        padding: 15px;
        text-align: center;
    }

    .stat-number {
        font-size: 1.8rem;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .stat-label {
        color: #6c757d;
        font-size: 0.85rem;
    }

    .table-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .table {
        margin-bottom: 0;
    }

    .table thead th {
        background: #f8f9fa;
        color: #495057;
        border-bottom: 2px solid #dee2e6;
        padding: 12px;
        font-weight: 600;
        font-size: 0.85rem;
        text-align: center;
    }

    .table tbody tr {
        transition: background-color 0.3s ease;
        cursor: pointer;
    }

    .table tbody tr:hover {
        background-color: #f8f9fa;
    }

    .table tbody td {
        padding: 10px 12px;
        vertical-align: middle;
        text-align: center;
        font-size: 0.85rem;
    }

    .badge-increase {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        padding: 5px 12px;
        border-radius: 20px;
        color: white;
        font-size: 0.75rem;
        display: inline-block;
    }

    .badge-decrease {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        padding: 5px 12px;
        border-radius: 20px;
        color: white;
        font-size: 0.75rem;
        display: inline-block;
    }

    .action-buttons {
        display: flex;
        gap: 5px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.7rem;
        transition: all 0.3s ease;
    }

    .btn-action:hover {
        transform: translateY(-2px);
    }

    .search-box {
        margin-bottom: 20px;
    }

    .search-box input {
        border-radius: 25px;
        padding: 8px 15px;
        border: 1px solid #ddd;
        width: 250px;
        transition: all 0.3s ease;
    }

    .search-box input:focus {
        border-color: #11998e;
        box-shadow: 0 0 0 0.2rem rgba(17, 153, 142, 0.25);
        outline: none;
    }

    .export-buttons {
        margin-bottom: 15px;
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .btn-export {
        border-radius: 8px;
        padding: 5px 12px;
        font-size: 0.8rem;
    }

    .table-footer {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 20px;
        border-radius: 0 0 12px 12px;
    }

    .footer-stats {
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        gap: 15px;
    }

    .footer-stat-item {
        text-align: center;
        flex: 1;
        min-width: 80px;
    }

    .footer-stat-number {
        font-size: 1.3rem;
        font-weight: bold;
    }

    .footer-stat-label {
        font-size: 0.7rem;
        opacity: 0.9;
    }

    @@media (max-width: 768px) {
        .stat-number {
            font-size: 1.3rem;
        }
        .action-buttons {
            flex-direction: column;
            align-items: center;
        }
        .search-box input {
            width: 100%;
        }
        .table thead th {
            font-size: 0.7rem;
            padding: 8px;
        }
        .table tbody td {
            padding: 6px 8px;
            font-size: 0.75rem;
        }
        .export-buttons {
            justify-content: center;
        }
        .footer-stat-number {
            font-size: 1rem;
        }
    }

    /* Animation */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .table-container {
        animation: fadeIn 0.5s ease-out;
    }
</style>

<div class="container-fluid">
    <!-- Page Header -->
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center flex-wrap">
            <div>
                <h1>
                    <i class="fas fa-chart-line"></i> @ViewData["Title"]
                </h1>
                <p>የእህል አቅርቦት ለውጥ ምክንያቶችን ይመልከቱ፣ ያስተዳድሩ እና አዲስ ምክንያት ይጨምሩ</p>
            </div>
            <div>
                <a asp-action="Create" class="btn-create">
                    <i class="fas fa-plus-circle"></i> አዲስ ምክንያት
                </a>
            </div>
        </div>
    </div>

    @{
        var totalReasons = Model.Count();
        var increaseReasons = Model.Count(x => x.ReasonType == ReasonType.Increase);
        var decreaseReasons = Model.Count(x => x.ReasonType == ReasonType.Decrease);
    }

    <!-- Statistics Cards -->
    <div class="row">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-header total">
                    <i class="fas fa-list fa-2x"></i>
                </div>
                <div class="stat-body">
                    <div class="stat-number">@totalReasons</div>
                    <div class="stat-label">ጠቅላላ ምክንያቶች</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-header increase">
                    <i class="fas fa-arrow-up fa-2x"></i>
                </div>
                <div class="stat-body">
                    <div class="stat-number">@increaseReasons</div>
                    <div class="stat-label">የጨመረ ምክንያቶች</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-header decrease">
                    <i class="fas fa-arrow-down fa-2x"></i>
                </div>
                <div class="stat-body">
                    <div class="stat-number">@decreaseReasons</div>
                    <div class="stat-label">የቀነሰ ምክንያቶች</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Export -->
    <div class="row mb-3">
        <div class="col-md-6">
            <div class="search-box">
                <div class="input-group">
                    <input type="text" id="searchInput" class="form-control" placeholder="🔍 ምክንያት ፈልግ..." />
                    <span class="input-group-text">
                        <i class="fas fa-search"></i>
                    </span>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="export-buttons">
                <button class="btn btn-success btn-export" onclick="exportToExcel()">
                    <i class="fas fa-file-excel"></i> Excel
                </button>
                <button class="btn btn-danger btn-export" onclick="exportToPDF()">
                    <i class="fas fa-file-pdf"></i> PDF
                </button>
                <button class="btn btn-info btn-export" onclick="printReport()">
                    <i class="fas fa-print"></i> አትም
                </button>
            </div>
        </div>
    </div>

    <!-- Table Container -->
    <div class="table-container">
        <div class="table-responsive">
            <table class="table table-hover" id="reasonTable">
                <thead>
                    <tr>
                        <th><i class="fas fa-tag"></i> የምክንያት ስም</th>
                        <th><i class="fas fa-chart-line"></i> የምክንያት አይነት</th>
                        <th><i class="fas fa-cogs"></i> ድርጊቶች</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.ReasonName</strong>
                            </td>
                            <td>
                                @if (item.ReasonType == ReasonType.Increase)
                                {
                                    <span class="badge-increase">
                                        <i class="fas fa-arrow-up"></i> ጨምሯል
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-decrease">
                                        <i class="fas fa-arrow-down"></i> ቀንሷል
                                    </span>
                                }
                            </td>
                            <td class="action-buttons">
                                <a asp-action="Edit" asp-route-id="@item.GrainIncreaseDecreaseId" class="btn btn-sm btn-warning btn-action" title="አርትዕ">
                                    <i class="fas fa-edit"></i> አስተካክል
                                </a>
                                <a asp-action="Details" asp-route-id="@item.GrainIncreaseDecreaseId" class="btn btn-sm btn-info btn-action" title="ዝርዝር">
                                    <i class="fas fa-eye"></i> ዝርዝር
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.GrainIncreaseDecreaseId" class="btn btn-sm btn-danger btn-action" title="ሰርዝ" onclick="return confirm('እርግጠኛ ነዎት? ይህን ምክንያት መሰረዝ ይፈልጋሉ?')">
                                    <i class="fas fa-trash"></i> ሰርዝ
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Empty State -->
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-chart-line fa-4x text-muted mb-3"></i>
                <h4 class="text-muted">ምንም ምክንያት አልተገኘም</h4>
                <p>እባክዎ አዲስ ምክንያት ለመጨመር ከላይ ያለውን ቁልፍ ይጫኑ</p>
            </div>
        }

        <!-- Table Footer -->
        
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Search functionality
            $("#searchInput").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#reasonTable tbody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });

            // Row click to go to details
            $('.table tbody tr').click(function(e) {
                if ($(e.target).closest('.action-buttons').length) {
                    return;
                }
                var detailsUrl = $(this).find('.btn-info').attr('href');
                if (detailsUrl) {
                    window.location.href = detailsUrl;
                }
            });
        });

        // Export to Excel
        function exportToExcel() {
            var table = document.getElementById('reasonTable');
            var html = table.outerHTML;
            var url = 'data:application/vnd.ms-excel,' + encodeURIComponent(html);
            var downloadLink = document.createElement('a');
            downloadLink.href = url;
            downloadLink.download = 'GrainSupplyReasons.xls';
            document.body.appendChild(downloadLink);
            downloadLink.click();
            document.body.removeChild(downloadLink);
        }

                    function exportToPDF() {
                var printContents = document.getElementById('reasonTable').outerHTML;
                var originalContents = document.body.innerHTML;

                var printWindow = window.open('', '', 'height=700,width=900');

                printWindow.document.write('<html><head><title>Grain Supply Reasons</title>');
                printWindow.document.write('<style>');
                printWindow.document.write('table { border-collapse: collapse; width: 100%; }');
                printWindow.document.write('th, td { border: 1px solid #ddd; padding: 8px; text-align: center; }');
                printWindow.document.write('th { background-color: #f2f2f2; }');
                printWindow.document.write('</style></head><body>');

                printWindow.document.write('<h2>Grain Supply Reasons List</h2>');
                printWindow.document.write(printContents);

                printWindow.document.write('</body></html>');

                printWindow.document.close();
                
            }

        
    </script>
}