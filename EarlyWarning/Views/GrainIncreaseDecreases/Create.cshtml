@model EarlyWarning.Models.SupplyofGrain.GrainIncreaseDecrease

@{
    ViewData["Title"] = "አዲስ ምክንያት ይመዝግቡ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 25px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
    }

        .page-header h1 {
            margin: 0;
            font-size: 1.6rem;
        }

        .page-header p {
            margin: 8px 0 0;
            opacity: 0.9;
        }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        overflow: hidden;
        max-width: 600px;
        margin: 0 auto;
    }

    .card-header-custom {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 20px;
        font-weight: 600;
    }

    .card-body-custom {
        padding: 25px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
    }

        .form-label i {
            margin-right: 5px;
            color: #11998e;
        }

    .form-control {
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 10px 12px;
        width: 100%;
    }

        .form-control:focus {
            border-color: #11998e;
            box-shadow: 0 0 0 0.2rem rgba(17, 153, 142, 0.25);
        }

    .radio-group {
        display: flex;
        gap: 20px;
        margin-top: 5px;
    }

    .radio-option {
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .radio-option input {
            width: 18px;
            height: 18px;
        }

    .text-danger {
        color: #dc3545;
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 25px;
    }

    .btn-custom {
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-submit {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
    }

    .btn-back {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white;
    }

    .btn-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    }

    @@media (max-width: 768px) {
        .action-buttons {
            flex-direction: column;
        }

        .btn-custom {
            width: 100%;
            text-align: center;
        }
    }
</style>

<div class="container-fluid">
    <div class="page-header">
        <h1>
            <i class="fas fa-plus-circle"></i> @ViewData["Title"]
        </h1>
        <p>እባክዎ አዲስ የእህል አቅርቦት ለውጥ ምክንያት ይሙሉ</p>
    </div>

    <div class="form-card">
        <div class="card-header-custom">
            <i class="fas fa-info-circle"></i> የምክንያት መረጃ
        </div>
        <div class="card-body-custom">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="ReasonName" class="form-label">
                        <i class="fas fa-tag"></i> @Html.DisplayNameFor(m => m.ReasonName)
                        <span class="text-danger">*</span>
                    </label>
                    <input asp-for="ReasonName" class="form-control" placeholder="ለምሳሌ፦ የመኸር ወቅት በመሆኑ" />
                    <span asp-validation-for="ReasonName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ReasonType" class="form-label">
                        <i class="fas fa-chart-line"></i> @Html.DisplayNameFor(m => m.ReasonType)
                        <span class="text-danger">*</span>
                    </label>
                    <div class="radio-group">
                        <label class="radio-option">
                            <input type="radio" asp-for="ReasonType" value="1" />
                            <span><i class="fas fa-arrow-up text-success"></i> ጨምሯል</span>
                        </label>
                        <label class="radio-option">
                            <input type="radio" asp-for="ReasonType" value="2" />
                            <span><i class="fas fa-arrow-down text-danger"></i> ቀንሷል</span>
                        </label>
                    </div>
                    <span asp-validation-for="ReasonType" class="text-danger"></span>
                </div>

                <div class="action-buttons">
                    <a asp-action="Index" class="btn-custom btn-back">
                        <i class="fas fa-arrow-left"></i> ወደ ዝርዝር ተመለስ
                    </a>
                    <button type="submit" class="btn-custom btn-submit">
                        <i class="fas fa-save"></i> መዝግብ
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}