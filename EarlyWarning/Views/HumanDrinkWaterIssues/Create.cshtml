@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Function to get Amharic day name
        function getAmharicDayName(dayIndex) {
            var days = ['እሑድ', 'ሰኞ', 'ማክሰኞ', 'ረቡዕ', 'ሐሙስ', 'አርብ', 'ቅዳሜ'];
            return days[dayIndex];
        }

        // Function to get Monday of current week
        function getCurrentMonday() {
            var today = new Date();
            var day = today.getDay();
            var diff = today.getDate() - day + (day === 0 ? -6 : 1);
            var monday = new Date(today);
            monday.setDate(diff);
            return monday;
        }

        // Function to get Sunday of current week
        function getCurrentSunday(monday) {
            var sunday = new Date(monday);
            sunday.setDate(monday.getDate() + 6);
            return sunday;
        }

        // Format date as YYYY-MM-DD
        function formatDate(date) {
            var year = date.getFullYear();
            var month = String(date.getMonth() + 1).padStart(2, '0');
            var day = String(date.getDate()).padStart(2, '0');
            return year + '-' + month + '-' + day;
        }

        // Format date for display as DD/MM/YYYY
        function formatDisplayDate(date) {
            var day = String(date.getDate()).padStart(2, '0');
            var month = String(date.getMonth() + 1).padStart(2, '0');
            var year = date.getFullYear();
            return day + '/' + month + '/' + year;
        }

        // Function to update date display
        function updateDateDisplay() {
            var startDateValue = $('#StartDate').val();
            var endDateValue = $('#EndDate').val();

            if (startDateValue) {
                var start = new Date(startDateValue);
                var formattedStart = formatDisplayDate(start);
                var startDayName = getAmharicDayName(start.getDay());

                $('#displayStartDate').text(formattedStart);
                $('#displayStartDateFormatted').text(startDayName);
            }

            if (endDateValue) {
                var end = new Date(endDateValue);
                var formattedEnd = formatDisplayDate(end);
                var endDayName = getAmharicDayName(end.getDay());

                $('#displayEndDate').text(formattedEnd);
                $('#displayEndDateFormatted').text(endDayName);

                if (startDateValue) {
                    var start = new Date(startDateValue);
                    var formattedStart = formatDisplayDate(start);
                    $('#displayDateRange').text(formattedStart + ' - ' + formattedEnd);
                }
            }
        }

        $(document).ready(function() {
            // Set default dates if not already set
            var startDateInput = $('#StartDate');
            var endDateInput = $('#EndDate');

            if (!startDateInput.val()) {
                var monday = getCurrentMonday();
                startDateInput.val(formatDate(monday));
            }

            if (!endDateInput.val()) {
                var monday = getCurrentMonday();
                var sunday = getCurrentSunday(monday);
                endDateInput.val(formatDate(sunday));
            }

            // Update the display card
            updateDateDisplay();

            // Auto-calculate end date when start date changes
            startDateInput.on('change', function() {
                if ($(this).val()) {
                    var startDate = new Date($(this).val());
                    var sunday = new Date(startDate);
                    sunday.setDate(startDate.getDate() + 6);
                    endDateInput.val(formatDate(sunday));
                    updateDateDisplay();
                }
            });

            // Update display when end date changes (if manually edited)
            endDateInput.on('change', function() {
                updateDateDisplay();
            });

            // Toggle sections based on HasWaterProblem
            function toggleSections() {
                var hasProblem = $('#hasWaterProblemSwitch').is(':checked');

                if (hasProblem) {
                    $('#affectedKebelesNumberRow').slideDown(300);
                    $('#populationSection').slideDown(300);
                    $('#reportSection').slideDown(300);
                    $('#summaryCard').slideDown(300);
                    $('#submitBtn').fadeIn(300);
                    $('#waterProblemLabel').html('<i class="fas fa-exclamation-triangle"></i> የሰው መጠጥ ውሃ ችግር አለ? (አዎ)');
                    $('#waterProblemLabel').css('color', '#dc3545');
                } else {
                    $('#affectedKebelesNumberRow').slideUp(300);
                    $('#kebeleSelectionRow').slideUp(300);
                    $('#populationSection').slideUp(300);
                    $('#reportSection').slideDown(300);
                    $('#summaryCard').slideUp(300);
                    $('#submitBtn').fadeIn(300);
                    $('#waterProblemLabel').html('<i class="fas fa-check-circle"></i> የሰው መጠጥ ውሃ ችግር አለ? (አይ)');
                    $('#waterProblemLabel').css('color', '#28a745');

                    // Reset all numbers to 0 when no problem
                    $('input[type="number"]').not('#NumberOfAffectedKebeles').val(0);
                    $('#NumberOfAffectedKebeles').val(0);
                }
            }

            // Calculate totals
            function calculateTotals() {
                var maleHouseholdHeads = parseInt($('#MaleHouseholdHeads').val()) || 0;
                var maleFamilyMembers = parseInt($('#MaleFamilyMembers').val()) || 0;
                var maleChildren = parseInt($('#MaleChildren').val()) || 0;
                var maleYouth = parseInt($('#MaleYouth').val()) || 0;
                var maleElderly = parseInt($('#MaleElderly').val()) || 0;
                var maleDisabled = parseInt($('#MaleDisabled').val()) || 0;

                var femaleHouseholdHeads = parseInt($('#FemaleHouseholdHeads').val()) || 0;
                var femaleFamilyMembers = parseInt($('#FemaleFamilyMembers').val()) || 0;
                var femaleChildren = parseInt($('#FemaleChildren').val()) || 0;
                var femaleYouth = parseInt($('#FemaleYouth').val()) || 0;
                var femaleElderly = parseInt($('#FemaleElderly').val()) || 0;
                var femaleDisabled = parseInt($('#FemaleDisabled').val()) || 0;

                var totalMales = maleHouseholdHeads + maleFamilyMembers + maleChildren + maleYouth + maleElderly + maleDisabled;
                var totalFemales = femaleHouseholdHeads + femaleFamilyMembers + femaleChildren + femaleYouth + femaleElderly + femaleDisabled;
                var totalPopulation = totalMales + totalFemales;
                var affectedKebeles = parseInt($('#NumberOfAffectedKebeles').val()) || 0;

                $('#totalMales').text(totalMales.toLocaleString());
                $('#totalFemales').text(totalFemales.toLocaleString());
                $('#totalPopulation').text(totalPopulation.toLocaleString());
                $('#affectedKebeles').text(affectedKebeles.toLocaleString());
            }

            // Auto-fill number of affected kebeles if needed
            $('#NumberOfAffectedKebeles').on('input', function() {
                calculateTotals();
            });

            // Trigger calculation on any number input change
            $('input[type="number"]').on('input', function() {
                calculateTotals();
            });

            // Initial setup
            $('#hasWaterProblemSwitch').on('change', function() {
                toggleSections();
                calculateTotals();
            });

            // Set default report date
            if (!$('#ReportDate').val()) {
                var now = new Date();
                var formattedDate = now.getFullYear() + '-' +
                                   String(now.getMonth() + 1).padStart(2, '0') + '-' +
                                   String(now.getDate()).padStart(2, '0') + 'T' +
                                   String(now.getHours()).padStart(2, '0') + ':' +
                                   String(now.getMinutes()).padStart(2, '0');
                $('#ReportDate').val(formattedDate);
            }

            // Initial toggle (default: no problem)
            toggleSections();
            calculateTotals();
        });

        // Form validation before submit
        $('#waterIssueForm').on('submit', function(e) {
            var hasProblem = $('#hasWaterProblemSwitch').is(':checked');
            var kebeleCount = parseInt($('#NumberOfAffectedKebeles').val()) || 0;
            var selectedKebeles = $('#AffectedKebeleIds option:selected').length;

            if (hasProblem) {
                var totalPopulation = parseInt($('#totalPopulation').text().replace(/,/g, '')) || 0;
                var affectedKebeles = parseInt($('#NumberOfAffectedKebeles').val()) || 0;

                if (totalPopulation === 0) {
                    e.preventDefault();
                    alert('እባክዎ ቢያንስ አንድ የተጎዳ ሰው ያስገቡ');
                    return false;
                }

                if (affectedKebeles === 0) {
                    e.preventDefault();
                    alert('እባክዎ የተጎዱ ቀበሌዎችን ቁጥር ያስገቡ');
                    return false;
                }
            }
            if (hasProblem && kebeleCount > 0 && selectedKebeles !== kebeleCount) {
                e.preventDefault();
                alert('የተመረጡ ቀበሌዎች ቁጥር ከተጎዱ ቀበሌዎች ቁጥር ጋር መመሳሰል አለበት');
                return false;
            }

            return true;
        });

        $('#NumberOfAffectedKebeles').on('input', function () {
            var kebeleCount = parseInt($(this).val()) || 0;

            if (kebeleCount > 0) {
                $('#kebeleSelectionRow').slideDown();
            } else {
                $('#kebeleSelectionRow').slideUp();
                $('#AffectedKebeleIds').val([]);
            }
        });
    </script>
}

