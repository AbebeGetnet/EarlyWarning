@using EarlyWarning.Enums
@model Locations

@{
    ViewData["Title"] = "Create";
}

<div class="card">
    <div class="btn btn-info">
        <h4 style="color: white;padding-left:10px;">አዲስ መዝግብ</h4>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-12">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="row col-md-12">
                        <div class="col-md-4">
                            <label asp-for="LocationName" class="control-label"></label>
                            <input asp-for="LocationName" class="form-control" autocomplete="off"/>
                            <span asp-validation-for="LocationName" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="LocationAmharicName" class="control-label"></label>
                            <input asp-for="LocationAmharicName" class="form-control" autocomplete="off"/>
                            <span asp-validation-for="LocationAmharicName" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="LocationCode" class="control-label"></label>
                            <input asp-for="LocationCode" class="form-control" autocomplete="off"/>
                            <span asp-validation-for="LocationCode" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PhoneNumber" class="control-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" autocomplete="off"/>
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CardHeaderTitle" class="control-label"></label>
                            <input asp-for="CardHeaderTitle" class="form-control" autocomplete="off"/>
                            <span asp-validation-for="CardHeaderTitle" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ParentId" class="control-label"></label>
                            <select asp-for="ParentId" class ="form-control" asp-items="ViewBag.ParentId"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Level" class="control-label"></label>
                            <select asp-for="Level" class ="form-control" asp-items="Html.GetEnumSelectList<LocationLevel>()"></select>
                        </div>
                        <div class="col-md-6">
                            <label>.</label>
                            <br />
                            <input type="submit" value="አስቀምጥ" class="btn btn-primary" />
                            <a asp-action="Index" class="btn btn-secondary">ተመለስ</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
