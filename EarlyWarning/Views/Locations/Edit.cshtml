@using EarlyWarning.Enums
@model EarlyWarning.ViewModels.AddressViewModel.AddressViewModel

@{
    ViewData["Title"] = "Edit";
}
<h6></h6>

<div class="card">
    <div class="btn btn-info">
        <h4 style="color: white;padding-left:10px;">ሙሉ መረጃ</h4>
    </div>
    <div class="card-body">
        <div class="col-md-12">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <div class="row">
                    <div class="form-group col-md-3">
                        <label asp-for="LocationAmharicName" class="control-label"></label>
                        <input asp-for="LocationAmharicName" class="form-control" required/>
                        <span asp-validation-for="LocationAmharicName" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="LocationName" class="control-label"></label>
                        <input asp-for="LocationName" class="form-control"  required/>
                        <span asp-validation-for="LocationName" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-2">
                        <label asp-for="CardHeaderTitle" class="control-label"></label>
                        <input asp-for="CardHeaderTitle" class="form-control" required />
                        <span asp-validation-for="CardHeaderTitle" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-2">
                        <label asp-for="LocationCode" class="control-label"></label>
                        <input asp-for="LocationCode" class="form-control"  required/>
                        <span asp-validation-for="LocationCode" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-4">
                        <label asp-for="Level" class="control-label"></label>
                        <select asp-for="Level" class="form-control" asp-items="@Html.GetEnumSelectList<LocationLevel>()" required></select>
                        <span asp-validation-for="Level" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-3">
                        <label class="control-label">እናት ተቋም</label>
                        <select asp-for="ParentId" class="form-control">
                            @foreach (var location in ViewBag.Locations)
                            {
                                <option value="@location.Id" name="@location.LocationAmharicName">@location.LocationAmharicName</option>
                            }
                        </select>
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="PhoneNumber" class="control-label"></label>
                        <input asp-for="PhoneNumber" class="form-control"  required/>
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label style="color:white">.</label><br />&nbsp;&nbsp;&nbsp;
                        <input type="submit" value="አስቀምጥ" class="btn btn-primary" />
                        <a asp-action="Index" class="btn btn-secondary">ተመለስ</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
