@using EarlyWarning.Enums
@using EarlyWarning.Models.SupplyofGrain
@model EarlyWarning.Models.SupplyofGrain.GrainSupply

@{
    ViewData["Title"] = "የእህል አቅርቦት ሪፖርት ዝርዝር መረጃ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Custom Styles */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 25px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            transform: rotate(45deg);
        }

        .page-header h1 {
            margin: 0;
            font-size: 1.6rem;
            position: relative;
            z-index: 1;
        }

        .page-header p {
            margin: 8px 0 0;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

    .detail-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .detail-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.15);
        }

    .card-header-custom {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 20px;
        font-weight: 600;
    }

        .card-header-custom i {
            margin-right: 8px;
        }

    .card-header-success {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    }

    .card-header-warning {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }

    .card-header-info {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }

    .card-body-custom {
        padding: 25px;
    }

    .info-row {
        display: flex;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
        transition: background-color 0.3s ease;
    }

        .info-row:hover {
            background-color: #f8f9fa;
            padding-left: 8px;
        }

    .info-label {
        width: 35%;
        font-weight: 600;
        color: #495057;
    }

    .info-value {
        width: 65%;
        color: #212529;
    }

    .badge-status {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.8rem;
    }

    .badge-increase {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
    }

    .badge-decrease {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
    }

    .badge-same {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .badge-draft {
        background: #6c757d;
        color: white;
    }

    .badge-submitted {
        background: #17a2b8;
        color: white;
    }

    .badge-approved {
        background: #28a745;
        color: white;
    }

    .badge-rejected {
        background: #dc3545;
        color: white;
    }

    .reason-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 5px;
    }

    .reason-tag {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
    }

        .reason-tag.increase {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .reason-tag.decrease {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .reason-tag i {
            margin-right: 5px;
        }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 20px;
    }

    .btn-custom {
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-edit {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
    }

    .btn-back {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white;
    }

    .btn-print {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        color: white;
    }

    .btn-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        color: white;
    }

    hr {
        margin: 15px 0;
    }

    @@media (max-width: 768px) {
        .info-row {
            flex-direction: column;
            padding: 8px 0;
        }

        .info-label, .info-value {
            width: 100%;
        }

        .info-label {
            margin-bottom: 5px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-custom {
            width: 100%;
            text-align: center;
        }
    }

    @@media print {
        .action-buttons, .page-header, .btn-print {
            display: none;
        }

        .detail-card {
            break-inside: avoid;
            box-shadow: none;
        }
    }
</style>

<div class="container-fluid">
    <!-- Page Header -->
    <div class="page-header">
        <h1>
            <i class="fas fa-chart-line"></i> @ViewData["Title"]
        </h1>
        <p>የእህል አቅርቦት ሪፖርት ዝርዝር መረጃ ከዚህ በታች ይመልከቱ</p>
    </div>

    <!-- Basic Information Card -->
    <div class="detail-card">
        <div class="card-header-custom">
            <i class="fas fa-info-circle"></i> መሰረታዊ መረጃ
        </div>
        <div class="card-body-custom">
            <div class="info-row">
                <div class="info-label">
                    <i class="fas fa-calendar-alt text-primary"></i> @Html.DisplayNameFor(m => m.StartDate)
                </div>
                <div class="info-value">
                    <strong>@Model.StartDate.ToString("dddd, MMMM dd, yyyy")</strong>
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">
                    <i class="fas fa-calendar-check text-success"></i> @Html.DisplayNameFor(m => m.EndDate)
                </div>
                <div class="info-value">
                    <strong>@Model.EndDate.ToString("dddd, MMMM dd, yyyy")</strong>
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">
                    <i class="fas fa-map-marker-alt text-danger"></i> @Html.DisplayNameFor(m => m.Woreda)
                </div>
                <div class="info-value">
                    <strong>@(Model.Woreda?.LocationAmharicName ?? "አልተመረጠም")</strong>
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">
                    <i class="fas fa-chart-line text-warning"></i> @Html.DisplayNameFor(m => m.GrainSupplyStatus)
                </div>
                <div class="info-value">
                    @if (Model.GrainSupplyStatus == SupplyStatus.Increased)
                    {
                        <span class="badge-status badge-increase">
                            <i class="fas fa-arrow-up"></i> ጨምሯል
                        </span>
                    }
                    else if (Model.GrainSupplyStatus == SupplyStatus.Decreased)
                    {
                        <span class="badge-status badge-decrease">
                            <i class="fas fa-arrow-down"></i> ቀንሷል
                        </span>
                    }
                    else
                    {
                        <span class="badge-status badge-same">
                            <i class="fas fa-equals"></i> ተመሳሳይ ነው
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Reasons Card -->
    @if (Model.GrainSupplyDetails != null && Model.GrainSupplyDetails.Any())
    {
        <div class="detail-card">
            <div class="card-header-custom card-header-warning">
                <i class="fas fa-question-circle"></i> የለውጡ ምክንያቶች
            </div>
            <div class="card-body-custom">
                <div class="info-row">
                    <div class="info-label">
                        <i class="fas fa-list"></i> የተመረጡ ምክንያቶች
                    </div>
                    <div class="info-value">
                        <div class="reason-tags">
                            @foreach (var detail in Model.GrainSupplyDetails)
                            {
                                if (detail.GrainIncreaseDecrease != null)
                                {
                                    var reasonType = detail.GrainIncreaseDecrease.ReasonType;
                                    <span class="reason-tag @(reasonType == ReasonType.Increase ? "increase" : "decrease")">
                                        <i class="fas @(reasonType == ReasonType.Increase ? "fa-arrow-up" : "fa-arrow-down")"></i>
                                        @detail.GrainIncreaseDecrease.ReasonName
                                    </span>
                                }
                            }
                        </div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.AdditionalNotes))
                {
                    <div class="info-row">
                        <div class="info-label">
                            <i class="fas fa-sticky-note"></i> ተጨማሪ ማስታወሻ
                        </div>
                        <div class="info-value">
                            @Model.AdditionalNotes
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(Model.AdditionalNotes))
    {
        <div class="detail-card">
            <div class="card-header-custom card-header-warning">
                <i class="fas fa-sticky-note"></i> ተጨማሪ ማስታወሻ
            </div>
            <div class="card-body-custom">
                <div class="info-row">
                    <div class="info-label">
                        <i class="fas fa-note"></i> ማስታወሻ
                    </div>
                    <div class="info-value">
                        @Model.AdditionalNotes
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Report Information Card -->
    <div class="detail-card">
        <div class="card-header-custom card-header-info">
            <i class="fas fa-file-alt"></i> የሪፖርት መረጃ
        </div>
        <div class="card-body-custom">
            <div class="info-row">
                <div class="info-label">
                    <i class="fas fa-calendar-day"></i> @Html.DisplayNameFor(m => m.ReportDate)
                </div>
                <div class="info-value">
                    @Model.ReportDate.ToString("dddd, MMMM dd, yyyy hh:mm tt")
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">
                    <i class="fas fa-user-edit"></i> @Html.DisplayNameFor(m => m.ReportedBy)
                </div>
                <div class="info-value">
                    @if (!string.IsNullOrEmpty(Model.ReportedBy))
                    {
                        <strong><i class="fas fa-user-circle"></i> @Model.ReportedBy</strong>
                    }
                    else
                    {
                        <span class="text-muted">አልተገለጸም</span>
                    }
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">
                    <i class="fas fa-check-circle"></i> @Html.DisplayNameFor(m => m.ApprovalStatus)
                </div>
                <div class="info-value">
                    @if (Model.ApprovalStatus == ApprovalStatus.በሂደት_ላይ)
                    {
                        <span class="badge-status badge-draft">በሂደት ላይ</span>
                    }
                    else if (Model.ApprovalStatus == ApprovalStatus.የተፈቀደ)
                    {
                        <span class="badge-status badge-submitted">የተፈቀደ</span>
                    }
                    else if (Model.ApprovalStatus == ApprovalStatus.የተከለከለ)
                    {
                        <span class="badge-status badge-approved">የተከለከለ</span>
                    }
                    else
                    {
                        <span class="badge-status badge-rejected">ውድቅ ተደርጓል</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="action-buttons">
        <a asp-action="Index" class="btn-custom btn-back">
            <i class="fas fa-arrow-left"></i> ወደ ዝርዝር ተመለስ
        </a>
        <a asp-action="Edit" asp-route-id="@Model.GrainSupplyId" class="btn-custom btn-edit">
            <i class="fas fa-edit"></i> አስተካክል
        </a>
        
    </div>
</div>

@section Scripts {
    <script>
        // Add print styles dynamically
        var style = document.createElement('style');
        style.innerHTML = `
            @@media print {
                .action-buttons, .page-header, .btn-print {
                    display: none !important;
                }
                .detail-card {
                    break-inside: avoid;
                    page-break-inside: avoid;
                    box-shadow: none;
                }
                body {
                    padding: 10px;
                }
            }
        `;
        document.head.appendChild(style);
    </script>
}